m,a)}})}function Uc1tn(a){const b=[];for(const c of a)c.He(Uce.iH)&&c.Vx().length>0&&(a=c.Vx().map(d=>d.id),b.push(`- ${c.id} contains: [${a.join(", ")}]`));return b.length===0?"":`\n\nItems contained in selected containers:\n${b.join("\n")}`}function Uc2tn(a,b,c){b?a="NOTE: ONLY selected items were processed. The following data DOES NOT REPRESENT the entire document.\n\n"+a:c.length>0&&(a+=`\n\n---\n\nSelected item IDs: [${c.map(d=>d.id).join(", ")}]`);b=Uc1tn(c);b.length>0&&(a+=b);return a}
