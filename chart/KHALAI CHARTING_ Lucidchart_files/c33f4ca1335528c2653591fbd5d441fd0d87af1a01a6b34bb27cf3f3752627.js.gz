function UcLzn(a,b,c,d){const e={[Ucco.key]:c.text,[Uc4Kd.key]:[UcCa.wL]};c.fillColor&&(e[UcQ.key]=c.fillColor);return a.uo.kA("StickiesStickyNoteBlock",b,e,d,void 0,!1)}function UcPzn(a,b,c,d,e,f){const g=Math.min(Math.ceil(Math.sqrt(c.length)),Math.max(1,Math.floor((f-16)/(UcGCl+16))));return c.map((h,k)=>UcLzn(a,b,h,{x:d+16+k%g*(UcGCl+16),y:e+16+Math.floor(k/g)*(UcHCl+16),w:UcGCl,h:UcHCl})).filter(Ucng)}
