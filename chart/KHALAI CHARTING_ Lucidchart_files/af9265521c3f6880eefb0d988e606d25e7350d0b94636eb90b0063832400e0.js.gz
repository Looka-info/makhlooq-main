var Uczjb={mf:"Default",t5m:"Amazon Central Lucid Account",yqn:"Migrating Documents Into Lucidspark",AEn:"United Airlines New Login Domain Announcement",YBn:"T-Mobile Account Enablement Banner"},UcAjb={mf:"Default"},UcBjb={mf:"Default"},UcCjb={mf:"Default",Tmn:"LC Pullthrough Onboarding",Y7m:"Brainstorm Use Case",Xon:"Lucidspark Business Persona Onboarding"},UcDjb=class{constructor(a){this.offset=0;this.Xla=a instanceof DataView?a:a instanceof Uint8Array?new DataView(a.buffer,0,a.length-0):new DataView(a,
0);this.UYf=new Uint8Array(this.Xla.buffer)}hasData(){return this.offset<this.UYf.byteLength}getUint8(){const a=this.Xla.getUint8(this.offset);this.offset+=1;return a}getUint16(){const a=this.Xla.getUint16(this.offset);this.offset+=2;return a}getUint32(){const a=this.Xla.getUint32(this.offset);this.offset+=4;return a}getInt8(){const a=this.Xla.getInt8(this.offset);this.offset+=1;return a}getInt16(){const a=this.Xla.getInt16(this.offset);this.offset+=2;return a}getInt32(){const a=this.Xla.getInt32(this.offset);
this.offset+=4;return a}getArray(a){const b=[],c=this.getUint16();for(let d=0;d<c;d++)b.push(a(this));return b}getMap(a,b){const c=new Map,d=this.getUint16();for(let e=0;e<d;e++)c.set(a(this),b(this));return c}};UcDjb.prototype.Wsf=Ucf(54);
var UcEjb=[{name:"diagramautolayout",displayName:"Auto Layout",description:"Stub — the `autolayout` API is not implemented yet.",Emf:"**Stub.** This API is not implemented yet. Its wiring (skill registration,\nloading, and dispatch) is in place, but the helper exposes no methods. The real\nimplementation lands in a later PR.",Be:"```js\n// Not implemented yet.\n```"},{name:"data",displayName:"Data",description:'Document data — read/create/edit/delete data sources and collections. Exposed to the user via the in-product "Manage Data" & "Data Linking" surfaces. Data powers many of our advanced generators.',
Emf:"A Lucid document carries any number of **data sources** (CSV imports, integration links, in-memory tables). Each source contains one or more **collections** (tables of rows). Data-bound generators bind to a _branched_ collection id, which is the read-only view of a source collection that auto-updates when the source changes.\n\nData-bound generators consume a collection id — pass them the **branched** `collectionId` returned by `createInMemoryDataSource`.\n\nFor data exposed by integrations (Salesforce, Jira, Google Sheets, file upload, …) look for an API/skill specific to that integration.\n\n## API at a glance\n\n```ts\nskills.data.list(): DataSourceInfo[]\nskills.data.get(id: string): DataSourceDetail | undefined\nskills.data.listCollections(): CollectionInfo[]\nskills.data.getCollection(id: string): CollectionDetail | undefined\n\nskills.data.createInMemoryDataSource(params: {\n    name: string,\n    primaryKey: string,\n    fields: Array<{name: string, type?: 'string' | 'number' | 'boolean' | 'date'}>,\n    items?: Array<{[field: string]: string | number | boolean | null}>,\n    foreignKeys?: Array<{fields: string[], referencesCollectionId: string | 'self'}>,\n}): {dataSourceId, collectionId, sourceCollectionId} | undefined\n\n// Rows\nskills.data.addItems(collectionId, items): boolean\nskills.data.updateItems(collectionId, items): boolean       // edit in place by primary key\nskills.data.removeItems(collectionId, primaryKeyRows): boolean\n\n// Schema\nskills.data.addFields(collectionId, fields): boolean\nskills.data.removeFields(collectionId, fieldNames): boolean\nskills.data.setFieldType(collectionId, fieldName, type): boolean    // 'string' | 'number' | 'boolean' | 'date'\nskills.data.renameField(collectionId, fieldName, label): boolean    // display label only\nskills.data.reorderFields(collectionId, fieldOrder): boolean        // field names in desired order\nskills.data.moveField(collectionId, fieldName, beforeFieldName?): boolean\nskills.data.addForeignKey(collectionId, fields, referencesCollectionId): boolean\n\n// Rename / delete\nskills.data.renameDataSource(dataSourceId, name): boolean\nskills.data.renameCollection(collectionId, name): boolean\nskills.data.deleteDataSource(dataSourceId): boolean\nskills.data.deleteCollection(collectionId): boolean\n```\n\n### Ids and writes\n\n- Returned `collectionId` is the **branched** id — pass it to data-bound generators.\n- Returned `sourceCollectionId` is the underlying writable collection. All mutators accept either id and route writes to the source.\n- `primaryKey` must match one of the `fields`; field `type` defaults to `'string'`.\n\n### Reading\n\n- Each source reports an `adapterType` string identifying its backing adapter — `'In-Memory'` for tables made with `createInMemoryDataSource`, otherwise the integration/import adapter name (e.g. `'CSV'`, `'Salesforce'`). Use it to tell hand-seeded tables apart from integration-backed ones.\n- `getCollection` returns `primaryKeyFields`, `foreignKeys`, and the field list (with types) — inspect these before binding a generator or declaring a foreign key against an existing collection.\n\n### Field types & dates\n\n- On write, a `'date'` field accepts a `'YYYY-MM-DD'` string (treated as date-only), a full ISO-8601 timestamp string, or a unix-millis number.\n- On read, dates serialize back through ISO-8601: a date-only value reads as `'YYYY-MM-DD'`, while a value carrying a time (a full ISO string or a unix-millis number) reads as a full UTC timestamp like `'2023-11-14T22:13:20.000Z'`. The read shape mirrors what was written — it does not normalize everything to one form.\n- `setFieldType` changes an existing field's declared type in place (the in-product type picker). Already-stored values keep their original form until they're rewritten; values written _after_ the change are stored under the new type. Rewrite affected rows with `updateItems` if you need existing data re-typed.\n- Enum / single-select fields aren't supported here — they're owned by the generator that defines them (e.g. lucid cards).\n\n### Rows\n\n- `addItems` / `updateItems` rows must include the primary-key field(s); a row missing it returns `false`. `updateItems` overwrites only the fields present on each row.\n- `removeItems` takes partial rows naming the primary key; extra fields are ignored and unknown rows are silently skipped.\n\n### Schema & foreign keys\n\n- `renameField` changes a field's display label only — the underlying key (and existing row data) is untouched, matching the in-product rename.\n- `removeFields` won't remove a primary-key field.\n- `reorderFields` takes field names in the desired left-to-right order; omitted fields keep their relative order after the listed ones. `moveField` slots one field before another (or to the end).\n- A foreign key declares that `fields` hold the primary key of `referencesCollectionId`; pass `'self'` (only in `createInMemoryDataSource`) for a self-reference such as a manager/parent field. Declared keys are visible on `CollectionInfo.foreignKeys`.\n\n### Delete\n\n- `deleteDataSource` removes a whole source and its collections — the clean way to undo a `createInMemoryDataSource`. `deleteCollection` removes one collection and its branched views together.",
Be:"```js\n// Build an in-memory roster a data-bound generator can later bind to.\nconst roster = [\n    {name: 'Pam', team: 'Reception'},\n    {name: 'Jim', team: 'Sales'},\n    {name: 'Dwight', team: 'Sales'},\n    {name: 'Angela', team: 'Accounting'},\n];\nconst ds = skills.data.createInMemoryDataSource({\n    name: 'Office',\n    primaryKey: 'name',\n    fields: [{name: 'name'}, {name: 'team'}],\n    items: roster,\n});\n// `ds.collectionId` is the branched id to hand to a data-bound generator;\n// `ds.sourceCollectionId` is the writable collection for row edits.\nskills.data.addItems(ds.sourceCollectionId, [{name: 'Kevin', team: 'Accounting'}]);\n```\n\n```js\n// A table with a date field and a self-referential foreign key (a reporting\n// chain), then edit one row and push the date out a week.\nconst org = skills.data.createInMemoryDataSource({\n    name: 'Headcount',\n    primaryKey: 'id',\n    fields: [\n        {name: 'id'},\n        {name: 'name'},\n        {name: 'manager'}, // references another row's id\n        {name: 'startDate', type: 'date'},\n    ],\n    foreignKeys: [{fields: ['manager'], referencesCollectionId: 'self'}],\n    items: [\n        {id: '1', name: 'Michael', manager: null, startDate: '2024-01-08'},\n        {id: '2', name: 'Jim', manager: '1', startDate: '2024-03-04'},\n    ],\n});\nskills.data.updateItems(org.sourceCollectionId, [{id: '2', startDate: '2024-03-11'}]);\n```\n\n```js\n// Inspect an existing collection's relational shape before binding to it:\n// read its primary key and foreign keys so a generator (or a new FK) lines up\n// with how the table is actually keyed, rather than guessing field names.\nconst people = skills.data.listCollections().find((c) => c.name === 'People');\nif (people) {\n    const detail = skills.data.getCollection(people.id);\n    const [pk] = detail.primaryKeyFields;\n    const reportsTo = detail.foreignKeys.find((fk) => fk.referencesCollectionId === people.id);\n    // e.g. only declare a manager FK if the table doesn't already have a self-reference\n    if (!reportsTo && detail.fields.some((f) => f.name === 'manager')) {\n        skills.data.addForeignKey(people.id, ['manager'], people.id);\n    }\n}\n```"},
{name:"lines",displayName:"Lines",description:"Detailed line operations — endpoint placement (specific link points, free positions, line-on-line), endpoint arrow styles, line shape, joints, line color/width/stroke style/opacity/rounding, swapping direction, and labels.",Emf:"A line on a Lucid document has **exactly two endpoints** (`from` and `to`), a\n**routing shape** (`'diagonal' | 'elbow' | 'curve'`), zero or more **text\nareas** along its length, and the usual style properties (color, width,\nstroke style, opacity, …). `document.addLine` covers the common case\n(center-to-center auto-linked line with an arrow on the `to` endpoint).\nAnything more specific goes through `skills.lines`.\n\nUse this API when you must create or edit lines with more precision than what the `document` API provides.\n\n## Endpoint specs\n\nEvery endpoint is a discriminated union:\n\n```js\n// Attached to a block:\n{kind: 'block', blockId: 'abc', linkX: 0.5, linkY: 0.5, autoLink: true, style: 'Arrow'}\n\n// Free-floating at a page-space point:\n{kind: 'position', x: 1200, y: 600, style: 'None'}\n\n// Attached to another line at fraction `lineP` along it:\n{kind: 'line', lineId: 'lineXyz', lineP: 0.5, style: 'Arrow'}\n```\n\n- `linkX` / `linkY` are 0..1 fractions of the block's bounding box —\n  `{0, 0}` is top-left, `{1, 1}` is bottom-right, `{0.5, 0.5}` is the\n  center. Defaults to the center when omitted.\n- `autoLink: true` (the default) lets the endpoint float to the nearest\n  sensible spot when the other endpoint moves. Set `false` to **pin** the\n  endpoint at the exact `linkX` / `linkY` you supplied. Pinning is fully\n  honored on `create` (which also disables auto-link at the line level).\n- `lineP` is 0..1 along the connected line. Defaults to `0.5`.\n- `style` is the endpoint cap. Omitting it differs by method: on `create`\n  it inherits the helper default (`'None'` on `from`, `'Arrow'` on `to`);\n  on `patch.from` / `patch.to` it **keeps the existing endpoint's cap\n  style** rather than resetting it to a default.\n\nCommon cap styles (no library load needed): `'None'`, `'Arrow'`,\n`'Equilateral Arrow'`, `'Hollow Arrow'`, `'Open Arrow'`. For the full set (UML, BPMN,\nERD, and decorative variants), call `skills.lines.listEndpointStyles()`.\n\n## API\n\n### `skills.lines.list()`\n\nReturns a `LineInfo[]`: id, from, to, shape, label. Only `'elbow'`,\n`'curve'`, and `'diagonal'` are settable shapes — `'cyclical'` (and any\n`Custom` shape) are read-only/derived states a line can report but you\ncannot set via `create` / `patch`.\n\n### `skills.lines.get(id)`\n\nReturns the full `LineDetail` for one line:\n\n```ts\n{\n    id, from, to, shape, label?,\n    lineColor: '#aarrggbb',\n    lineWidth: number,\n    strokeStyle: 'solid' | 'dashed' | …,\n    opacity: number,                 // 0..100\n    rounding?: number,\n    lineJumps?: boolean,\n    doubleLine?: boolean,\n    joints: [{x, y}, …],\n    textAreas: [{key, text, location, side}, …],\n}\n```\n\n`label` is a lossy convenience: it concatenates the text of **every** text\narea on the line into one string. For a line with multiple labels, read\n`get(id).textAreas` — that's the authoritative, per-label list.\n\n### `skills.lines.create(spec)`\n\nCreates a new line. Returns the new line id or `undefined`.\n\n```js\nconst id = skills.lines.create({\n    from: {kind: 'block', blockId: fromId, linkX: 1, linkY: 0.5, autoLink: false},\n    to: {kind: 'block', blockId: toId, linkX: 0, linkY: 0.5, autoLink: false},\n    shape: 'elbow',\n    label: 'then',\n    style: {lineColor: '#d62828', strokeStyle: 'dashed', lineWidth: 2},\n});\n```\n\n### `skills.lines.patch(id, patch)`\n\nPartial update. Every field is optional — touch only what you want.\n\n```js\nskills.lines.patch(id, {from: {kind: 'block', blockId: newFromId, linkX: 1, linkY: 0.5, autoLink: false}});\nskills.lines.patch(id, {shape: 'curve'}); // resets routing/joints\nskills.lines.patch(id, {\n    joints: [\n        {x: 300, y: 200},\n        {x: 600, y: 400},\n    ],\n});\nskills.lines.patch(id, {label: ''}); // clear the label\nskills.lines.patch(id, {style: {lineColor: 'unset', lineWidth: 'unset'}}); // re-inherit\n```\n\nA `shape` change here **resets routing state (joints)**, so the line re-routes\ncleanly.\n\n### `skills.lines.swap(id)`\n\nFlip arrow direction in one call (swaps `from` / `to` and reverses\njoints / bezier joints / text-area positions to match).\n\n### `skills.lines.setEndpointStyle(id, which, style)`\n\nChange just the cap style on one endpoint. `which` is `'from'` or `'to'`.\n\n```js\nskills.lines.setEndpointStyle(id, 'from', 'Arrow'); // make it double-arrowed\nskills.lines.setEndpointStyle(id, 'to', 'None'); // strip the head\n```\n\n### `skills.lines.addLabel(id, text, location?, side?)`\n\nAdds a label at `location` (0..1 along the line; defaults to `0.5`).\n`side` is `-1` (above), `0` (on), or `1` (below). Returns the text-area\nkey so you can remove it later.\n\n### `skills.lines.removeLabel(id, key)`\n\nRemove a single text area by key. Use `skills.lines.get(id).textAreas` to\ndiscover keys.\n\n### `skills.lines.listEndpointStyles()`\n\nReturns `{name, categories}[]` for every available cap style. Use it to find\na `style` value beyond the common set listed above (e.g. a specific UML, BPMN,\nor ERD arrowhead). The `name` goes straight into `setEndpointStyle` or an\nendpoint spec's `style`.\n\n### `skills.lines.listStrokeStyles()`\n\nReturns the `string[]` of valid `style.strokeStyle` values (`'solid'`,\n`'dashed'`, `'dotted'`, and the dash/dot/stripe variants). Use it to pick a\nvalue beyond the common three.\n\n## Pitfalls\n\n- `autoLink: true` makes the endpoint float — set it to `false` if you\n  want the line to actually land at the `linkX/linkY` you supplied.\n- A `shape` change clears the line's joints. If you want to keep joints in\n  the same `patch`, pass `joints` alongside `shape` — they're re-applied\n  after the shape change (see the diagonal-joints example below). To change\n  shape _without_ discarding joints, use `document.patchLine` instead.\n- `style.lineColor`, `lineWidth`, and `strokeStyle` all accept the literal\n  string `'unset'` to re-inherit from the document's line style preset.\n- `lineP` and `linkX/linkY` only apply to their respective endpoint kind;\n  the helper silently ignores fields that don't match `kind`.",
Be:"## Pin both ends to exact ports\n\n`autoLink: false` is what keeps each end on the port you named instead of\nletting it float to the nearest one.\n\n```js\nconst id = skills.lines.create({\n    from: {kind: 'block', blockId: fromId, linkX: 1, linkY: 0.5, autoLink: false}, // right-center\n    to: {kind: 'block', blockId: toId, linkX: 0, linkY: 0.5, autoLink: false}, // left-center\n    shape: 'elbow',\n});\nreturn id;\n```\n\n## Route a diagonal line through explicit joints\n\nA `patch` applies `shape` before `joints`, so the routing reset triggered by\nthe shape change won't wipe the joints you set in the same call.\n\n```js\nskills.lines.patch(lineId, {\n    shape: 'diagonal',\n    joints: [\n        {x: 300, y: 200},\n        {x: 600, y: 400},\n    ],\n});\n```"},
{name:"offset",displayName:"Positioning",description:"movement, translation, positioning, resize, rotation, batched changes. Only use this API when the global `document helper` is not sufficient.",Emf:"`skills.offset` is the agent's batch transform surface. Use it any time you\nwant to move, position, resize, or rotate **more than one item at a time**,\nor any time the operation is naturally relative (`\"shift everything right by\n200\"`, `\"rotate this group 90°\"`, `\"line these up so their combined top-left\nsits at (0, 0)\"`).\n\nFor single-block, absolute positioning, `document.moveBlock` and\n`document.patchBlock` are simpler.\n\nThe helper accepts arrays of ids that may **mix blocks and lines**.\nUnknown ids are silently skipped.\n\n## When to reach for it\n\n- Batch translation — `\"move these N items right by 200\"`.\n- Absolute group positioning — `\"place this group so its center is at (800, 400)\"`.\n- Group resize — `\"make these items together span 600 × 400\"`.\n- Rotation — `\"rotate this set of blocks 90° around their group center\"`.\n- Translating free-floating lines (lines whose endpoints are `{x, y}` points\n  rather than block ids).\n\nFor laying things out by algorithm consider `skills.autolayout` instead.\n\n## Anchors and pivots\n\nGroup-relative methods (`moveTo`, `resize`, `rotate`) accept a named `Anchor`\nto describe a point on the group's combined bounding box:\n\n```\n topLeft     top     topRight\n   left    center    right\nbottomLeft bottom  bottomRight\n```\n\n`moveTo` uses the anchor to decide *which* point of the bbox lands at the\ntarget coordinates (default `'topLeft'`).\n\n`resize` and `rotate` use the anchor (or a free `pivot: {x, y}` page-space\npoint) to decide which point stays fixed during the transform. `pivot`\nwins when both are supplied. `resize` defaults to `anchor: 'topLeft'`;\n`rotate` defaults to `anchor: 'center'`.\n\n## API\n\n### `skills.offset.move(ids, {dx?, dy?})`\n\nTranslate every resolved item by `(dx, dy)`. Omitted axes default to 0.\nReturns `{moved: string[]}` — the ids that actually translated (mixed blocks\nand lines are fine).\n\n```js\nreturn skills.offset.move(ids, {dx: 200});            // shift right by 200\nreturn skills.offset.move(ids, {dx: -40, dy: 80});    // move down-and-left\n```\n\n### `skills.offset.moveTo(ids, {x?, y?, anchor?})`\n\nTranslate the group as a whole so its combined bbox's `anchor` (default\n`'topLeft'`) lands at `(x, y)`. Omit `x` or `y` to leave that axis alone.\nPreserves the relative layout between items. Returns\n`{moved: string[]}`.\n\n```js\nskills.offset.moveTo(ids, {x: 0, y: 0});                          // top-left of group → origin\nskills.offset.moveTo(ids, {x: 800, y: 400, anchor: 'center'});    // center the group on a point\nskills.offset.moveTo(ids, {y: 600, anchor: 'bottom'});            // pin the group's bottom edge at y=600\n```\n\n### `skills.offset.resize(ids, {width?, height?, fixRatio?, anchor?, pivot?})`\n\nResize the group's combined bounding box to `width × height`. Either\ndimension may be omitted (keeps the current value). `anchor` (default\n`'topLeft'`) or a free `pivot` decides which point of the *current* bbox\nstays fixed; the rest of the group scales around it. `fixRatio: true`\nconstrains the aspect ratio. Returns `{resized: string[]}`. The group box is\nmeasured with rotation applied, so already-rotated members scale correctly.\n\n```js\nskills.offset.resize(ids, {width: 600});                          // stretch width, anchor top-left\nskills.offset.resize(ids, {width: 600, height: 400});             // both\nskills.offset.resize(ids, {width: 600, anchor: 'center'});        // grow symmetrically left + right\nskills.offset.resize(ids, {width: 600, pivot: {x: 100, y: 100}}); // resize keeping (100,100) fixed\n```\n\n### `skills.offset.rotate(ids, radians, {anchor?, pivot?})`\n\nRotate the group by `radians` clockwise (`Math.PI / 2` is a quarter-turn\nright; negative values rotate counter-clockwise). `anchor` (default\n`'center'`) or a free `pivot` point decides what the group rotates around;\n`pivot` wins over `anchor` when both are supplied. Returns\n`{rotated: string[]}`.\n\n```js\nskills.offset.rotate(ids, Math.PI / 2);                              // 90° around the group center\nskills.offset.rotate(ids, -Math.PI / 2, {anchor: 'topLeft'});        // -90° around the top-left corner\nskills.offset.rotate(ids, Math.PI, {pivot: {x: 1000, y: 500}});       // 180° around an arbitrary page point\n```\n\n## Mixed blocks and lines\n\nEvery method accepts ids in any combination — blocks and lines together.\nSome things worth knowing:\n\n- **Block-anchored lines follow their block for free** — even when only the\n  block's id is in the input, any line whose endpoint is attached to that\n  block translates / rotates along with it.\n- **Free lines need their own id** — a line whose endpoints are `{x, y}`\n  points (not attached to a block) only moves / resizes / rotates when its\n  own id is in the input. Such a line counts toward the group's combined\n  bounding box, so including it in a `resize` stretches its endpoints along\n  with the blocks.\n\n## Pitfalls\n\n- The group bounding box is recomputed on every call from the items'\n  current positions. Repeated `align`-style calls (using `moveTo` with\n  `anchor: 'topLeft'` etc.) will keep producing the same result, but\n  mixing with intermediate user edits can shift the reference frame.\n- Non-default anchors/pivots on `resize` and `rotate` take **two** undo\n  steps (the transform plus a corrective translation); the defaults\n  (`resize` top-left, `rotate` group center) take one.\n- Rotation angles are in **radians**, clockwise. Use `Math.PI / 2` /\n  `Math.PI` / `Math.PI * 1.5` for the obvious quarter turns.\n- Resizing a group containing items that don't support the resize (locked\n  generators, certain custom shapes) may be a partial no-op for those\n  individual items — the call still returns their ids in `resized`\n  because the request was accepted, but their bbox may not change.",
Be:"## Fan items into a row, then anchor the row at the origin\n\nCombine per-item `move` (relative) with a single group `moveTo` (absolute).\n\n```js\nconst ids = [\n    await document.addBlock({blockClass: 'StickyNote', location: {x: 100, y: 100}}),\n    await document.addBlock({blockClass: 'StickyNote', location: {x: 100, y: 100}}),\n    await document.addBlock({blockClass: 'StickyNote', location: {x: 100, y: 100}}),\n];\n// addBlock stacked them at the same coords — spread them out, then move the\n// whole row's top-left to (0, 0) in one call.\nskills.offset.move([ids[1]], {dx: 220});\nskills.offset.move([ids[2]], {dx: 440});\nreturn skills.offset.moveTo(ids, {x: 0, y: 0});\n```"},
{name:"orgcharts",displayName:"Org Charts",description:"Build and edit data-backed org charts — people, reporting lines, fields, layout, collapse/expand, and CSV/data binding.",Emf:"`skills.orgcharts` builds and edits Lucid's modern, data-backed **org charts**.\nEach person is a row of data, and the reporting lines (manager → report) come\nfrom a \"Supervisor ID\" column: a person reports to whichever row that column\npoints at. This API is the supported way to read the full hierarchy and to edit\nit.\n\nPeople are addressed by their **block id** — the same id `document.read()`\nreports for a person's card, and the id this API returns from the create/read\nmethods, `addPerson`, and `addReport`.\n\nReporting lines are managed for you: change who reports to whom with\n`setManager` (not by writing the \"Supervisor ID\" / id columns, which aren't\nexposed as editable fields). `setField` edits only display fields like `Title`.\n\n## Two ways to build a chart\n\n- **Bind to existing data (`createFromData`)** — the in-product \"link data to an\n  org chart\" / CSV flow. Point the chart at a collection you already have (e.g.\n  one created with `skills.data.createInMemoryDataSource`, or any collection from\n  `skills.data.listCollections`). You supply the name field, the id field, and\n  the self-referential *manager* field (the column whose value is the id of each\n  person's manager). This is the right path whenever the people already live in a\n  collection — edits to the rows reflow the chart, and `setField` can write any\n  column on the collection.\n\n- **Seed from a flat list (`create`)** — when you just have people in hand and no\n  collection. `create({people})` builds a fresh in-memory collection for you.\n  Each person has a `name`, an optional stable `id`, an optional `managerId`\n  (referencing another person's `id`; omit for a top-level person), and optional\n  `fields`. Declare any custom card fields here (or via `displayFields`) —\n  `setField` can only update fields that already exist. Both `create` and\n  `createFromData` accept an `orientation` (`'vertical'` | `'horizontal'`) so you\n  can build the chart in its final orientation in one call.\n\n## Reading\n\n- `read(generatorId)` — full nested tree: `roots[]`, each person with `name`,\n  `fields` (every column, keyed by name), `collapsed` (subtree hidden?), and\n  `reports[]`. `document.read()` only shows the generator's flat child-block ids,\n  so use `read` for structure.\n- `list()` — enumerate org charts on the current page (`generatorId`,\n  `personCount`, `rootNames`).\n- `listFields(generatorId)` — the field names you can pass to `setField` (always\n  starts with `Name`).\n\n## Editing people\n\n- `addPerson(generatorId, {name, managerId?, fields?})` /\n  `addReport(generatorId, managerId, name)` — add one person (a new root if no\n  manager). New siblings are appended after existing ones (the same default\n  ordering the in-product \"+\" button uses); there is no explicit \"insert before\n  sibling X\" control.\n- `setManager(generatorId, personId, newManagerId | undefined)` — reparent a\n  person and their whole subtree; pass `undefined` to promote them to a root.\n  Cycles (making someone report to their own report) are rejected.\n- `rename(generatorId, personId, name)` / `setField(generatorId, personId,\n  fieldName, value)` — edit a person's `Name` or another existing display field.\n  `setField` rejects the managed structural columns (the \"Supervisor ID\"\n  reporting key and internal id) — use `setManager` to change reporting lines.\n- `removePerson(generatorId, personId)` — delete a person; their reports\n  re-attach to the removed person's manager (matching the in-product delete).\n  Removing the last person deletes the chart.\n\n## Collapse / expand\n\n- `collapse(generatorId, personId)` / `expand(generatorId, personId)` — hide /\n  show one person's subtree. A collapsed person's card stays visible; their\n  reports are removed from the rendered chart until expanded. `read` still\n  reports the full structure and marks the person `collapsed: true`.\n- `collapseBelowLayer(generatorId, maxVisibleLayer | undefined)` — collapse\n  everything deeper than `maxVisibleLayer` levels (root = layer 1); show only the\n  top N levels. Pass `undefined` to expand everything. Returns the collapsed\n  person ids.\n- `listCollapsed(generatorId)` — the currently-collapsed person ids.\n\n## Layout\n\n`getLayout(generatorId)` / `setLayout(generatorId, patch)` change:\n\n- `orientation` — `'vertical'` (root on top, reports below — the default) or\n  `'horizontal'` (root on the left, reports to the right).\n- `layoutType` — how subtrees are packed:\n  - `'compact'` (default) — shifts subtrees together to minimize whitespace; the\n    densest, best general-purpose layout.\n  - `'separate'` — keeps each subtree in its own horizontal band so branches\n    never interleave; easier to read who-belongs-to-which-branch, but wider.\n  - `'leafList'` — stacks a manager's leaf reports into a vertical list directly\n    under them instead of spreading them across a row; ideal for tall charts and\n    managers with many individual contributors.\n- `siblingSeparation` / `neighborSeparation` / `levelSeparation` — spacing (px)\n  between siblings, between adjacent non-siblings, and between hierarchy levels.\n\nAny omitted field keeps its current value.",
Be:"Build a data-backed chart from an existing collection, then tidy the layout\n(mirrors the in-product \"link to data\" flow):\n\n```js\n// 1) Seed (or look up) the data. Each row names its manager by Employee ID.\nconst ds = skills.data.createInMemoryDataSource({\n    name: 'Employees',\n    primaryKey: 'EmpId',\n    fields: [{name: 'EmpId'}, {name: 'Full Name'}, {name: 'Manager'}, {name: 'Title'}],\n    items: [\n        {EmpId: '1', 'Full Name': 'Dana Reed', Manager: '', Title: 'CEO'},\n        {EmpId: '2', 'Full Name': 'Lee Park', Manager: '1', Title: 'VP Eng'},\n        {EmpId: '3', 'Full Name': 'Sam Cruz', Manager: '1', Title: 'VP Sales'},\n        {EmpId: '4', 'Full Name': 'Jordan Kim', Manager: '2', Title: 'Engineer'},\n    ],\n});\n\n// 2) Build the chart: the hierarchy is derived from Manager → EmpId.\nconst chart = skills.orgcharts.createFromData({\n    collectionId: ds.collectionId,   // branched id from skills.data\n    nameField: 'Full Name',\n    managerField: 'Manager',         // the self-referential \"Supervisor ID\" column\n    idField: 'EmpId',\n});\n\n// 3) Use a left-to-right, leaf-list layout (good for many ICs under a manager).\nskills.orgcharts.setLayout(chart.generatorId, {orientation: 'horizontal', layoutType: 'leafList'});\n\nreturn skills.orgcharts.read(chart.generatorId);\n```\n\nSeed a small chart from a flat list, re-org it, and collapse a subtree:\n\n```js\nconst oc = skills.orgcharts;\nconst chart = oc.create({\n    people: [\n        {id: 'ceo', name: 'Dana Reed', fields: {Title: 'CEO'}},\n        {id: 'eng', name: 'Lee Park', managerId: 'ceo', fields: {Title: 'VP Eng'}},\n        {id: 'sales', name: 'Sam Cruz', managerId: 'ceo', fields: {Title: 'VP Sales'}},\n    ],\n});\n\n// Add an engineer under the VP of Eng, then move them to report to the CEO.\nconst eng = chart.roots[0].reports.find((p) => p.name === 'Lee Park');\nconst icId = oc.addReport(chart.generatorId, eng.id, 'Jordan Kim');\noc.setField(chart.generatorId, icId, 'Title', 'Engineer');\noc.setManager(chart.generatorId, icId, chart.roots[0].id);\n\n// Collapse the Sales VP's subtree to declutter the view.\nconst sales = oc.read(chart.generatorId).roots[0].reports.find((p) => p.name === 'Sam Cruz');\noc.collapse(chart.generatorId, sales.id);\n\nreturn oc.read(chart.generatorId);\n```"},
{name:"text",displayName:"Text",description:"Detailed read and edit rich text on blocks and lines — content plus formatting (bold/italic/underline/strike, font family & size, text & highlight color, super/subscript, alignment), applied to a whole text area or to specific substrings.",Emf:"`skills.text` is the detailed read/write surface for text formatting on blocks\nand lines — everything in the text toolbar. `document.read()` flattens an item to a single\n`label`, and `document`'s `patchBlock` only exposes whole-block `TextAlign` /\n`TextVAlign`. Use this API to see and set per-text-area content, per-run styling,\nand alignment in one place.\n\nItems are addressed by **id** (from `document.read()` / `document.addBlock`) and,\nwhen an item has more than one text area, by **text-area name**. Most blocks and\nlines have a single text area — omit `textAreaName` to target it. Use\n`listTextAreas(itemId)` to discover the names and which are editable/styleable.\n\n## Styles\n\nStyle names and value formats (discover at runtime with `listStyles()`):\n\n- `bold`, `italic`, `underline`, `strike`, `superscript`, `subscript` — value\n  `'true'` / `'false'`.\n- `textColor`, `highlightColor` — a color string, e.g. `'#ff0000'`.\n- `fontSize` — a size in **points** as a string, e.g. `'18'`.\n- `fontFamily` — a font family name. Discover valid names with `listFonts()`.\n\nWhole-area styling (`fullTextStyles` / `setStyle`) applies a style uniformly to\nevery styleable text area on the item. Per-run styling (`partialTextStyles` /\n`styleSubstring`) applies a style to occurrences of a substring within one text\narea (1-based `occurrences` to target specific matches; `wholeWord` to match\nonly at word boundaries).\n\n## Reading — `read(itemId)` / `listTextAreas(itemId)`\n\n`read` returns `undefined` for an id that isn't a text-bearing block/line on the\ncurrent page. Otherwise it returns the item's `kind`, every `textArea`\n(`key`, `text`, `editable`, `styleable`, plus any active styles such as\n`bold: 'true'` or `fontSize: '18'`), and block `textAlign` / `textVAlign` when\nset. `listTextAreas` returns just the `textAreas` entries.\n\n## Editing\n\nThe do-everything method is `edit(itemId, edit)`; the rest are thin wrappers.\nFields in `edit` are all optional and applied content → whole-area styles →\nper-run styles → alignment:\n\n- `texts: [{textAreaName?, text}]` — replace a text area's content (formatting is\n  preserved). `setText(itemId, text, textAreaName?)` is the one-area shortcut.\n- `fullTextStyles: [{style, value}]` — whole-area styling.\n  `setStyle(itemId, style, value)` is the one-style shortcut.\n- `partialTextStyles: [{textAreaName?, substring, entry: {style, value}, occurrences?, wholeWord?}]`\n  — per-run styling (see Styles above). `styleSubstring(itemId, substring, style, value, {…})`\n  is the shortcut.\n- `textAlign: 'left'|'center'|'right'`,\n  `textVAlign: 'top'|'middle'|'bottom'` — block alignment (ignored for lines).\n  `setAlignment(itemId, {textAlign?, textVAlign?})` is the shortcut.\n\nAll editing methods return `{found, hasUpdates, skipReasons}`. `skipReasons`\nexplains any edit that didn't apply (missing/uneditable text area, substring not\nfound, style not editable on this shape, content already matched, an invalid\nalignment value, or alignment requested on a line).",
Be:"## Bold one word, recolor it, and bump the whole block's font size\n\n```js\nconst id = await document.addBlock({blockClass: 'SparkRectangleBlock', label: 'Status: BLOCKED'});\nskills.text.edit(id, {\n    fullTextStyles: [{style: 'fontSize', value: '20'}],\n    partialTextStyles: [\n        {substring: 'BLOCKED', entry: {style: 'bold', value: 'true'}},\n        {substring: 'BLOCKED', entry: {style: 'textColor', value: '#d32f2f'}},\n    ],\n    textAlign: 'center',\n});\nreturn skills.text.read(id);   // textAreas[0] shows fontSize '20'; 'BLOCKED' run is bold + red\n```\n\n## Inspect formatting before changing it\n\n```js\nconst before = skills.text.read(blockId);\n// Only enlarge if it isn't already big enough.\nconst size = Number(before?.textAreas[0]?.fontSize ?? '12');\nif (size < 14) {\n    skills.text.setStyle(blockId, 'fontSize', '14');\n}\nreturn skills.text.read(blockId);\n```"}],
