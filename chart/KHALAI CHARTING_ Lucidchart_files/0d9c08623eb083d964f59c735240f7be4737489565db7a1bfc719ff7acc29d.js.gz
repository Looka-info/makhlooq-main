    :root {
        color-scheme: light dark;
    }
    @property --process-capture-pulse-opacity {
        syntax: '<number>';
        inherits: true;
        initial-value: 1;
    }
    * {
        box-sizing: border-box;
    }
    body {
        --process-capture-pulse-opacity: 1;
        margin: 0;
        padding: 16px;
        font-family: -apple-system, BlinkMacSystemFont, 'Segoe UI', Roboto, sans-serif;
        background: var(--strata-background-primary, ${UcNre});
        color: var(--strata-foreground-primary, ${UcOre});
        display: flex;
        flex-direction: column;
        gap: 8px;
        user-select: none;
        overflow: hidden;
        animation: process-capture-pulse 1.1s ease-in-out infinite;
    }
    header {
        display: flex;
        align-items: center;
        gap: 8px;
    }
    .title {
        margin: 0;
        font-size: ${Ucbca["font-size"]};
        font-weight: ${Uc$ba["font-weight"]};
        line-height: ${Ucbca["line-height"]};
    }
    .beta-tag {
        display: inline-flex;
        align-items: center;
        padding: 2px 8px;
        border-radius: var(--strata-radius-md, 8px);
        border: 2px solid var(--strata-foreground-secondary, ${UcPre});
        color: var(--strata-foreground-secondary, ${UcPre});
        font-size: 12px;
        font-weight: 700;
        letter-spacing: 0.05em;
        flex-shrink: 0;
    }
    .status-group {
        display: flex;
        flex-direction: column;
        gap: 2px;
    }
    .status-row {
        display: flex;
        align-items: center;
        justify-content: space-between;
    }
    .status-left {
        display: flex;
        flex-direction: column;
        align-items: flex-start;
        gap: 4px;
    }
    .recording-label {
        display: flex;
        align-items: center;
        gap: 8px;
    }
    .recording-indicator {
        width: 10px;
        height: 10px;
        background: var(--strata-background-danger, ${UcUre});
        border-radius: 50%;
        opacity: var(--process-capture-pulse-opacity);
        flex-shrink: 0;
    }
    .recording-indicator.paused {
        background: var(--strata-border-subtle, ${UcWre});
        opacity: 1;
    }
    .recording-indicator.stopped {
        background: var(--strata-border-subtle, ${UcWre});
        opacity: 1;
    }
    @keyframes process-capture-pulse {
        0%, 100% { --process-capture-pulse-opacity: 1; }
        50% { --process-capture-pulse-opacity: 0.5; }
    }
    .status-text {
        font-size: ${Ucbca["font-size"]};
        font-weight: ${Uc$ba["font-weight"]};
    }
    .status-right {
        display: flex;
        align-items: center;
        gap: 8px;
    }
    .mic-icon {
        display: flex;
        align-items: center;
        color: var(--strata-foreground-secondary, ${UcPre});
    }
    .timer-ring {
        position: relative;
        width: 64px;
        height: 64px;
        display: grid;
        place-items: center;
        flex: 0 0 auto;
    }
    .timer-ring-svg {
        position: absolute;
        inset: 0;
        width: 64px;
        height: 64px;
    }
    .timer-ring-track,
    .timer-ring-progress {
        fill: none;
        stroke-width: 4;
    }
    .timer-ring-track {
        stroke: var(--strata-border-subtle, ${UcWre});
    }
    .timer-ring-progress {
        stroke: var(--strata-foreground-primary, ${UcOre});
        stroke-linecap: round;
        stroke-dasharray: 100;
        transform: rotate(-90deg);
        transform-origin: center;
    }
    .timer-ring.warning .timer-ring-progress {
        stroke: var(--strata-background-warning, ${UcVre});
    }
    .timer-ring.danger .timer-ring-progress {
        stroke: var(--strata-foreground-danger, ${UcUre});
    }
    .timer-ring.pulse .timer-ring-progress {
        stroke-opacity: var(--process-capture-pulse-opacity);
    }
    .timer-ring.paused .timer-ring-progress {
        stroke: var(--strata-border-neutral, ${UcXre});
        stroke-opacity: 1;
    }
    .timer {
        position: relative;
        z-index: 1;
        font-size: ${Ucbca["font-size"]};
        font-weight: ${Uc$ba["font-weight"]};
        font-variant-numeric: tabular-nums;
    }
    .frame-count {
        margin: 0;
        padding-top: 4px;
        font-size: ${Ucaca["font-size"]};
        font-weight: ${Ucaca["font-weight"]};
        line-height: ${Ucaca["line-height"]};
        color: var(--strata-foreground-secondary, ${UcPre});
    }
    .limit-message {
        margin: 0;
        min-height: ${Ucaca["line-height"]};
        visibility: hidden;
        font-size: ${Ucaca["font-size"]};
        font-weight: ${Uc$ba["font-weight"]};
        line-height: ${Ucaca["line-height"]};
        color: var(--strata-background-danger, ${UcUre});
    }
    .limit-message.visible {
        visibility: visible;
    }
    .button-icon {
        display: flex;
        align-items: center;
    }
    .button-icon svg {
        width: 24px;
        height: 24px;
    }
    .pause-button {
        width: 100%;
        height: 32px;
        padding: 0 16px;
        display: flex;
        align-items: center;
        justify-content: center;
        gap: 4px;
        margin-top: 8px;
        border: 1px solid var(--strata-border-accent, ${UcQre});
        border-radius: var(--strata-radius-md, 8px);
        background: transparent;
        color: var(--strata-foreground-accent, ${UcSre});
        font-size: ${Ucbca["font-size"]};
        font-weight: ${UcJBh["font-weight"]};
        font-family: inherit;
        cursor: pointer;
    }
    .pause-button:hover {
        background: var(--strata-background-accent, ${UcQre});
        color: var(--strata-foreground-on-accent, ${UcTre});
    }
    .pause-button:disabled {
        border-color: var(--strata-border-neutral, ${UcXre});
        color: var(--strata-foreground-secondary, ${UcPre});
        cursor: default;
        opacity: 1;
    }
    .pause-button:disabled:hover {
        background: transparent;
        color: var(--strata-foreground-secondary, ${UcPre});
    }
    .pause-button:focus-visible {
        outline: 2px solid var(--strata-border-focus, ${UcYre});
        outline-offset: 2px;
    }
    .finish-button {
        width: 100%;
        height: 32px;
        padding: 0 16px;
        border: none;
        border-radius: var(--strata-radius-md, 8px);
        background: var(--strata-background-accent, ${UcQre});
        color: var(--strata-foreground-on-accent, ${UcTre});
        font-size: ${Ucbca["font-size"]};
        font-weight: ${UcJBh["font-weight"]};
        font-family: inherit;
        cursor: pointer;
    }
    .finish-button:hover {
        background: var(--strata-background-accent-hover, ${UcRre});
    }
    .finish-button:disabled,
    .finish-button:disabled:hover {
        background: var(--strata-border-neutral, ${UcXre});
        color: var(--strata-foreground-secondary, ${UcPre});
        cursor: default;
    }
    .finish-button:focus-visible {
        outline: 2px solid var(--strata-border-focus, ${UcYre});
        outline-offset: 2px;
    }
    .strata-2-colors .pause-button {
        border-color: var(--strata-foreground-primary, ${UcOre});
        color: var(--strata-foreground-primary, ${UcOre});
    }
    .strata-2-colors .pause-button:hover {
        background: var(--strata-background-brand, ${UcZre});
        color: var(--strata-foreground-on-brand, ${Uc0re});
    }
    .strata-2-colors .pause-button:disabled,
    .strata-2-colors .pause-button:disabled:hover {
        border-color: var(--strata-border-neutral, ${UcXre});
        background: transparent;
        color: var(--strata-foreground-secondary, ${UcPre});
    }
    .strata-2-colors .finish-button {
        background: var(--strata-background-brand, ${UcZre});
        color: var(--strata-foreground-on-brand, ${Uc0re});
    }
    .strata-2-colors .finish-button:hover {
        background: var(--strata-background-brand-hover, ${Uc_re});
    }
    .strata-2-colors .finish-button:disabled,
    .strata-2-colors .finish-button:disabled:hover {
        background: var(--strata-border-neutral, ${UcXre});
        color: var(--strata-foreground-secondary, ${UcPre});
    }
