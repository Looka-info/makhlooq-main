kJr:"imageurl",d7e:"sprint",d_h:"team",pXh:"parent",XJq:"alias"};const UcZgb=new Set(Object.values(UcTb));
var Uc_gb={[UcGb.Kt]:UcTb.kda,[UcGb.Description]:UcTb.DESCRIPTION,[UcGb.Qj]:UcTb.Csn,[UcGb.Reporter]:UcTb.kqb,[UcGb.Time]:UcTb.CBs,[UcGb.Ut]:UcTb.Vir,[UcGb.so]:UcTb.rGc,[UcGb.Xl]:UcTb.fU,[UcGb.tZ]:UcTb.agb,[UcGb.Priority]:UcTb.WDa,[UcGb.Lz]:UcTb.pwa,[UcGb.ywa]:UcTb.lBs,[UcGb.SDa]:UcTb.kJr,[UcGb.MS]:UcTb.d7e,[UcGb.yq]:UcTb.d_h,[UcGb.X3]:UcTb.pXh,[UcGb.lpb]:UcTb.XJq},Uc0gb=Object.keys(Uc_gb).reduce((a,b)=>{a[Uc_gb[b]]=b;return a},{});var Uc1gb=new Uc7a("ExpandedSchemaReferenceEvaluator");var Uc2gb=new Uc7a("ExplicitImplicitLinkReferenceEvaluator");var Uc3gb=new Uc7a("ImplicitLinkReferenceEvaluator");var Uc4gb={type:"System",name:UcWa.BYq,isAvailable:a=>a.Kc.wSa(),Vj:Ucha.wf,description:"Canvas data scripting guidance. Use when reading, creating, linking, or updating shape data, reference keys, data sources, collections, data items, formulas, or linked data.",content:"# Canvas Data Skill\n\n**How to create data sources, link data to shapes, and read/update data programmatically.**\n\n## Data Model Overview\n\n```\nDataProxy\n  └── dataSources (MapProxy<string, DataSourceProxy>)\n       └── collections (MapProxy<string, CollectionProxy>)\n            └── items (MapProxy<string, DataItemProxy>)\n                 └── fields (MapProxy<string, value>)\n```\n\n- **DataProxy** — top-level access to all data on the document\n- **DataSourceProxy** — a named group of related collections (one per import)\n- **CollectionProxy** — a table of data items with a schema\n- **DataItemProxy** — a single row, accessed by primary key\n\n## Creating a DataProxy\n\n```js\nconst data = new sdk.DataProxy(client);\n```\n\nNot available as a script context variable — must be constructed from `sdk` and `client`.\n\n## Data Sources\n\n### Create\n\n```js\nconst source = data.addDataSource('My Data', { origin: 'my-extension' });\n// sourceConfig is arbitrary metadata; 'adapterType: EXTENSION_API' is auto-added\n```\n\n### List existing\n\n```js\nfor (const [id, source] of data.dataSources) {\n  const name = source.getName();\n  const config = source.getSourceConfig();\n}\n```\n\n### Find by name\n\n```js\nconst source = data.dataSources.find(s => s.getName() === 'Airline Operations');\n```\n\n## Collections\n\n### Create with schema\n\n```js\nconst collection = source.addCollection('Systems', {\n  fields: [\n    { name: 'SystemId', type: sdk.ScalarFieldTypeEnum.STRING },\n    { name: 'Name', type: sdk.ScalarFieldTypeEnum.STRING },\n    { name: 'Status', type: sdk.ScalarFieldTypeEnum.STRING },\n    { name: 'IncidentCount', type: sdk.ScalarFieldTypeEnum.NUMBER },\n    { name: 'HeatLevel', type: sdk.ScalarFieldTypeEnum.NUMBER },\n  ],\n  primaryKey: ['SystemId'],\n});\n```\n\n### Available field types (`sdk.ScalarFieldTypeEnum`)\n\n| Enum | Value | Use for |\n|---|---|---|\n| `STRING` | 3 | Text values |\n| `NUMBER` | 1 | Integers and decimals |\n| `BOOLEAN` | 2 | True/false |\n| `COLOR` | 4 | Color values |\n| `DATE` | 5 | Date + time |\n| `DATEONLY` | 9 | Date without time |\n| `TIMEONLY` | 10 | Time without date |\n| `CURRENCY` | 8 | Currency values |\n| `DICTIONARY` | 7 | Key-value objects |\n| `NULL` | 6 | Nullable (use in union: `[ScalarFieldTypeEnum.DATEONLY, ScalarFieldTypeEnum.NULL]`) |\n\n### Read schema back\n\n```js\nconst schema = collection.getSchema();\n// { fields: [{name, type}...], primaryKey: ['SystemId'] }\n\nconst fieldNames = collection.getFields();\n// ['SystemId', 'Name', 'Status', ...]\n```\n\n## Data Items\n\n### Add items\n\n```js\nconst result = collection.patchItems({\n  added: [\n    { SystemId: 'RADAR', Name: 'Weather Radar', Status: 'Operational', HeatLevel: 15 },\n    { SystemId: 'NAV', Name: 'Navigation System', Status: 'Degraded', HeatLevel: 65 },\n  ],\n});\n// Returns array of primary keys: ['\"RADAR\"', '\"NAV\"']\n```\n\n**Gotcha: Primary keys are JSON-stringified.** A string `\"RADAR\"` becomes the primary key `'\"RADAR\"'` (with wrapping quotes). Use `JSON.stringify(value)` or literal `'\"RADAR\"'` when looking up items.\n\n### Read items\n\n```js\nfor (const [pk, item] of collection.items) {\n  const name = item.fields.get('Name');\n  const status = item.fields.get('Status');\n  const exists = item.exists();\n}\n\n// Direct lookup by primary key\nconst item = collection.items.get('\"RADAR\"');\nitem.fields.get('Name'); // 'Weather Radar'\n```\n\n### Update items\n\n```js\ncollection.patchItems({\n  changed: new Map([\n    ['\"COMMS\"', { Status: 'Resolved', IncidentCount: 0, HeatLevel: 10 }],\n  ]),\n});\n// Only specified fields are updated; others keep their values\n```\n\n### Delete items\n\n```js\ncollection.patchItems({\n  deleted: ['\"FUEL\"'],\n});\n// item.exists() returns false after deletion\n```\n\n### Combined patch\n\nAll three operations can be done in a single call:\n\n```js\ncollection.patchItems({\n  added: [{ SystemId: 'NEW', Name: 'New System', Status: 'OK', HeatLevel: 0 }],\n  changed: new Map([['\"COMMS\"', { Status: 'Fixed' }]]),\n  deleted: ['\"OLD\"'],\n});\n```\n\n## Shape Data (Direct)\n\nShape data can be set directly on any element (block, line, group, page):\n\n```js\nblock.shapeData.set('Status', 'Active');\nblock.shapeData.set('Priority', 3);\nblock.shapeData.set('IsBlocked', true);\n\n// Read back\nblock.shapeData.get('Status');  // 'Active'\nblock.shapeData.get('Priority'); // 3\n```\n\n### Formulas in shape data\n\n```js\nblock.shapeData.set('DoublePriority', '=@Priority * 2');\nblock.shapeData.get('DoublePriority'); // 6 (evaluated)\n```\n\n### Execute formula on an element\n\n```js\nblock.executeFormula('@Priority + 10'); // 13\n```\n\n### Inheritable shape data\n\nShape data on a page or group can be inherited by children:\n\n```js\npage.shapeData.addInheritable('GlobalStatus', '=@Status');\n// Each block on the page gets its own 'GlobalStatus' evaluated in its own context\n```\n\n### Delete shape data\n\n```js\nblock.shapeData.delete('Priority');\n```\n\n### Iteration\n\n```js\nfor (const [key, value] of block.shapeData) { ... }      // direct only\nfor (const [key, value] of block.allShapeData) { ... }    // including inherited (read-only)\n```\n\n## Reference Keys (Linking Data to Shapes)\n\nReference keys connect elements to data items, making collection fields accessible via formulas.\n\n### Link a block to a collection data item\n\n```js\nblock.setReferenceKey('data', {\n  collectionId: collection.id,\n  primaryKey: '\"RADAR\"',  // JSON-stringified primary key\n});\n```\n\n### Read linked data via formula\n\n```js\nblock.executeFormula('@Name');       // 'Weather Radar'\nblock.executeFormula('@HeatLevel');  // 15\n```\n\n**Key insight:** Linked data does NOT appear in `block.shapeData` or `block.allShapeData`. It is only accessible via `executeFormula()` or template expressions in text areas.\n\n### Formula template in text areas\n\n```js\nblock.textAreas.set('Text', '{{=@Name}}');\n// Renders visually as \"Weather Radar\" in the Lucid UI\n// Reads back as literal '{{=@Name}}' via textAreas.get()\n```\n\n### Read reference keys back\n\n```js\nfor (const [key, refProxy] of block.referenceKeys) {\n  refProxy.collectionId;  // collection ID (may differ from what you set — see branching note)\n  refProxy.primaryKey;     // '\"RADAR\"'\n  refProxy.definition;     // full definition object\n}\n```\n\n**Branching caveat:** The `collectionId` read back may differ from what you passed to `setReferenceKey`. Lucid creates a local branch of the collection for edit tracking. The reference still works correctly.\n\n### Access the linked data item directly\n\n```js\nconst item = refProxy.getItem();\nitem.fields.get('Name');  // 'Weather Radar'\nitem.exists();            // true\n```\n\n### Remove a reference key\n\n```js\nblock.removeReferenceKey('data');\n```\n\n### What happens when linked data is deleted\n\nIf the data item is deleted, formulas return `undefined` — no error is thrown.\n\n```js\ncollection.patchItems({ deleted: ['\"FUEL\"'] });\nfuelBlock.executeFormula('@Name'); // undefined (graceful degradation)\n```\n\n## Flattened References (Inline Data)\n\nFor data that doesn't need a collection, embed it directly in the reference key:\n\n```js\nblock.setReferenceKey('inline', {\n  name: 'Inline Data',\n  schema: {\n    fields: [\n      { name: 'Label', type: sdk.ScalarFieldTypeEnum.STRING },\n      { name: 'Score', type: sdk.ScalarFieldTypeEnum.NUMBER },\n    ],\n    primaryKey: ['Label'],\n  },\n  data: { Label: 'Test Item', Score: 42 },\n});\n\nblock.executeFormula('@Label'); // 'Test Item'\nblock.executeFormula('@Score'); // 42\n```\n\nUseful for attaching metadata to shapes without creating a full data source/collection."};var Uc5gb={type:"System",name:UcWa.FYq,isAvailable:a=>a.Kc.wSa(),Vj:Ucha.wf,description:"Canvas heatmap scripting guidance. Use when overlaying status, severity, score, or operational data onto existing diagrams by matching blocks to data and applying color-coded styling.",content:"# Canvas Heatmap Skill\n\nLoad EditTextAreasSkill for detailed text-area guidance, including text styles, text measurement, line labels, and formula text.\nLoad CanvasExplorationSkill for detailed guidance on searching existing canvas items and gathering IDs before styling them.\n\n---\n\n**End-to-end workflow: overlay operational data onto an existing diagram as a color-coded heatmap.**\n\n## The Pattern\n\nRead an existing diagram, match blocks to external data, and modify visual properties without destroying the manual layout.\n\n```\n1. Define or fetch operational data (external)\n2. Read all blocks on the page\n3. For each block:\n   a. Skip non-data blocks (frames, labels)\n   b. Match block text to data key\n   c. Apply heatmap color based on severity\n   d. Store data as shape data for later reference\n4. Optionally style dependency lines based on severity\n5. Add a legend\n```\n\n## Step-by-Step\n\n### 1. Define the data\n\n```js\nconst operationalData = {\n  'Navigation':     { status: 'Degraded', incidents: 7,  heat: 65 },\n  'VHF Radio':      { status: 'Critical', incidents: 15, heat: 95 },\n  'Autopilot':      { status: 'Warning',  incidents: 3,  heat: 38 },\n  'Fuel System':    { status: 'Operational', incidents: 0, heat: 5 },\n};\n```\n\n### 2. Define the color scale\n\n```js\nfunction heatColor(heat) {\n  if (heat >= 80) return '#c0392b';  // red — critical\n  if (heat >= 50) return '#e67e22';  // orange — degraded\n  if (heat >= 30) return '#f39c12';  // yellow-orange — warning\n  return '#27ae60';                   // green — operational\n}\n```\n\n### 3. Read and match blocks\n\n```js\nconst allBlocks = [...page.allBlocks.values()];\n\nfor (const block of allBlocks) {\n  if (block.properties.get('ClassName') !== 'ProcessBlock') continue;\n\n  const text = block.textAreas.get('Text');\n  if (!text) continue;\n\n  const data = operationalData[text];\n  if (!data) continue;\n\n  block.properties.set('FillColor', heatColor(data.heat));\n  block.textStyles.set('Text', { color: '#ffffff', bold: true });\n\n  block.shapeData.set('Status', data.status);\n  block.shapeData.set('Incidents', data.incidents);\n  block.shapeData.set('HeatLevel', data.heat);\n}\n```\n\n### 4. Style dependency lines (optional)\n\n```js\nfor (const [id, line] of page.allLines) {\n  const ep2 = line.getEndpoint2();\n  if (!ep2.connection) continue;\n\n  const targetText = ep2.connection.textAreas.get('Text');\n  const targetData = targetText ? operationalData[targetText] : null;\n\n  if (targetData && targetData.heat >= 50) {\n    line.properties.set('LineColor', '#e74c3c');\n    line.properties.set('LineWidth', 2);\n  }\n}\n```\n\n### 5. Add a legend\n\n```js\nawait client.loadBlockClasses(['ProcessBlock']);\n\nlet maxY = 0;\nfor (const block of allBlocks) {\n  const bb = block.getBoundingBox();\n  maxY = Math.max(maxY, bb.y + bb.h);\n}\n\nconst legendY = maxY + 20;\nconst items = [\n  { label: 'Critical (80+)', color: '#c0392b' },\n  { label: 'Degraded (50-79)', color: '#e67e22' },\n  { label: 'Warning (30-49)', color: '#f39c12' },\n  { label: 'Operational (<30)', color: '#27ae60' },\n];\n\nfor (let i = 0; i < items.length; i++) {\n  const swatch = page.addBlock({\n    className: 'ProcessBlock',\n    boundingBox: { x: 70 + i * 200, y: legendY, w: 180, h: 30 },\n  });\n  swatch.textAreas.set('Text', items[i].label);\n  swatch.properties.set('FillColor', items[i].color);\n  swatch.textStyles.set('Text', { color: '#ffffff', size: 11, bold: true });\n}\n```\n\n## Matching Strategies\n\n### By text (simplest)\n\n```js\nconst data = operationalData[block.textAreas.get('Text')];\n```\n\n**Pros:** Simple, works for well-labeled diagrams.\n**Cons:** Fragile — breaks if text is edited, has line breaks, or includes extra info.\n\n### By shape data key\n\n```js\nconst sysId = block.shapeData.get('SystemId');\nconst data = operationalData[sysId];\n```\n\n**Pros:** Survives text edits.\n**Cons:** Requires shape data to be pre-populated.\n\n### By reference key (most robust)\n\n```js\nblock.setReferenceKey('health', {\n  collectionId: collection.id,\n  primaryKey: JSON.stringify(sysId),\n});\nconst heatLevel = block.executeFormula('@HeatLevel');\n```\n\n**Pros:** Full data model, survives text/layout changes, enables formula-driven text.\n**Cons:** More setup, requires data source creation.\n\n### By position (spatial matching)\n\n```js\nconst bb = block.getBoundingBox();\nif (bb.x >= regionX && bb.y >= regionY && ...) { ... }\n```\n\n**Pros:** Works when text isn't reliable.\n**Cons:** Breaks on layout changes.\n\n## Diagram Creation Best Practices\n\nWhen creating the base diagram programmatically:\n\n1. **Use `measureText()` to size blocks.** Create blocks at temp size, measure the longest label, resize all uniformly.\n2. **Compute frame sizes from block sizes.** `frameW = cols * blockW + (cols-1) * gap + 2 * padding`.\n3. **Smart anchor selection for lines.** Compare block positions to choose horizontal vs. vertical connections.\n4. **Account for frame title area.** Place frames at least 45 units below any above blocks to avoid overlapping the frame title.\n"};var Uc6gb={type:"System",name:UcWa.GYq,isAvailable:a=>a.Kc.wSa(),Vj:Ucha.EG,description:"Canvas viewport scripting guidance. Use when reading the visible area, focusing the camera on specific items, or getting or setting the user selection programmatically.",content:"# Canvas Viewport Skill\n\n**How to read and control the camera view and selection state.**\n\n## Camera / Visible Area\n\n```js\nconst rect = viewport.getVisibleRect();\n// { x, y, w, h } — the current camera view in canvas coordinates\n```\n\n```js\nviewport.focusCameraOnItems([block1, block2, frame]);\n// Animates the camera to zoom to show all given items with 80 unit padding\n```\n\n**Note:** `getVisibleRect()` may return stale values immediately after `focusCameraOnItems()` in the same script call.\n\n## Selection\n\n```js\nconst selected = viewport.getSelectedItems();\nviewport.setSelectedItems([block1, block2]);\nviewport.setSelectedItems([]);  // clear selection\n```\n\n`viewport.getSelectedItems()` returns item proxy objects. Use the returned proxy directly when an SDK method accepts a proxy, such as a line endpoint connection:\n\n```js\nconst selected = viewport.getSelectedItems();\nconst source = selected[0];\npage.addLine({\n  endpoint1: { connection: source, linkX: 1, linkY: 0.5 },\n  endpoint2: { x: 300, y: 100 },\n});\n```\n\nIf you need to return or persist a selection for a later script call, return item IDs:\n\n```js\nconst selected = viewport.getSelectedItems();\nreturn JSON.stringify(selected.map((item) => item.id));\n```\n"};var Uc7gb={type:"System",name:UcWa.m8q,isAvailable:a=>a.Kc.wSa(),Vj:Ucha.wf,description:"REQUIRED when creating, editing, searching, resizing, styling, updating, or deleting blocks programmatically.",content:"# Create and Edit Blocks Skill\n\n\n**How to create, read, move, resize, style, and set text on blocks.**\n\n## Creating Blocks\n\nIt is smart to start each block at the size given in the `shape_details` tool. If the contents or layout of the document require increasing the size of the shape, then shape can be resized after content is added.\n\n```js\nconst block = page.addBlock({\n  className: 'ProcessBlock',\n  boundingBox: { x: 100, y: 200, w: 150, h: 80 },\n});\n\n```\n\n### Prerequisites\n\nBefore creating any blocks, you MUST load the block classes:\n\n```js\nawait client.loadBlockClasses(['ProcessBlock', 'DecisionBlock', ...]);\n```\n\nWithout this, `page.addBlock()` throws \"Block class X not yet loaded\".\n\n## Block Types\n\nDiscover block classes using ShapeLibraryTool or explore existing blocks with run_script-explore-canvas-skill.\nOnce blocks/blockClasses are determined ALWAYS fetch the ShapeDetails for each block class to determine what properties, text areas, and connection points are available.\n\n## Shapes RunScript Cannot Create\n\nIf ShapeLibrary or ShapeDetails returns `RunScriptCanCreate: false`, that shape cannot be created with run_script and you must instead use create_block.\n\n## Reading General Properties\n\nOnly the following general block properties can and should be set using RunScript:\n- `block.id` — unique string ID\n- `block.getBoundingBox()` — returns `{ x, y, w, h }`\n- `block.textAreas.get('Text')` — read text content\n- `block.properties.get('ClassName')` — actual block class name\n- `block.properties.get('FillColor')` — fill color (returns with alpha, e.g. `#ff0000ff`)\n- `block.properties.get('LineColor')` — outline/border color (returns with alpha, e.g. `#ff0000ff`)\n- `block.properties.get('LineWidth')` — line width (number)\n- `block.textAreas.entries()` — **does NOT work** (not a standard Map)\n- `block.properties.get('')` — should NEVER be used with properties discovered in a shape's schema\n\nBlock object keys: `id`, `client`, `properties`, `shapeData`, `allShapeData`, `referenceKeys`, `textAreas`, `textStyles`\n\n### Shape Property Guardrails\n\nNever set shape-specific schema properties in `run_script`. Shape-specific schema properties are any properties listed in `ShapeSchemaProperties` from ShapeDetails. Set those properties only with `set_block_shape_property` / SetBlockShapeProperty after the target block exists.\n\nBefore any `run_script` that creates or edits blocks:\n- Call `shape_details` for every involved shape class or placed block.\n- Make a property plan with two lists:\n  - `scriptSafeProperties`: generic visual, layout, and text edits allowed in `run_script`.\n  - `toolOnlySchemaProperties`: properties from `ShapeSchemaProperties` that require `set_block_shape_property`.\n- If a property appears in `ShapeSchemaProperties`, it belongs in `toolOnlySchemaProperties`, even if it looks simple.\n\nScript-safe properties:\n- Bounding box: position and size via `setBoundingBox()`\n- Rotation via `setRotation()`\n- Generic style properties: `FillColor`, `LineColor`, `LineWidth`, `StrokeStyle`\n- Text areas discovered through `TextAreaDescriptors`\n- Text styles through `textStyles`\n- Line creation, endpoints, labels, and generic line style\n\nTool-only schema properties:\n- Any property returned by `ShapeSchemaProperties`\n- Examples, when present in ShapeDetails: `LaneCount`, `ColumnWidths`, `RowHeights`, ERD/entity fields, card fields, generated diagram markup, and table, container, or smart-shape configuration\n\nRequired workflow when tool-only properties are needed:\n- Wave 1: Create or find the target block and return its ID.\n- Wave 2: Use `set_block_shape_property` once per schema property.\n- Wave 3: Read or script final layout, text, connectors, and validation after the schema property changes have landed.\n\nBefore calling `run_script`, self-check:\n- Did I call `shape_details` for every shape class or block I will edit?\n- Am I about to set any property name that appeared in `ShapeSchemaProperties`?\n- If yes, stop and use `set_block_shape_property` instead.\n- If no, proceed with `run_script`.\n\nDo not claim schema properties were successfully changed unless `set_block_shape_property` succeeded or a later read/validation confirms the intended result.\n\n### Applying Default Shape Styling\n\nBefore creating a block, fetch the ShapeDetails for the block's className. Unless necessary to better portray meaning or fit existing layout, ALWAYS default to using the default properties and size from ShapeDetails.\n\n### Setting Shape-Specific Properties\n\nShape-specific properties are the entries returned in `ShapeSchemaProperties` from ShapeDetails. Use them for properties that are not generic block styling, such as entity fields, lane counts, column widths, row heights, card fields, generated diagram markup, or other shape-defined controls.\n\n- Always call ShapeDetails before setting shape-specific properties. Use `ToolboxId` for a shape you have not created yet, or `BlockId` for a placed shape when you need `currentValue` or live `validValues`.\n- Copy the property name exactly from `ShapeSchemaProperties[].name`. Do not guess property names from visible labels or UI control names.\n- Do not set entries marked `readOnly`.\n- SetBlockShapeProperty applies one property to one shape. For multiple properties, issue multiple SetBlockShapeProperty calls.\n\n## Moving, Resizing, and Rotating\n\n```js\n// Move: change x/y, keep w/h\nblock.setBoundingBox({ x: newX, y: newY, w: bb.w, h: bb.h });\n\n// Resize: change w/h\nblock.setBoundingBox({ x: bb.x, y: bb.y, w: 200, h: 200 });\n\nIMPORTANT: If a shape has an inner set of columns or rows, use ShapeDetails to determine if there are schema properties available to set inner column widths or row heights. If so, set those properties with SetBlockShapeProperty in addition to resizing the block with setBoundingBox().\n\n// Rotate: set an absolute rotation around the block's center, in radians\nblock.setRotation(45 * Math.PI / 180);\n\n// Read the current rotation, in radians\nconst rotationRadians = block.getRotation();\n```\n\n**Gotcha:** Some blocks enforce constraints on resize:\n- `StickiesStickyNoteBlock` enforces 1:1 aspect ratio\n- `AutoGrowTextBlock` and `DefaultCodeBlock` auto-size vertically\n\n**Rotation uses radians in RunScript.** Convert user-facing degree requests with `degrees * Math.PI / 180`. Use `setRotation(0)` to remove rotation.\n\n## Z-Order / Stacking Order\n\nUse `changeZOrder()` to adjust whether a block appears in front of or behind other overlapping items:\n\n```js\n// Bring a block all the way to the front of the items it overlaps\nblock.changeZOrder(sdk.ZOrderOperation.TOP);\n\n// Send a block all the way to the back of the items it overlaps\nblock.changeZOrder(sdk.ZOrderOperation.BOTTOM);\n\n// Move one step forward or backward in the stack\nblock.changeZOrder(sdk.ZOrderOperation.UP);\nblock.changeZOrder(sdk.ZOrderOperation.DOWN);\n```\n\n`changeZOrder()` works on item proxies such as blocks, lines, and groups. For block scripts, call it on the block proxy you found or created. Prefer this SDK method over setting a raw numeric `ZOrder` property in RunScript; it matches Lucid's bring-forward/send-backward behavior and only adjusts the item's order relative to overlapping items on the page.\n\n## Fill Color\n\n```js\nblock.properties.set('FillColor', '#ff0000');\n// Reads back as '#ff0000ff' (with alpha channel appended)\n```\n\n## Outline / Border Style\n\nFor block outlines, borders, and arrow-shaped block outlines, set these properties:\n\n| Property | Example | Notes |\n|---|---|---|\n| `LineColor` | `\"#ff0000\"` | Outline/border color. Reads back with alpha, e.g. `#ff0000ff`. |\n| `LineWidth` | `3` | Outline/border thickness in pixels. Use `0` for no visible border. |\n| `StrokeStyle` | `\"dashed\"` | Border pattern. User-selectable values: `\"solid\"`, `\"dashed\"`, `\"longdash\"`, `\"dashdot\"`, `\"dashdotdot\"`, `\"dashlongdash\"`, `\"dashed32\"`, `\"dashed44\"`, `\"dashed24\"`, `\"dotted\"`, `\"dotdotdot\"`. |\n\n```js\nblock.properties.set('LineColor', '#ff0000');\nblock.properties.set('LineWidth', 3);\nblock.properties.set('StrokeStyle', 'dashed');\n// Reads back as '#ff0000ff' (with alpha channel appended)\n```\n\nDo not use `StrokeColor` for block outline color. `StrokeColor` may appear in rendered shape data, but `LineColor` is the editable block property. If a style change does not apply, inspect whether the block disables `LineColor`, `LineWidth`, or `StrokeStyle` controls before retrying.\n\n## Deleting Blocks\n\n```js\nblock.delete();\n```\n\nDeleting a block does NOT delete its connected lines. Lines connected to the deleted block become dangling: the endpoint connection becomes falsy, the endpoint keeps its last absolute position, and the line remains visible.\n\nFor clean deletion, delete connected lines first:\n\n```js\nconst lines = block.getConnectedLines();\nfor (const line of lines) {\n  line.delete();\n}\nblock.delete();\n```\n\n## Iterating Blocks\n\n```js\n// All blocks on current page\nfor (const block of page.allBlocks.values()) { ... }\n\n// As array\nconst blocks = [...page.allBlocks.values()];\n```\n\nNote: iteration order is NOT sorted by position — do not assume any particular order when looping through `page.allBlocks`.\n"};var Uc8gb={type:"System",name:UcWa.n8q,isAvailable:a=>a.Kc.wSa(),Vj:Ucha.wf,description:"Canvas line scripting guidance. Use when creating or editing lines, endpoints, connections, routing, arrowheads, labels, style, or deletion programmatically.",content:"# Create and Edit Lines Skill\n\nLoad EditTextAreasSkill for detailed line label and text-area guidance.\n\n---\n\n**How to create, read, style, and connect lines between blocks.**\n\n## Creating Lines\n\n```js\nconst line = page.addLine({\n  endpoint1: {\n    connection: block1,\n    linkX: 1.0,  // right edge\n    linkY: 0.5,  // vertical center\n  },\n  endpoint2: {\n    connection: block2,\n    linkX: 0.0,  // left edge\n    linkY: 0.5,\n  },\n});\n```\n\n### Anchor Points (linkX/linkY)\n\nRelative coordinates on the block's bounding box:\n- `(0, 0)` = top-left\n- `(0.5, 0)` = top-center\n- `(1, 0)` = top-right\n- `(1, 0.5)` = right-center\n- `(1, 1)` = bottom-right\n- `(0.5, 1)` = bottom-center\n- `(0, 1)` = bottom-left\n- `(0, 0.5)` = left-center\n\nThe absolute coordinates returned by `getEndpoint1/2()` match `blockX + linkX * blockW` and `blockY + linkY * blockH`.\n\n### Free-Floating Lines\n\nLines don't need to be connected to blocks:\n\n```js\n// Fully free-floating\nconst line = page.addLine({\n  endpoint1: { x: 100, y: 100 },\n  endpoint2: { x: 300, y: 100 },\n});\n\n// Mixed: one end connected, one free\nconst line = page.addLine({\n  endpoint1: { connection: block, linkX: 1, linkY: 0.5 },\n  endpoint2: { x: 400, y: 200 },\n});\n```\n\n## Reading Line Data\n\n```js\nconst ep1 = line.getEndpoint1();\n// Returns: { connection: BlockProxy|undefined, linkX, linkY, x, y, inside, padding, style, autoLink }\n// x/y are absolute coordinates (computed from linkX/linkY + block position)\n\nconst ep2 = line.getEndpoint2();\n```\n\nFor connected endpoints: `connection` is a BlockProxy, `linkX`/`linkY` are the relative coords, `x`/`y` are the absolute coords.\nFor free endpoints: `connection` is falsy, `x`/`y` are the absolute coords.\n\n## Iterating Lines\n\n```js\nfor (const [id, line] of page.allLines) { ... }\nconst lines = [...page.allLines.values()];\n```\n\n## Line Shapes\n\n| Shape | Value | Visual |\n|---|---|---|\n| Curve | `\"curve\"` | Smooth bezier curve |\n| Elbow | `\"elbow\"` | Right-angle segments (default) |\n| Diagonal | `\"diagonal\"` | Straight line point-to-point |\n\n```js\nline.setShape('curve');    // or 'elbow' or 'diagonal'\nconst shape = line.getShape();  // returns 'curve', 'elbow', or 'diagonal'\n```\n\n**Default shape is `\"elbow\"`.**\n\n## Endpoint Styles\n\nControl arrowheads/markers on line endpoints. The style is a string passed to `setEndpoint1/2()`.\n\n**Format:** Use the exact display-style string values (for example `Hollow Arrow`, `Open Arrow`, `BPMN Conditional`, `CFN ERD Zero Or More Arrow`). Do not use camelCase variants such as `HollowArrow`.\n\n**Common styles:**\n\n| Style | Description |\n|---|---|\n| `None` | No marker (default for endpoint1) |\n| `Arrow` | Filled triangle (default for endpoint2) |\n| `Hollow Arrow` | Hollow triangle |\n| `Open Arrow` | Open chevron |\n| `Equilateral Arrow` | Filled equilateral triangle |\n| `Equilateral Hollow Arrow` | Hollow equilateral triangle |\n| `Measure` | Perpendicular tick mark |\n\n**UML styles:** `Generalization`, `Asynch1`, `Asynch2`, `Aggregation` (hollow diamond), `Composition` (filled diamond), `BlockEnd`, `BlockEndFill`, `CircleOpen`, `CircleClosed`, `Nesting`\n\n**BPMN styles:** `BPMN Conditional`, `BPMN Default`\n\n**ERD (Crow's foot) styles:** `CFN ERD Zero Or More Arrow`, `CFN ERD One Or More Arrow`, `CFN ERD Many Arrow`, `CFN ERD Exactly One Arrow`, `CFN ERD Zero Or One Arrow`, `CFN ERD One Arrow`\n\n**Additional styles:** `Short Open Arrow`, `Short Arrow`, `Short Hollow Arrow`, `Open Curved Arrow`, `Concave Hollow Arrow`, `Concave Arrow`, `Convex Hollow Arrow`, `Convex Arrow`, `Kite Hollow Arrow`, `Kite Arrow`, `Slash`, `Centered Hollow Circle`, `Centered Filled Circle`, `Centered Hollow Square`, `Centered Filled Square`, `Large Open Arrow`, `Diamond`, `Measure Triple`, `Double Hollow Arrow`, `Double Arrow`, `Double Open Arrow`\n\nThere are 67+ styles total.\n\nSet via `setEndpoint1/2()`:\n\n```js\nline.setEndpoint1({\n  connection: block,\n  linkX: 0.5,\n  linkY: 1,\n  style: 'Hollow Arrow',\n});\n```\n\n**Defaults:** endpoint1 = `\"None\"`, endpoint2 = `\"Arrow\"` (arrow on the destination end).\n\n## autoLink\n\nSetting `autoLink: true` on an endpoint lets it slide around the connected block's edge to find the best route:\n\n```js\npage.addLine({\n  endpoint1: { connection: block1, linkX: 1, linkY: 0.5, autoLink: true },\n  endpoint2: { connection: block2, linkX: 0, linkY: 0.5, autoLink: true },\n});\n```\n\n## Line Properties\n\n| Property | Default | Notes |\n|---|---|---|\n| `LineColor` | `\"#3a414aff\"` | Line color with alpha |\n| `LineWidth` | `1` | Line thickness |\n\n```js\nline.properties.set('LineColor', '#ff0000');\nline.properties.set('LineWidth', 3);\n```\n\n**Note:** `StrokeColor` and `FillColor` returned undefined when read. `LineColor` is the correct property for line color.\n\n## getConnectedLines\n\nFind all lines attached to a block:\n\n```js\nconst lines = block.getConnectedLines();\n// Returns LineProxy[] — all lines where either endpoint is connected to this block\n```\n\n## Other Methods\n\n- `line.getRelativePosition(0.5)` — get absolute `{x, y}` at a point along the line\n- `line.getUpstreamConnection()` — block/line connected to endpoint1\n- `line.getDownstreamConnection()` — block/line connected to endpoint2\n- `line.delete()` — remove the line"};var Uc9gb={type:"System",name:UcWa.mkr,isAvailable:a=>a.Kc.wSa(),Vj:Ucha.wf,description:"Canvas text-area guidance. **REQUIRED** when working with any text on the document like shape and line labels, text on a table, or any other visible text on the canvas.",content:"# Edit Text Areas Skill\n\n---\n\n**How to read, write, measure, style, and position text areas.**\n\n## Text Area Basics\n\nText areas are named strings on blocks and lines. The most common block text area is `Text`; frames use `FrameTitle`. Lines can have multiple generated text area names such as `t0` and `t1`.\n\n```js\nblock.textAreas.get('Text');          // most blocks\nblock.textAreas.set('Text', 'Label');\nframe.textAreas.get('FrameTitle');    // frames\nframe.textAreas.set('FrameTitle', 'Section');\n```\n\n## Measuring and Styling Block Text\n\nMost blocks do NOT auto-resize to fit text. Set the text and style, call `measureText()`, then resize the block with padding.\n\n```js\nblock.textAreas.set('Text', label);\nblock.textStyles.set('Text', { size: 12, bold: true });\nconst measured = block.measureText('Text', 300);\nblock.setBoundingBox({ x, y, w: Math.ceil(measured.w) + 24, h: Math.ceil(measured.h) + 16 });\n```\n\n## Line Text Areas\n\n```js\nconst name = line.addTextArea('Yes', { location: 0.5, side: 0 });\nconst text = line.textAreas.get(name);\nconst position = line.getTextAreaPosition(name);\nline.setTextAreaPosition(name, { location: 0.3, side: -1 });\nline.deleteTextArea(name);\n```\n\nFor lines, iteration works:\n\n```js\nfor (const [name, text] of line.textAreas) { ... }\n```\n\n## New Shape Text\n\n- For newly created shapes, set the text value and let the shape/document defaults provide styling.\n- Only apply explicit text styling when the user requests a visual style or when required to pass validation.\n\nPreferred default:\n\n```js\nconst block = page.addBlock({ className: 'ProcessBlock', boundingBox });\nblock.textAreas.set('Text', 'Evaporation');\n```\n\nAvoid unless styling was requested by the user or necessary to portray meaning or fix layout.\n\n## Formula Text\n\nUse formula templates when linked data or shape data should render visually in text. Reads return the literal template string.\n\n```js\nblock.textAreas.set('Text', '{{=@Name}}');\nblock.textAreas.get('Text'); // '{{=@Name}}'\n```\n\n## Text Styling\n\n```js\nblock.textStyles.set('Text', {\n  bold: true,\n  size: 24,\n  color: '#ffffff',\n});\n\n// Read back\nconst style = block.textStyles.get('Text');\n// Returns: { font: \"Inter\", bold: true, italic: false, underline: false, size: 24, color: \"#ffffff\", align: \"\" }\n```\n\nAvailable text style properties: `font`, `bold`, `italic`, `underline`, `size`, `color`, `align`\n\n### Measuring text size\n\n```js\nconst size = block.measureText('Text', maxWidth);\n// Returns { w, h } — exact pixel dimensions needed to render the text\n```\n\n**Important:** Most blocks do NOT auto-resize to fit text. Text that overflows renders outside the block bounds, overlapping other content. Use `measureText()` to size blocks correctly.\n"};var Uc$gb={type:"System",name:UcWa.mmr,Vj:Ucha.EG,description:'REQUIRED before working with or creating ERDs. VITAL information around what makes "good" ERD (Entity Relationship Diagram) layout. Helpful when evaluating an ERD\'s layout.',content:'# ERD Diagram Layout Skill\n\nThe following information is CRITICAL to follow as you read and work with ERD diagrams.  The guidelines and rules help you create better ERD diagrams and make more professional edits to them.  ALL of these rules should be followed at ALL TIMES on ERD diagrams with the only exceptions being cases where the user explicitly requests something contradicting one of these rules.  These rules are your intelligent defaults when working with ERD diagrams.\n\n## General Layouts and Positioning Rules\n\n- Overall Structure: Clusters.  While other diagram types value single lines, ERD diagrams should all fit on the screen at the same time if possible (keeping in mind that screens tend to be wider than they are tall when working on ERDs).\n- Table proximity directly correlates to schema relationship for users.  Make sure that tables that are MORE related to eachother (e.g. User and Role) are closer together than tables that are LESS related to eachother (e.g. User and Templates)\n- Spacing: Large.  ERD tables are so information-dense themselves that they should be given MORE space around them than other shapes.  Two tables that _almost_ overlap still look messy and cluttered to users.  Make sure to get the bounds of each table (ONCE IT IS FULLY FILLED OUT WITH TEXT) and control the gap between the tables to be around 200px+.\n\n### Common Gotcha: Table Resizing\n\nWhen you add text into all the text areas of the ERD table shape, the table will grow much larger.  If you have calculated the layout positions of the tables BEFORE adding their content texts, the resulting layout will be cluttered and illegible.  You MUST place and entirely fill out all ERD tables before worrying about layout when generating ERD tables/diagrams.  When editing tables, keep in mind that you must check to see if you need to move any table you add/remove content to/from.\n\n## Connections with ERD tables\n\nERD tables have two kinds of lines that connect to them.  The first type is a Row-level Relation.  This is the MOST COMMON type of line connection, and makes up **100% of Table-to-Table connections**.  They represent a connection to a specific field within the table. These lines should ONLY EVER be placed on the left and right sides of the table; NEVER the top or bottom.  By reading the ShapeDetails to get the connection points on an ERD table, you can find the per-row connection points so that you can connect these Row-Level Relationship lines to the correct rows.\n\nThe second type is a Table-level Relation.  This is uncommon, and indicates a connection between an ERD table and something else that is NOT an ERD table.  These connections represent a relationship to the table as a whole; not just a single row.  These lines SHOULD ALWAYS be placed on the top and bottom, so as to avoid looking like a Row-level relationship.\n\nConnections between two ERD tables are also expected to have cardinality indicators on the endpoints (using endpoint styles).  Correctly using endpoint styles to indicate the relationship between ERD entities (one-to-many, one-to-one, etc) is STRONGLY ENCOURAGED FOR ALL ERD DIAGRAMS.\n\nBecause of the informational communication that a line\'s connection point to the ERD table gives, you should be EXTRA CAREFUL that every line is where it should be and corresponds to the table row that it should.  For example, a line between a User table and a Resource table that represents a FK in Resource ("user_id"), you should be SUPER CAREFUL that the line goes from the "user_id" row of Resource to the "id" row of User.\n\n## Table Centrality Rule\n\nSome tables in an ERD diagram have more connections coming in/out than others.  While one table might only be referenced by one other table, another table may have FKs linking it to 8 others.  **Tables with more connections should be placed in the middle of the diagram, and tables with fewer connections should be placed on the edges**.\n\n'};var Ucahb={type:"System",name:UcWa.srr,Vj:Ucha.EG,description:'REQUIRED before working with or creating Fishbone ("Ishikawa" or "cause-and-effect") diagrams.  Vital information around how they should look.',content:'# Fishbone Diagram Layout Skill\n\nROLE: Deterministic Layout Compiler for Ishikawa (cause-and-effect) diagrams.\nA fishbone diagram is NOT a natural fit for the canvas. Work against the defaults to get the right look.\n\nThe diagram resembles a fish skeleton: the focus problem/condition is the **head**, a horizontal **spine** extends from it, and the contributing factors form diagonal **ribs** along the spine.\n\n## STRUCTURE\n\n- **Head**: a block labeled with the problem/condition.\n- **Spine**: a straight line (NO arrowheads, "none" on both sides) extending from the head to the side (usually left).\n- **Factors**: split evenly, half above the spine and half below. Each connects DIRECTLY to the spine — never to the head.\n- **Sub-causes** (optional): plain Auto-grow Text blocks beside a rib. Never shapes/blocks.\n\n## RIBS\n\n- NO arrowheads ("none" both sides). Routed **diagonal** — never elbow or curved.\n- Mostly vertical, tilted 20-40 degrees.\n- **DIRECTION — every rib slants TOWARD the head.** The end touching the spine is always closer to the head than the end touching the factor. This is true for top ribs AND bottom ribs.\n  - MOST COMMON ERROR: slanting ribs AWAY from the head. Do not do this.\n  - If the head is on the RIGHT: every rib\'s spine-connection X must be GREATER (further right) than its factor-connection X.\n  - If the head is on the LEFT: every rib\'s spine-connection X must be LESS (further left) than its factor-connection X.\n- **UNIFORM TILT**: every rib uses the exact same horizontal offset (if rib 1\'s spine end is 40px toward the head from its factor end, ALL ribs use 40px).\n- **FACTOR FACE — ribs connect to the face pointing toward the spine, never the sides.**\n  - For factors in the TOP row (above the spine), the rib connects to the **BOTTOM face** of the factor box.\n  - For factors in the BOTTOM row (below the spine), the rib connects to the **TOP face** of the factor box.\n  - Never connect a rib to the left or right (side) face of a factor box.\n- **CONNECTION MATH**: the factor-connection X = factor.x + (connectionPoint * factor.width). Example: a top-row box at x=500, width 120, connecting at 0.5 on its bottom face → 500 + (0.5 * 120) = 560. With head on the right, that rib\'s spine end sits to the RIGHT of 560.\n\n## SPINE\n\n- The spine goes from the head edge to the last rib\'s connection point, and NO further.\n- **The spine has NO dots, ticks, or markers along it — ever.** It is a single plain line. Tick marks/dots ONLY appear on ribs (one per sub-cause).\n\n## FACTOR ALIGNMENT\n\n- **All factors above the spine share ONE identical Y. All factors below the spine share their own identical Y.** They line up along a single horizontal row on each side.\n- Factors are also evenly spaced horizontally (same X gap between them).\n- All factors sit the same distance from the spine. Match their distance to the factor that has the most sub-causes, so its ribs have room.\n- Even with no sub-causes, leave generous padding between factors and the spine.\n\n## SUB-CAUSES\n\n- Evenly spaced along their rib, each with a tick mark/dot ON THE RIB at the Y center of its text.\n- Place the text "under" the rib angle (further from the head than the rib). If that puts text to the left of the rib, right-align it so it stays pinned to the rib when text changes.\n- Adding/removing sub-causes may require moving the factor closer to or further from the spine to stay cleanly spaced.\n\n## GENERATION ORDER\n\n1. Place the head.\n2. Set the spine Y.\n3. Set factor Y positions (above and below), allowing room for sub-causes.\n4. Set horizontal spacing between factors (driven by the longest sub-cause text; large padding even with none).\n5. Place factors, then draw ribs to the spine Y — all diagonal, uniform tilt, all slanting TOWARD the head.\n6. Place the spine, from the head edge to the last rib\'s connection point.\n7. Remove all arrowheads.\n8. Place sub-causes along the ribs, adjusting text alignment.\n\n## FINAL SELF-CHECK (verify ALL)\n\n- Does EVERY rib slant toward the head (spine end closer to the head than the factor end)?\n- Is the spine completely free of any dots/ticks/markers?\n- Do all top factors share one Y, and all bottom factors share one Y?\n- Are ribs uniformly tilted and all diagonally routed?\n- Do no lines have arrowheads?\n\n## DEFAULTS TO OVERRIDE\n\n- The canvas gives lines one arrowhead by default — remove every one.\n- The canvas routes lines by "elbow" (zig-zag) — force every line to route "diagonal".\n- Do NOT use the RerouteLines tool on this diagram; the canvas cannot route fishbone lines.'};var Ucbhb={type:"System",name:UcWa.Nwr,Vj:Ucha.EG,description:"Required when working with any flowcharts or other node-and-edge diagrams. Layout and Structure information for these diagrams.",isAvailable:a=>!a.Kc.wSa(),content:'# Flowchart Diagram Layout Skill\n\nThis skill\'s purpose is to teach you how to lay out flowcharts cleanly and in a readable way. Hold to these guidelines closely when creating new flowcharts and when adjusting existing ones. These guidelines are specific to flowcharts — they do not apply to other diagram types such as trees or ERDs.\n\nWhen performing tasks on the document that involve flowcharts, you MUST begin with a think_aloud tool call, used as a notepad to plan the layout. In that first think_aloud, state, in order:\n\n1. The spine — its direction (default left-to-right) and the ordered shape and line IDs that form it.\n2. Each branch — where it attaches to the spine, which side of the spine it sits on, and its type/role (e.g. error path, "No" outcome, retry loop).\n3. Any cycles, and how they will be laid out.\n\nFailing to do this will lead to poor flowchart layouts.\n\n1. The Spine\n\n    **The spine is the SINGLE MOST IMPORTANT thing to pay attention to in a flowchart.** It is the set of blocks and connections that form the "main" or "happy" path through the flowchart. From start to finish, the spine should ALWAYS be clear, consistent, and evenly spaced. Most of the time, when a user says a flowchart "looks bad" or is "messy", they are looking at a poorly organized spine.\n\n    To organize a spine, look at the "beginning" of the flowchart (often the left or top) and follow primary connections until you find the end of the primary flow. The blocks and lines you traverse are the Spine. When working on a flowchart, the spine (complete with IDs for the shapes and lines) should briefly be mentioned in your wave plan in a ThinkAloud tool call. Once you have identified your spine, you need to pay CLOSE attention to its layout. The blocks should be evenly spaced, and should be placed along a clear, consistent path (usually top-to-bottom or left-to-right, though sometimes other paths like circles are used). The connections between blocks should be as direct as possible. When working with a top-to-bottom spine, each line in the spine should have endpoints that share an X value. Same principle for connections in a horizontal spine with their endpoints\' Y values. When aligning spine connections, also make sure to center each block on that aligned axis so it is beautiful.\n\n    When choosing the spine direction, if it\'s between left-to-right and top-to-bottom, **choose left-to-right** unless there\'s a semantic reason not to.\n\n2. Overall Diagram Shape\n\n    The goal is to give the diagram a clean, readable 2D shape.\n\n    - **Linear shape**: Flowcharts should follow a consistent directional flow.  This is often a straight direction (top-to-bottom, or left-to-right).  **Default to this spine shape**.\n    - **Tree shape**: If the flowchart has more than one "happy path" through it, or multiple branches coming off of branches, a Tree shape is likely the most semantic shape.\n    - **Oval / loop shape**: If the flowchart contains a cycle that returns close to the start, the return path can arc around the outside of the main flow, making the overall shape feel rounded or oval.\n\n3. Branches\n\n    Branches are groups of blocks and lines that depart from the spine of the flowchart. **Alongside the spine, branch placement is the most important factor in a readable flowchart** — pay close attention to it. The initial block of a branch should ALWAYS be perpendicular to the spine. The branch itself should have a sub-spine that either:\n    - Run as parallel as possible to the parent spine if it will connect back to the spine in a later spot\n    - Go in reverse, parallel to the parent spine if it will connect back to the spine in an earlier spot\n    - Stick perpendicular, away from the parent spine if it is NOT going to re-connect at any point\n    - Go in an arc away from and then towards the parent spine if the branch has more than a few blocks and connects back to the parent spine quickly\n\n    You also need to be thoughtful about which side of the spine to put a branch on. Almost always, the correct choice is whichever side has the most space. You can usually correctly choose a good side not by trying to read and parse all the sparse location data in the Document Lymtex, but rather by internally tracking what direction the spine is going, and where you have placed previous branches.\n\n    When a flowchart has multiple branches of the same kind or role — e.g. error/failure paths, rejection paths, "No" decision outcomes, retry loops, etc — you should, WHENEVER POSSIBLE, keep all branches of that same type on the **SAME side** of the spine. Putting every error branch on (say) the right, and every success/continuation branch on the left, lets the reader instantly recognize the meaning of a branch from its position alone. Only split branches of the same type across both sides when space constraints genuinely force it; consistent side-assignment by branch type is a major contributor to a flowchart\'s readability.\n\n    When a branch merges back into the parent spine or a sibling branch, the connections coming together should come from distinct directions and should NEVER cross. This helps maintain the readable flow during a branch merge.\n\n4. Spacing\n\n    As you lay out the flowchart, you should be mindful of how much space is between the blocks. The spacing should be relatively consistent in a clean flowchart.\n\n    In flowcharts, you MUST utilize a dynamic grid layout rather than a static grid.  A static grid is when the position of a block is calculated by something like \'x = colIndex * columnWidth\'.\n    When writing code, the pattern for dynamic grids is to have a positional cursor variable that traverses a spine of blocks and positions the next block in relation to the last one like:\n\n    \'\'\'javascript\n    const spineBlockIds = [...];\n    let yCursor = baseY;\n    for (let i = 0; i < spineBlockIds.length; i++) {\n        const b = getBlock(spineBlockIds[i]);\n        const bb = b.getBoundingBox();\n        const x = spineXCenter - bb.w / 2;\n        b.setBoundingBox({ x: Math.round(x), y: Math.round(yCursor), w: bb.w, h: bb.h });\n        yCursor += bb.h + minGap;\n    }\n    \'\'\'\n\n    This is because we care about the gaps BETWEEN blocks being consistent; which depends on each block\'s size.\n\n5. Flowchart Cycles\n\n    If the flowchart has a cycle in it, make that cycle clear and obvious. Any cycle should have its own sub-spine that is thoughtfully placed and evenly spaced.  Diagrams with a prominent cycle (the main spine is a loop) MAY WARRANT a circular spine shape - it helps the circular flow stand out on first glance.\n\n6. Connection Lines\n\n    Good line handling often comes down to a few key things. **The most important aspect of line handling is where the lines connect to their endpoint shapes** — be mindful of which side each line connects to. For example, if A -> B and A is above B, then the line between them should connect to the bottom of A and the top of B. Whenever possible, lines should be straight — such that the two endpoints share either an X or Y coordinate value. And short of a good reason not to (such as fitting multiple connections on one block\'s face), lines should almost always attach to the middle of a face (x/y = 0.5). Exceptions include shapes whose ideal attachment points are not in the middle. Use the LineConnectorTool to identify special attachment points for shapes like tables and ERD entities.\n\n    Lastly, when a line has a label on it, that label should be closer to the source than the destination (closer to the side of the line without an arrow than the side with one). For bidirectional or directionless arrows, the label can go anywhere though the middle is a sound default.\n\n7. FINAL PASS\n\n    Before considering any flowchart work done (such as cleaning up a flowchart, making a new one, etc), you MUST do a final pass through the flowchart to make sure it looks good and is ready to go. This includes:\n    - Validating the spine and sub-spines: Are they neatly aligned and clearly distinguished?\n    - Line Endpoint: Are the lines you worked on connecting to the most reasonable and efficient faces of their connected blocks?\n    - Line-face Placement: Are lines placed at the middle of their connected blocks when appropriate?\n    - Container bounds: If the flowchart sits inside a frame/container, does the container fully enclose the moved or newly added nodes with padding?\n    - Then re-check every Hard Rule below before finishing:\n        - Does every line leaving a decision block have a label naming its branch?\n        - Are there any shape overlaps to resolve?\n        - Are dotted line styles used sparingly?\n        - Does any single node hold more than ~6-7 words of text?\n\n## Hard Rules\n\nFinally, the following rules should always be kept when working with flowchart diagrams:\n\n- **All connection lines** whose source block is a decision block **MUST** have a label near the source naming what decision branch it corresponds to\n- **No Shape Overlaps**\n- **Use dotted line styles sparingly**.  Too many dotted lines become hard to visually follow.\n- Shape text should be limited.  No one node shape should have more than ~6-7 words on it.  Too many words indicates you should just place more blocks.'},
Ucchb={type:"System",name:UcWa.Tzs,Vj:Ucha.EG,description:"Required when working with any flowcharts or other node-and-edge diagrams. Layout and Structure information for these diagrams.",isAvailable:a=>a.Kc.wSa(),content:"# Flowchart Diagram Layout Skill\n\nThis skill's purpose is to teach you how to lay out flowcharts cleanly and in a readable way. Hold to these guidelines closely when creating new flowcharts and when adjusting existing ones. These guidelines are specific to flowcharts — they do not apply to other diagram types such as trees or ERDs.\n\nWhen performing tasks on the document that involve flowcharts, you MUST begin with a think_aloud tool call, used as a notepad to plan the layout. In that first think_aloud, state, in order:\n\n1. The spine — its direction (default left-to-right) and the ordered shape and line IDs that form it.\n2. Each branch — where it attaches to the spine, which side of the spine it sits on, and its type/role (e.g. error path, \"No\" outcome, retry loop).\n3. Any cycles, and how they will be laid out.\n\nFailing to do this will lead to poor flowchart layouts.\n\n1. The Spine\n\n    **The spine is the SINGLE MOST IMPORTANT thing to pay attention to in a flowchart.** It is the set of blocks and connections that form the \"main\" or \"happy\" path through the flowchart. From start to finish, the spine should ALWAYS be clear, consistent, and evenly spaced. Most of the time, when a user says a flowchart \"looks bad\" or is \"messy\", they are looking at a poorly organized spine.\n\n    To organize a spine, look at the \"beginning\" of the flowchart (often the left or top) and follow primary connections until you find the end of the primary flow. The blocks and lines you traverse are the Spine. When working on a flowchart, the spine (complete with IDs for the shapes and lines) should briefly be mentioned in your wave plan in a ThinkAloud tool call. Once you have identified your spine, you need to pay CLOSE attention to its layout. The blocks should be evenly spaced, and should be placed along a clear, consistent path (usually top-to-bottom or left-to-right, though sometimes other paths like circles are used). The connections between blocks should be as direct as possible. When working with a top-to-bottom spine, each line in the spine should have endpoints that share an X value. Same principle for connections in a horizontal spine with their endpoints' Y values. When aligning spine connections, also make sure to center each block on that aligned axis so it is beautiful.\n\n    When choosing the spine direction, if it's between left-to-right and top-to-bottom, **choose left-to-right** unless there's a semantic reason not to.\n\n2. Overall Diagram Shape\n\n    The goal is to give the diagram a clean, readable 2D shape.\n\n    - **Linear shape**: Flowcharts should follow a consistent directional flow.  This is often a straight direction (top-to-bottom, or left-to-right).  **Default to this spine shape**.\n    - **Tree shape**: If the flowchart has more than one \"happy path\" through it, or multiple branches coming off of branches, a Tree shape is likely the most semantic shape.\n    - **Oval / loop shape**: If the flowchart contains a cycle that returns close to the start, the return path can arc around the outside of the main flow, making the overall shape feel rounded or oval.\n\n3. Branches\n\n    Branches are groups of blocks and lines that depart from the spine of the flowchart. **Alongside the spine, branch placement is the most important factor in a readable flowchart** — pay close attention to it. The initial block of a branch should ALWAYS be perpendicular to the spine. The branch itself should have a sub-spine that either:\n    - Run as parallel as possible to the parent spine if it will connect back to the spine in a later spot\n    - Go in reverse, parallel to the parent spine if it will connect back to the spine in an earlier spot\n    - Stick perpendicular, away from the parent spine if it is NOT going to re-connect at any point\n    - Go in an arc away from and then towards the parent spine if the branch has more than a few blocks and connects back to the parent spine quickly\n\n    You also need to be thoughtful about which side of the spine to put a branch on. Almost always, the correct choice is whichever side has the most space. You can usually correctly choose a good side not by trying to read and parse all the sparse location data in the Document Lymtex, but rather by internally tracking what direction the spine is going, and where you have placed previous branches.\n\n    When a flowchart has multiple branches of the same kind or role — e.g. error/failure paths, rejection paths, \"No\" decision outcomes, retry loops, etc — you should, WHENEVER POSSIBLE, keep all branches of that same type on the **SAME side** of the spine. Putting every error branch on (say) the right, and every success/continuation branch on the left, lets the reader instantly recognize the meaning of a branch from its position alone. Only split branches of the same type across both sides when space constraints genuinely force it; consistent side-assignment by branch type is a major contributor to a flowchart's readability.\n\n    When a branch merges back into the parent spine or a sibling branch, the connections coming together should come from distinct directions and should NEVER cross. This helps maintain the readable flow during a branch merge.\n\n4. Spacing\n\n    As you lay out the flowchart, you should be mindful of how much space is between the blocks. The spacing should be relatively consistent in a clean flowchart.\n\n    In flowcharts, you MUST utilize a dynamic grid layout rather than a static grid.  A static grid is when the position of a block is calculated by something like 'x = colIndex * columnWidth'.\n    When writing code, the pattern for dynamic grids is to have a positional cursor variable that traverses a spine of blocks and positions the next block in relation to the last one like:\n\n    '''javascript\n    const spineBlockIds = [...];\n    let yCursor = baseY;\n    for (let i = 0; i < spineBlockIds.length; i++) {\n        const b = getBlock(spineBlockIds[i]);\n        const bb = b.getBoundingBox();\n        const x = spineXCenter - bb.w / 2;\n        b.setBoundingBox({ x: Math.round(x), y: Math.round(yCursor), w: bb.w, h: bb.h });\n        yCursor += bb.h + minGap;\n    }\n    '''\n\n    This is because we care about the gaps BETWEEN blocks being consistent; which depends on each block's size.\n\n5. Flowchart Cycles\n\n    If the flowchart has a cycle in it, make that cycle clear and obvious. Any cycle should have its own sub-spine that is thoughtfully placed and evenly spaced.  Diagrams with a prominent cycle (the main spine is a loop) MAY WARRANT a circular spine shape - it helps the circular flow stand out on first glance.\n\n6. Connection Lines\n\n    Good line handling often comes down to a few key things. **The most important aspect of line handling is where the lines connect to their endpoint shapes** — be mindful of which side each line connects to. For example, if A -> B and A is above B, then the line between them should connect to the bottom of A and the top of B. Whenever possible, lines should be straight — such that the two endpoints share either an X or Y coordinate value. And short of a good reason not to (such as fitting multiple connections on one block's face), lines should almost always attach to the middle of a face (x/y = 0.5). Exceptions include shapes whose ideal attachment points are not in the middle. Use the LineConnectorTool to identify special attachment points for shapes like tables and ERD entities.\n\n    Lastly, when a line has a label on it, that label should be closer to the source than the destination (closer to the side of the line without an arrow than the side with one). For bidirectional or directionless arrows, the label can go anywhere though the middle is a sound default.\n\n7. FINAL PASS\n\n    Before considering any flowchart work done (such as cleaning up a flowchart, making a new one, etc), you MUST do a final pass through the flowchart to make sure it looks good and is ready to go. This includes:\n    - Validating the spine and sub-spines: Are they neatly aligned and clearly distinguished?\n    - Line Endpoint: Are the lines you worked on connecting to the most reasonable and efficient faces of their connected blocks?\n    - Line-face Placement: Are lines placed at the middle of their connected blocks when appropriate?\n    - Container bounds: If the flowchart sits inside a frame/container, does the container fully enclose the moved or newly added nodes with padding?\n    - Then re-check every Hard Rule below before finishing:\n        - Does every line leaving a decision block have a label naming its branch?\n        - Are there any shape overlaps to resolve?\n        - Are dotted line styles used sparingly?\n        - Does any single node hold more than ~6-7 words of text?\n\n## Hard Rules\n\nFinally, the following rules should always be kept when working with flowchart diagrams:\n\n- **All connection lines** whose source block is a decision block **MUST** have a label near the source naming what decision branch it corresponds to\n- **No Shape Overlaps**\n- **Use dotted line styles sparingly**.  Too many dotted lines become hard to visually follow.\n- Shape text should be limited.  No one node shape should have more than ~6-7 words on it.  Too many words indicates you should just place more blocks.\n\n** Here is a general pattern for using runscript for programmatic flowchart layouts**\n\n## Flowchart Layout\n\n### Row/column grid approach\n\nDefine nodes with row/column positions, compute absolute coordinates:\n\n```js\nconst BlockW = 160;\nconst BlockH = 70;\nconst VGap = 30;\nconst HGap = 40;\n\nconst nodes = [\n  { id: 'start', type: 'TerminatorBlockV2', text: 'Begin', row: 0, col: 0 },\n  { id: 'step1', type: 'ProcessBlock', text: 'Step 1', row: 1, col: 0 },\n  { id: 'decide', type: 'DecisionBlock', text: 'OK?', row: 2, col: 0 },\n  { id: 'alt', type: 'ProcessBlock', text: 'Alternative', row: 2, col: 1 },\n];\n\nfor (const node of nodes) {\n  const x = baseX + node.col * (BlockW + HGap);\n  const y = baseY + node.row * (BlockH + VGap);\n  const block = page.addBlock({\n    className: node.type,\n    boundingBox: { x, y, w: BlockW, h: BlockH },\n  });\n  block.textAreas.set('Text', node.text);\n}\n```\n\n### Connection helper\n\n```js\nfunction getAnchor(side) {\n  switch (side) {\n    case 'top':    return { linkX: 0.5, linkY: 0 };\n    case 'bottom': return { linkX: 0.5, linkY: 1 };\n    case 'left':   return { linkX: 0, linkY: 0.5 };\n    case 'right':  return { linkX: 1, linkY: 0.5 };\n  }\n}\n```\n\n### Smart anchor selection based on position\n\n```js\nconst dx = toBB.x - fromBB.x;\nconst dy = toBB.y - fromBB.y;\nif (Math.abs(dx) > Math.abs(dy)) {\n  // Horizontal: right-to-left or left-to-right\n  ep1 = { connection: fromBlock, linkX: dx > 0 ? 1 : 0, linkY: 0.5 };\n  ep2 = { connection: toBlock, linkX: dx > 0 ? 0 : 1, linkY: 0.5 };\n} else {\n  // Vertical: bottom-to-top or top-to-bottom\n  ep1 = { connection: fromBlock, linkX: 0.5, linkY: dy > 0 ? 1 : 0 };\n  ep2 = { connection: toBlock, linkX: 0.5, linkY: dy > 0 ? 0 : 1 };\n}\n```\n\n### Labeled branches from decisions\n\n```js\nline.addTextArea('Yes', { location: 0.5, side: 0 });\n\nconst noLine = page.addLine({\n  endpoint1: { connection: decisionBlock, linkX: 1, linkY: 0.5 },\n  endpoint2: { connection: altBlock, linkX: 0, linkY: 0.5 },\n});\nnoLine.addTextArea('No', { location: 0.5, side: 0 });\n```\n"};var Ucdhb={type:"System",name:UcWa.Rer,Vj:Ucha.wf,description:"Explains how to reliably recreate diagrams from images. Load when the user wants you to create a diagram from an image.",content:'# Creating Diagrams From Images Skill\n\nWhen the user gives you an image (of a diagram) and wants you to recreate that on the canvas, follow these guidelines to do so reliably. To begin, make sure you have loaded the CanvasEditing skill. You will need access to the information and tools it provides.\n\n## GUIDING PRINCIPLE: REPRODUCE THE SOURCE EXACTLY\n\nYour goal is a faithful, pixel-faithful reproduction of the source image — not a "close enough" diagram and not your own cleaner version of it. Treat the source image as the single source of truth for EVERY visual detail, including:\n\n- The shape class and proportions of every block\n- The exact text in every label, and how that text wraps and flows across lines\n- The spacing and gaps between blocks, and their alignment (what lines up in a row/column, what is offset)\n- The relative position and size of every element\n- The slope, angle, and routing of every line (a diagonal line at ~30° must look like ~30°, not snapped to horizontal or an elbow)\n- Every color, stroke, fill, and arrowhead\n\nDo NOT "improve", tidy, straighten, evenly-space, or re-align anything that is not already that way in the source. If the source is messy, asymmetric, or oddly spaced, reproduce that messiness faithfully. The ONLY acceptable deviations are ones the user explicitly asks for. When in doubt, look at the source again and match it.\n\n## NEVER DELETE THE SOURCE IMAGE\n\nIf the source image was placed on the document (i.e. it exists as an image block on the canvas, rather than only being attached to the conversation), you MUST NOT delete, move, or modify it at any point. It is the user\'s reference and the ground truth you are auditing against — deleting it is never acceptable, even after you believe the recreation is finished and even if it overlaps or crowds your work. Build your recreation alongside it (in empty space next to it), not on top of it. If you need more room, place your diagram elsewhere on the canvas; do not remove the source image to make space. Leave it exactly where and how the user put it.\n\n## MANDATORY TASK LIST\n\nIf you have access to the task list, you MUST begin your work by creating these tasks:\n1. Record (in a ThinkAloud tool call) what diagram type is in the source image, and list out every single shape, line, entity, table, and note visible.\n    - This step must be INCREDIBLY detailed and thorough. Failure to do so will result in a bad diagram recreation.\n2. Load any skill(s) related to the diagram type in the source image.\n3. Record (in a ThinkAloud tool call) any other patterns, colors, object shape, size differences, or use of spacing in the source image\'s entities and shapes.\n4. Record (in a ThinkAloud tool call) each line\'s color, endpoint style, routing method (curved, elbow, diagonal, etc), and connection points to its connected shapes.\n5. Read the shape library to decide what shape classes to use for each shape in the source image.\n6. Carefully place ALL diagram content (place all shapes, lines, and other entities) according to their relative positions in the source image.\n7. Style all content to MATCH the source image as exactly as you can — colors, sizes, text labels and their wrapping/flow, spacing, alignment, arrowhead shapes, line routing styles, line slopes, etc. "As close as possible" means matching every visible attribute, not just the obvious ones.\n8. Read the document and take a screenshot to compare your work with the source image. Fix any mistakes you have made.\n9. Perform the dedicated LINE AUDIT (see below). Do NOT skip this even if step 8 looked correct — line routing and connection points are the most common things to get wrong, and they are easy to miss in a quick glance.\n\n## SUPPORTING DETAILS\n\nMost of these steps are self-explanatory. Work carefully and double check your work. The following steps supply extra information about how to complete them.\n\n### Step 2: Load Applicable Diagram Layout Skills\n\nThe diagram layout skills will tell you all about what makes a good diagram. This info can largely be ignored; the BEST diagram is the one that matches the source image. However, the diagram skill may inform you of crucial technical details about the diagram that you need to be especially careful to follow exactly (e.g. the line arrowhead styles in an ERD, where these styles communicate vital relationship information).\n\n### Step 8: The Final Audit\n\nPut your screenshot next to the source image and scrutinize them like you are looking for differences in a "spot the difference" puzzle. Assume there ARE differences and hunt for them — do not look for reasons to declare it finished. Go element by element; a quick overall impression is not an audit. Every attribute below that does not match the source is a defect you must fix before you are done:\n\n- The shape of each block (shape class) and its proportions\n- Shape color and text label, including how the label text wraps/flows across lines\n- The size of each block relative to the others\n- Space between blocks, and their alignment (rows, columns, offsets) — match the source\'s spacing exactly, even if it is uneven\n- The relative position of every element\n- Line color and stroke (solid/dashed/dotted)\n- Line arrowhead style (none, arrow, crows foot, etc)\n- Line routing (elbow, curved, diagonal, etc) AND the slope/angle of each line\n- Any other diagram-specific technical details (e.g. where a line connects to an ERD table)\n\nIf anything is off — even spacing that is slightly too even, or a line that is slightly too straight — fix it and re-screenshot. Repeat until the two images are genuinely hard to tell apart.\n\n### Step 9: The Line Audit\n\nA general screenshot comparison (step 8) is NOT enough to catch line problems. The whole-image glance consistently misses two things: the **routing/shape** of a line and the exact **connection points** (which side of a shape each end attaches to). You MUST audit these explicitly and per-line.\n\nDo this as a structured pass, not a vibe check:\n\n1. Read the document\'s lymtex to get the actual current state of every line: its shape, both endpoints (which block each end attaches to, and the LinkX/LinkY on each end), arrowhead styles, color, and stroke.\n2. In a ThinkAloud call, build a line-by-line comparison. For EACH line, state the SOURCE value and your CURRENT value side by side, then mark match/mismatch:\n    - **Routing shape**: straight / elbow (right-angle) / curved / diagonal. This is the `LineShape` property. A curved source line rendered as an elbow (or vice versa) is a mismatch even if the endpoints are right.\n    - **Connection point — each end**: which side or feature the line enters/exits. Standard shapes use `LinkX`/`LinkY`: left = (0, 0.5), right = (1, 0.5), top = (0.5, 0), bottom = (0.5, 1). In the source, does the line leave the source shape\'s right side and enter the target\'s left side? Match the entry/exit sides, not just "the two shapes are connected.".\n    - **ERD / multi-point shapes**: when a line should attach to a specific field/row (not just an edge midpoint), get the exact LinkY for the field\'s connection point, and verify the line attaches to the correct field — connecting to the wrong row is a silent, common error.\n    - **Arrowhead style** on each end (none / arrow / crows foot / etc).\n    - **Color and stroke** (solid / dashed / dotted).\n3. For every mismatch you listed, make the corresponding fix IN THIS PASS. Do not defer them.\n4. If you fixed anything, take a fresh screenshot and repeat the per-line comparison until every line matches the source.\n\nA line is only "done" when its shape, both connection points, both arrowheads, color, and stroke all match the source. Connecting the right two shapes is the minimum bar, not the goal.'};var Ucehb={type:"System",name:UcWa.dBb,isAvailable:({Kc:a})=>a.gQp(),Vj:Ucha.wf,description:"Load this skill when a user wants to plan a project or prepare for a planning meeting — sprint planning, roadmapping, PI/epic planning, project tracking, or figuring out how to use Lucid to plan initiatives.",content:'# Project Planning\n\nBuild a planning board in four steps: **(1) get the goal and details, (2) route to a timeline or a dynamic table, (3) lay it out with `text_to_board`, (4) refine the generator.** Work the steps in order: don\'t build before you know the goal, and don\'t stop at the layout before the work is actually on the generator.\n\n**Use exact `LoadSkill` names** — `text_to_board_skill`, `canvas_editing_skill`, `dynamic_tables`, `lucid_timelines`. Don\'t add or drop a `_skill` suffix; the registry lookup is exact and a mismatched name fails to load.\n\n## Planning-adjacent work owned by other capabilities\n\nA few requests sound like planning but are owned elsewhere. When the user *clearly* wants one of these, route there instead of running the four steps:\n\n* **Connected diagrams** — flowcharts, dependency maps, alignment maps, org charts, ERDs, architecture diagrams → diagram generation.\n* **Business processes / SOPs** specific to the user\'s organization → process.\n* **Activities with no trackable work** — retrospectives, SWOT, icebreakers, brainstorms → load **text_to_board_skill** directly.\n\n\n## Step 1 — Ask for the goal and details\n\n**Start by asking the user\'s goal — directly.** Before building anything, ask what they\'re planning and what they want the board to do for them (e.g. "What are you planning, and what should this board help you do — track a sprint, map out a roadmap, run a planning meeting with your team?"). Ask it outright; don\'t infer the goal silently. Keep it to one direct question, not an interrogation — their answer drives the routing in step 2 and everything you build after.\n\nWhen you describe what you\'ll build — in that first reply or any suggested next action — **describe it as a timeline or a dynamic table** ("a roadmap timeline of the three initiatives," "a sprint board you can track status on"), never as a generic board of frames, columns, and sticky notes. Pitching a plain frames board here is what leads the build astray: it pre-commits you to the failure case before you\'ve even routed.\n\nAlso read **what\'s already on the canvas** and briefly confirm it\'s what they want — don\'t restart work they meant to extend, or extend a canvas they wanted fresh. If there\'s already a partial artifact (a bare timeline, a table with no capacity planning, scattered cards), skip straight to **step 4** and improve it in place rather than rebuilding from scratch.\n\nGather just enough detail to build: the work items (or where they live), rough dates or sprint cadence, and team/assignees. **Infer defaults rather than interrogating** — a two-month project implies a timeline spanning those months, not a question about exact dates. If cards are already on the canvas (Jira/ADO imports or ones the user made), plan to use *those* (see `Working with integrations`).\n\n## Step 2 — Route: timeline or dynamic table?\n\n**You MUST pick one before building — this step is not optional.** Decide which artifact fits, and say which you\'re building and why:\n\n* **Dynamic table** — Agile / status-driven work: sprints, backlog, status columns, story-point estimation, capacity per assignee.\n* **Timeline** — Non-Agile / date-driven work: roadmaps, quarterly plans, milestones, multiple initiatives spanning weeks or months, anything organized by *when* rather than *status*.\n* **Mixed signals** → the cadence the team *runs on* wins. If they run on sprints, route to a dynamic table even when a multi-month span is mentioned.\n* **Still ambiguous** (e.g. "plan our 3 initiatives" with no sprint/status signal) → **default to a timeline** — planning several initiatives is almost always a roadmap. Never resolve ambiguity by falling back to a generic frames board; that is not one of the options.\n\n## Step 3 — Lay it out with `text_to_board`\n\n**`text_to_board` owns the layout for both artifacts — including creating the generator itself.** Now load **text_to_board_skill** (and only that skill) and build the board with **one fully-specified prompt**. This is not optional and not skippable: even when the user says "make the table," the table is born here, inside the `text_to_board` prompt — not from `create_dynamic_table`. The whole game is **naming the generator explicitly** — if your prompt only lists frames (Agenda, Initiatives, Risks, Next Steps…) and never says the words "dynamic table" or "timeline," `text_to_board` will return swimlanes + sticky notes and **no generator at all**. That is the single most common failure; the literal generator phrase is mandatory, not optional flavor.\n\n* **Frames, top to bottom:** an **Agenda** frame (goal, estimation, risks, next steps); a **Plan** frame holding the artifact — the **timeline or dynamic table** generator (this is the frame that must name the generator explicitly; see below); an **Estimation** frame (sprint/Agile only); and **Risks / Decisions / Parking Lot** frames.\n* **The Plan frame holds the generator and *nothing else*.** Prompt `text_to_board` so that the artifact frame contains *only* the timeline/table generator — no sticky notes, no extra cards, no headings or notes inside it.\n* **Name the generator explicitly — use the literal phrase:**\n    * *Dynamic table:* say "**add a dynamic table** (an editable Lucid dynamic-table generator — not a static table, not swimlanes)" and name the row/column labels (e.g. columns To Do / In Progress / Done, rows Sprint 1–4). Ask for it **empty** — `text_to_board` can\'t bind cards into a table\'s pivot, so **dynamic_tables** adds the cards in step 4.\n    * *Timeline:* say "**add a timeline** from <start> to <end> (e.g. 2026-01-01 to 2026-03-31)" with the date range. Build it **empty** too — cards `text_to_board` drops into a timeline frame land loose and unbound to the bar, so **lucid_timelines** schedules them onto it in step 4.\n* **Estimation bank** (sprint/Agile only): ask for a **story-point estimation bank on the Estimation frame** — `text_to_board` renders the 1-2-3-5-8-13 bank natively (`IncludeStoryPointBank`).\n\n## Step 4 — Refine the generator, then coach\n\nThe `text_to_board` call is a **one-shot layout step**, not the end of the turn. The moment it returns, continue straight into refinement in the *same turn* — the layout is just scaffolding until the work is on the generator and capacity planning is on. Make every change with the **dynamic_tables** / **lucid_timelines** skills (load whichever matches the routed artifact).\n\n**Refinement is a separate phase from layout — do not call `text_to_board` again here.** `text_to_board` already built the frames, the empty table, and its rows/columns in step 3. Refining the board means **populating it with cards**, not rebuilding the scaffold.\n\n**Do not use the canvas-editing / `EditBoard` tools to touch the generator.** `EditBoard` only reshuffles the `text_to_board` frame layout — it cannot create cards, bind them onto a generator, or change generator settings, and using it to "add work" leaves cards loose and makes overlaps worse. All generator work goes through **dynamic_tables** / **lucid_timelines**:\n* *Timeline:* use **lucid_timelines** to create dated cards and add them onto the timeline generator (cards need start/end dates *before* they\'re added, or they collapse onto the start edge), row-group by workstream or owner, and **eagerly turn on the sprint-load capacity view.**\n* *Dynamic table:* use **dynamic_tables** to **add cards to the table** — create the cards (title, status, owner, estimate) and place them **onto the generator** bound to the pivot (not loose in the frame). The table\'s rows and column headers were already set in step 3; **don\'t re-create or rearrange them here** — the work of refining a table is filling its cells with cards, not reshaping its structure. Then set the axis ordering and **eagerly turn on capacity planning** — group by **sprint, team, or assignee** so it\'s meaningful.\n\n**Sourcing the work:** pull from wherever the user actually has it — if cards are already on the canvas (Jira/ADO imports or ones the user made), organize and bind **those** rather than inventing new cards (see `Working with integrations`); if the user gave you details, build cards from those; otherwise add a representative starter set so the structure is legible. Never leave the generator empty waiting on input you could reasonably infer. Group related blocks into **named** containers to mark workstreams.\n\n**Coach as you build.** Don\'t assemble the board silently — as you place each piece, briefly say what it\'s for and surface the next thing the user can do with it. One sentence each, not a lecture. Examples:\n* After turning on capacity planning: "I turned on capacity planning for the sprint columns, so you can see at a glance when a sprint\'s estimated work exceeds the team\'s capacity and rebalance before committing."\n* After the story-point bank: "The point shapes beside the table are for the estimation activity — your team can drag them onto unestimated cards together."\n\n**Once the board is built and validated, the build phase is over — shift fully into coaching.** Help the user *use* what\'s on the canvas and teach them what Lucid planning can do — don\'t offer a flat menu of cosmetic tweaks. Ask directly where they want to go next: "Now that the board\'s set up, what do you want to do with it — run your meeting from it, keep it synced with your tracker, or pressure-test the plan?" Let their answer steer what you teach, then offer two or three follow-ups, each pairing a concrete next step with the skill it builds, e.g.:\n* **Facilitate it** — "Want me to walk you through running the estimation activity live, so the team drags point shapes onto unestimated cards together?"\n* **Read the signals** — "I can show you how to read the capacity bars so you can rebalance an over-allocated sprint before you commit."\n* **Keep it current** — "Want to set up the saved query so the board refreshes itself during the meeting?"\n* **Pressure-test the plan** — "We could try a what-if: move a card to a later sprint and watch capacity update."\n\nMatch the suggestions to the user\'s stated goal and what they seem unsure about — surface the capability they\'d most benefit from learning, not just the next edit. Renaming or summarizing is fine *if the user asks*, but lead with what moves their planning forward and grows their command of the tool.\n\n## Working with integrations (Jira / ADO)\n\n* **When integration cards are already on the board, work with them directly.** Imported Jira/ADO items are ordinary Lucid cards — their fields (status, assignee, estimate, sprint, dates) are readable through the normal canvas tools, with **no integration tool or live connection required**. Add *those* cards to the artifact in step 4 rather than inventing generic ones, and map their fields onto it — dates onto the timeline, status/sprint onto the table pivot. Ask only the mapping questions the binding actually needs (e.g. "Which date field should I map onto the timeline — due date or sprint end?").\n* **When the user asks to connect or import (or you don\'t have the tool), point them to the setup help article — don\'t ask them to list their issues.** Don\'t ask the user to paste or list out their projects, milestones, or issues, and don\'t hand them a JQL query to run. Instead surface the matching help-center article: if you have a `HelpCenterFallback` tool, use it (e.g. "Jira integration setup", "Azure DevOps integration setup"); otherwise describe the integrations-panel path in words. Keep building the artifact with manual cards in parallel — using the fields their data will land in (Status, Estimate, Sprint) so it lines up cleanly once they connect — so the link unblocks setup rather than stalling the conversation.\n* **Prepare the schema either way.** Before utilizing a Lucid tool, ensure the data has the fields it needs (e.g. tasks need dates before being mapped on a timeline). If required data is missing, explain why it\'s necessary and infer what it might look like. If a user gives a "brain dump," take the initiative to categorize it into a format a Lucid planning tool can consume.'};var Ucfhb={type:"System",name:UcWa.FPh,Vj:Ucha.wf,description:"AWS (Amazon Web Services) shape-library knowledge for building AWS diagrams. Use when the user asks about AWS services or wants to build or edit an AWS architecture diagram.",isAvailable:a=>a.Kc.Ndf()&&a.AO.OFa(),content:'# AWS Diagramming Skill\n\n## AWS expertise\n\nYou have expertise in AWS resources, and the relationships between them, as well as AWS patterns, best practices, and common use cases. Use that expertise to interpret AWS data, answer questions, and better assist with AWS related needs.\n\n## Shape library\n\nWhen the diagram\'s subject is AWS (Amazon Web Services), use the **AWS 2024** shape library as the source of shapes.\n\n- Call *ShapeLibrary* with `"AWS"` plus the service name (e.g. `"AWS EC2"`, `"AWS Lambda"`, `"AWS S3"`) to find the right `blockClass`.\n- Prefer an AWS 2024 library shape over a generic block whenever the user is depicting a recognizable AWS service. A generic `ProcessBlock` labeled "EC2" is wrong — use the AWS EC2 shape.\n- For elements with no AWS-specific equivalent (generic users, free-form annotations, section titles), fall back to a generic block — don\'t force an AWS shape.'};var Ucghb={type:"System",name:UcWa.pZs,Vj:Ucha.EG,description:"Important instructions for planning and managing your workflow during complex tasks. Also REQUIRED before editing the canvas.",isAvailable:a=>!a.Kc.wSa(),content:'# Wave Planning Skill\n\nA "wave" is one full reply from you. The goal is to AGGRESSIVELY MINIMIZE the number of waves (responses) we need from you by **packing in as many logical steps and tool calls into a single response as possible**, with a MAX of fifteen (15) tool calls per wave.\nTo effectively plan your waves, you MUST begin your wave with a ThinkAloud tool call, using it as a notepad to record your thoughts on what tasks are needed and what tool calls are dependent on others.\n\nOnce you know what steps are needed (which should map closely with what tool calls are needed), you should group them into waves. The rule for grouping remaining steps into waves is as such: **ALL tool calls that are not explicitly blocked by an inter-tool dependency MUST BE INCLUDED IN THIS WAVE, up to the max of fifteen (15) tool calls**.\nEach wave takes an incredibly long time and should be used to the greatest extent possible. AGAIN, YOU ARE TO BE EXTREMELY AGGRESSIVE IN YOUR EFFORTS TO PACK ALL POSSIBLE TOOL CALLS INTO THIS WAVE, up to the max of fifteen (15).\n\nIf you have more than fifteen (15) unblocked tool calls, fill this wave to the maximum number of tool calls and push the remainder to the next wave — this is the ONLY acceptable reason to defer an unblocked tool call.\n\nPlease note that tools are run in the order you produce them. This means that you absolutely CAN AND SHOULD include any post-edit canvas reads IN THE SAME WAVE as the edit tool calls; they will reflect the canvas\'s state AFTER the edits that come before them.\n- E.g. In a diagram that has A->B->C, you can delete B with healConnections set to true, then also call CanvasQuery in the SAME WAVE in order to view the exact result of the heal connections algorithm.\n- Because of this, it is EXPRESSLY PROHIBITED for you to respond to this wave with JUST a CanvasQuery tool call. That does NOT help us get closer to accomplishing the user\'s requests.\n\n## Dependencies\n\nThere are only a few situations in which we consider one tool call to be "dependent" on another.\n\n1. Tool call B needs a block ID from tool call A that is NOT in the existing context or conversation history\n    - E.g. tool call A is a CreateBlock, and tool call B is a CreateLine / EditTextArea / EditBlockStyle that targets that new block\n2. Tool call B operates directly on the result of an automated algorithm triggered by tool call A\n    - E.g. tool call A deletes a block and uses the healConnections flag, and tool call B aims to delete one of those healed connections\n    - Note that if tool call B does not DIRECTLY reference one of the connections affected by the healConnections flag, then no dependency exists\n3. RerouteLines / validation depend on the blocks and lines they inspect already existing — they go in the wave after the layout-changing edits land\n\n## Concrete Example\n\n<background>\n    In this example, the canvas already has A -> B -> C, and B -> D.\n</background>\n\n<scenario>\n    The user requests that you:\n    - Add a new block Z that connects to D with a D -> Z line\n    - Add a new frame to the right of the entire diagram\n    - Change the color of A\n    - Delete B\n    - Make C taller\n    - Delete the line from A->D that will result from the healing of connections after deleting B\n</scenario>\n\n<ideal_plan>\n    Wave 1: think_aloud(this plan), delete_item(blockB.id, healConnections=true), create_block(blockZ), create_block(newFrame), edit_block_style(A color), resize_block(C taller), canvas_query(A|C|D|Z|frame, w/ surrounding shapes)\n    Wave 2: edit_text_area(Z label), edit_text_area(frame label), delete_item(A->D line id), create_line(D->Z), reroute_lines(all affected ids), validation(for items created or modified this turn)\n    Wave 3: message_user\n</ideal_plan>\n\n### Important Notes on this example\n\n- Notice how we add the CanvasQuery call to the first wave rather than making it its own wave. Because READ tools get called after EDIT tools, this will correctly show the results of all the EDIT tool calls.\n- We add canvas validation in wave 2. This is not required, but good practice to add to your second-to-last wave to make sure the immediate effects of your task look right.\n- The last wave is JUST a MessageUser tool call. Do not include TaskList tools, validation tools, or any other tool with it. Complete and clear the task list in the preceding wave.\n- EditTextArea on Z is in wave 2 because it depends on Z\'s ID from the CreateBlock in wave 1. The same applies to any EditBlockStyle / EditLineStyle on freshly-created items.\n- The DeleteItem of the A->D line is in wave 2 because it depends on the ID of that line, which is revealed by the CanvasQuery call in wave 1.\n- NONE of the waves consisted of only ThinkAloud, TaskList, or similar tools.  **EACH WAVE IS VALUABLE - DO NOT WASTE ONE ON NON-ACTIONS**!\n\n## Anti-patterns\n\n- Calling ThinkAloud in its own wave, then acting in the next wave\n- Packing more than fifteen (15) tool calls into a single wave\n- Calling CanvasQuery after a mutation just to confirm it worked — only re-query when a subsequent tool call genuinely needs the updated state\n- Splitting independent sub-tool calls across waves when the current wave is under the fifteen (15) tool call max — e.g. firing one EditBlockStyle per wave instead of all of them in parallel\n- Performing one mutation per wave when multiple mutations are independent and the wave is not at the max number of tool calls\n- Calling any TaskList tools in their own wave\n\n## Final Wave Planning Take-aways\n\n- You MUST CALL ALL UNBLOCKED tool calls in THIS wave (this response) up to an ABSOLUTE MAXIMUM of fifteen (15) tool calls. Any more tool calls beyond this number should wait for the next wave. We do not care how long your response is as long as it includes fewer than or equal to fifteen (15) tool calls.\n- ONLY push tool calls off to a future wave if there is an EXPLICIT DEPENDENCY DOCUMENTED IN A ThinkAloud TOOL CALL or if you have already output fifteen (15) tool calls.\n- Feel free to call ThinkAloud at any point in your generation of this wave. Order does not matter and it\'s a good way to make sure your next step is correct.\n\n# Wave Planning during Error Handling\n\nWhen handling an error, you should first identify what tool calls are needed to continue past the error (e.g. Same call but with a different block ID, make a call to enable assisted layout for a container, etc).  Once you have identified what steps are needed moving forwards, you should integrate them into the existing planned waves.\n\n**WHENEVER POSSIBLE, YOU SHOULD NOT HANDLE THE ERRORS IN AN ISOLATED WAVE**.  Add the tool calls needed to resolve the error you have seen into the waves you were already planning to do, if any.  This will include you **re-analyzing** what dependencies do and do not exist for the remaining waves planned.\n\n## Example of good wave planning during an error\n\n<background>\n    The document has a single, red block labelled "A"\n</background>\n\n<plans_before_error>\n    Wave 1: Make block A blue, and create block B, and load validate_canvas_skill\n    Wave 2: Create a line from A->B, plus run canvas validation\n    Wave 3: Message user\n</plans_before_error>\n\n<situation>\n    The tool call to make A blue has failed - you used the wrong ID!\n</situation>\n\n<plans_after_error>\n    Wave 2: Make block A blue (with correct ID), create line from A->B, run canvas validation\n    Wave 3: Message user\n</plans_after_error>\n\n### Important take-aways from the example\n\n- We did NOT add another wave to the plan in order to handle the error\n- This is because the creation of Block B is done. The creation of the line from A->B is no longer blocked\n- The next response from the agent in this situation would be the ENTIRE Wave 2 - including the color change AND the new line\n- It would be INAPPROPRIATE for the agent to ONLY respond with an updated Color change command for block A\n\n'},
Uchhb={type:"System",name:UcWa.Vzs,Vj:Ucha.EG,description:"Important instructions for planning and managing your workflow during complex tasks. Also REQUIRED before editing the canvas.",isAvailable:a=>a.Kc.wSa(),content:'# Wave Planning Skill\n\nA "wave" is one full reply from you. The goal is to AGGRESSIVELY MINIMIZE the number of waves (responses) we need from you by **packing in as many logical steps and tool calls into a single response as possible**.\nTo effectively plan your waves, You MUST begin a wave with a ThinkAloud tool call, using it as a notepad to record the plan: what you need to read, what the mutation is, and what genuinely blocks what.\nEach wave takes an incredibly long time and should be used to the greatest extent possible. AGAIN, YOU ARE TO BE EXTREMELY AGGRESSIVE IN YOUR EFFORTS TO PACK ALL POSSIBLE TOOL CALLS INTO THIS WAVE. YOU ARE ALSO TO BE AGGRESSIVE IN PACKING ALL POSSIBLE ACTIONS INTO EACH TOOL CALL. MEANING...\n\n## Prefer one script over many tool calls\n\nIf the run script tool is available, it is almost always the right way to make canvas changes. If the given task can be accomplished with the run script tool, use it.\nA single run_script call can create, read, restyle, move, connect, delete and verify many items in one execution, holding the IDs of everything it creates in local variables.\nonly use individual tools when the task can not be accomplished with the run script tool. This should mean:\n\n- **Most "dependencies" disappear.** A block you create in a script can be connected, labelled, and styled later in the SAME script — you do not need a second wave to reference its ID. Reach for separate waves only when you need to read canvas state you do not yet have, or run an automated algorithm whose output you must inspect before continuing.\n- **Bulk work is one tool call.**\n\n## Ordering within a wave\n\nTools run in the order you produce them, and execute as they arrive. A read tool placed AFTER an edit in the same wave reflects the canvas state AFTER that edit.\n\n- You CAN and SHOULD place a post-edit read in the SAME wave as the edit, when a later step needs the resulting state.\n- It is PROHIBITED to spend a wave on JUST a CanvasQuery to confirm a mutation worked. Only re-read when a subsequent step genuinely needs the updated state.\n- Do not spend a wave on ONLY ThinkAloud or TaskList tools. Every wave should move the task forward.\n- If a mutation fails, later task-list updates from that same wave do not prove the mutation succeeded.\n- Do not mark dependent tasks done or report completion until a retry succeeds or another successful tool performs the previously failed edit.\n\n## When separate waves are still required\n\nA later step is blocked, and belongs in a following wave, only when:\n\n1. It needs canvas state you do not yet have and must read first (the read happens in the earlier wave; the action that consumes it in the next).\n2. It operates directly on the output of an automated algorithm (e.g. healConnections, reroute results) that you must observe before acting on it.\n3. RerouteLines / Canvas validation depends on the items they are passed already existing — they go in the wave after the edits that create those items land.\n\nNote that using run_script often collapses case (1) for IDs it creates itself: those never need a second wave.\n\n## Finishing\n\nWhen the task is complete, the final wave is JUST a MessageUser tool call — that is how you respond to the user and signal the system that the work is done.\nIf the previous wave included validation or a verification read, treat that output as part of the task before deciding the task is complete. A successful mutation script plus a later failed validation is not complete.\n\n# Wave Planning during Error Handling\n\nWhen a tool call fails, identify what is needed to recover (e.g. the same call with a corrected ID, enabling assisted layout, fixing a script and re-running it), then fold those steps into your existing plan. Re-analyze which of your remaining steps are still blocked.\n\n**WHENEVER POSSIBLE, DO NOT HANDLE ERRORS IN AN ISOLATED WAVE.** Merge the recovery steps into the wave you were already going to send, and re-evaluate dependencies for the rest of the plan.\n\nFor `run_script` failures, verify whether the script failed before the intended mutation. Fix clear script errors before concluding that scripting is unavailable for the task.\n\n## Example\n\n<background>The document has a single red block labelled "A".</background>\n<plan_before_error>\n    Wave 1: Make A blue; create block B.  Load validate canvas skill.\n    Wave 2: Create a line A->B; validate the canvas.\n    Wave 3: Message user.\n</plan_before_error>\n<situation>The call to make A blue failed — wrong ID.</situation>\n<plan_after_error>\n    Wave 2: Make A blue (correct ID); create line A->B; validate canvas.\n    Wave 3: Message user.\n</plan_after_error>\n\nThe recovery did NOT add a wave: B was already created, so the A->B line is no longer blocked, and the corrected color change rides along in the same wave.\n'};var Ucihb=new UcYa(Uc4ga);var Ucjhb=new Uc7a("DOMDocument");Ucjhb[Ucmca]=void 0;var Uckhb=new UcYa(Uc6ga);var Uclhb=new Uc7a("ImplicitDocAccessToken");var Ucmhb=new UcYa(Uc$ga);var Ucnhb=new UcYa(Ucbha);var Ucohb=new UcYa(Ucdha);var Ucphb=new UcYa(Ucfha);var Ucqhb=new UcYa(Uchha);var Ucrhb=new UcYa(Ucjha);var Ucshb=new UcYa(Uclha);var Ucthb=[UcGb.Kt,UcGb.Description];var Ucuhb=new Uc7a("MessageBarManagerBase");var Ucvhb=new Uc7a("IsPlatform");var Ucwhb=new Uc7a("PostMessageTargetOrigin");var Ucxhb=new Uc7a("TemplateCategoriesListFactory");var Ucyhb=new Uc7a("lucid.RawFolderEntriesID"),Uczhb=new Uc7a("lucid.RawDocumentsID");var UcAhb=new UcYa(UcBha);var UcBhb=new Uc7a("ShapeLibraryIndex");UcBhb[Ucmca]=void 0;var UcChb=new Uc7a("DocumentWindow");var UcDhb=new Uc7a("HeaderCommentTool");var UcEhb=new Uc7a("LibraryAllowListManager");var UcFhb=Uc8a.Vra("CollectionClipboardSerializationMultiId"),U