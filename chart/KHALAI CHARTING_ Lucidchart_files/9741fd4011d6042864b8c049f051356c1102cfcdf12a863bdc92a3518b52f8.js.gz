-acceptee-fallback-name\":\"the person\",\"presentation-hand-off-announcement-growl-fallback-message\":\"A new presenter is now presenting\",\"presentation-hand-off-announcement-growl-message\":\"{name} is now presenting.\",\"presentation-hand-off-opt-out-growl-accept-button-label\":\"Accept\",\"presentation-hand-off-opt-out-growl-message\":\"{name} wants to pass the presentation to you.\",\"presentation-hand-off-presenter-fallback-name\":\"The presenter\",\"presentation-hand-off-reject-growl-declined-message\":\"{name} has declined the handoff. Choose another presenter?\",\"presentation-hand-off-reject-growl-general-message\":\"Sorry, we weren't able to pass the presentation to {name}. Please try again.\",\"presentation-hand-off-success-growl-fallback-message\":\"You passed the presentation.\",\"presentation-hand-off-success-growl-message\":\"You passed the presentation to {name}\",\"presentation-legacy-label\":\"Presentation\",\"preset-setup-modal-back\":\"Basic setup\",\"primary-panel-back-to-document-tools\":\"Go back to document tools\",\"private-mode-ending-growl-authors-remain-hidden\":\"<w0>{name}</w0> is ending the mode. Authors will remain hidden.\",\"private-mode-ending-growl-authors-remain-hidden-no-name\":\"A collaborator is ending the mode. Authors will remain hidden.\",\"private-mode-ending-growl-authors-revealed\":\"<w0>{name}</w0> is ending the mode. Authors will be revealed.\",\"private-mode-ending-growl-authors-revealed-no-name\":\"A collaborator is ending the mode. Authors will be revealed.\",\"process-capture-discard-feedback-high\":\"Very confident\",\"process-capture-discard-feedback-low\":\"Not confident at all\",\"process-capture-discard-feedback-main-question\":\"How confident did you feel continuing the capture?\",\"process-capture-discard-feedback-short-response\":\"What made you stop?\",\"process-capture-education-prompt-description\":\"Record your workflow and let Lucid AI turn it into a process diagram. No manual mapping required.\",\"process-capture-education-prompt-primary-button-v2\":\"Get started\",\"process-capture-education-prompt-secondary-button\":\"Maybe later\",\"process-capture-education-prompt-title\":\"Go from workflow to diagram—in minutes\",\"process-capture-feedback-high-v2\":\"Very useful\",\"process-capture-feedback-low-v2\":\"Not useful at all\",\"process-capture-feedback-main-question\":\"How useful is this diagram as a starting point?\",\"process-capture-feedback-short-response\":\"What would make it more useful?\",\"process-capture-move-to-repository-prompt-description\":\"Add this diagram to a repository so your team can review, approve, and maintain it with features like document ownership, approval workflows, and version history.\",\"process-capture-move-to-repository-prompt-primary-button\":\"Add to repository\",\"process-capture-move-to-repository-prompt-secondary-button\":\"Don’t ask again\",\"process-capture-move-to-repository-prompt-title\":\"Ready to make this process official?\",\"progress-tracking-shapes-load-tracking-nudge-explanation\":\"Visualize the sum total of estimate points.\",\"progress-tracking-shapes-load-tracking-nudge-image-alt\":\"Toggling on Workload Tracking displays a number at the top of each column representing the sum of its cards' estimate points.\",\"progress-tracking-shapes-load-tracking-nudge-title\":\"Track workload?\",\"progress-tracking-shapes-ownership-chart-nudge-explanation\":\"Add an ownership chart to visualize individual workload at a glance.\",\"progress-tracking-shapes-ownership-chart-nudge-image-alt\":\"This feature adds a new shape with a customizable chart representing the breakdown of tasks in this container by assignee.\",\"progress-tracking-shapes-ownership-chart-nudge-title\":\"Track ownership?\",\"progress-tracking-shapes-progress-block-nudge-explanation\":\"Add a progress bar to visualize your work at a glance.\",\"progress-tracking-shapes-progress-block-nudge-image-alt\":\"This feature adds a new shape with a customizable progress bar representing the cards in this container.\",\"progress-tracking-shapes-progress-block-nudge-title\":\"Track progress?\",\"pt-BR--intelligent-feedback-panel-accidental-click\":\"Clique acidental\",\"pt-BR--intelligent-feedback-panel-missing-functionality\":\"Funcionalidade ausente\",\"pt-BR--intelligent-feedback-panel-preference\":\"Preferência pelo Lucidchart clássico\",\"pt-BR--intelligent-feedback-panel-something-else\":\"Outra coisa\",\"pt-BR--intelligent-feedback-panel-spark-switch-preference\":\"Preferência pelo Lucidspark\",\"pt-BR--presentation-legacy-label\":\"Apresentação\",\"publish-item-display-prop-publish-double-arrow-block\":\"Arrow\",\"publish-item-display-prop-publish-single-arrow-block\":\"Arrow\",\"quick-diagramming-ghost-press\":\"Press\",\"quick-tools-panel-quick-actions-onboarding\":\"Add and activate your tools on the canvas\",\"quick-tools-panel-quick-shape-banks-onboarding\":\"Speed up collaboration with infinite stacks on your canvas\",\"quick-tools-panel-search\":\"Search\",\"quick-tools-panel-search-results-not-found\":\"Sorry, we didn't find any matching quick tools.\",\"quick-tools-title\":\"Quick tools\",\"rapid-optimization-growl-learn-more\":\"Learn more\",\"rapid-optimization-onload-prompt-LC-Pullthrough-Onboarding-page-0-subtitle\":\"Lucidspark is purpose-built for brainstorming, feedback, and collaboration. Here's how Lucidspark can connect your team and bring your best ideas to life.\",\"rapid-optimization-onload-prompt-LC-Pullthrough-Onboarding-page-0-title\":\"Collaborate in Lucidspark\",\"rapid-optimization-onload-prompt-LC-Pullthrough-Onboarding-page-1-subtitle\":\"Give real time reactions with emojis, add tags, and sort objects to synthesize your ideas.\",\"rapid-optimization-onload-prompt-LC-Pullthrough-Onboarding-page-1-title\":\"Highlight and organize your work\",\"rapid-optimization-onload-prompt-LC-Pullthrough-Onboarding-page-2-subtitle\":\"Supercharge your brainstorming sessions with timers, voting, and facilitator controls.\",\"rapid-optimization-onload-prompt-LC-Pullthrough-Onboarding-page-2-title\":\"Tools for your team\",\"rapid-optimization-onload-prompt-LC-Pullthrough-Onboarding-page-3-subtitle\":\"Invite your team to this board to start collaborating.\",\"rapid-optimization-onload-prompt-LC-Pullthrough-Onboarding-page-3-title\":\"Two heads are better than one!\",\"rapid-optimization-onload-prompt-aioptinmessaging-primary-button\":\"Open Lucid AI\",\"rapid-optimization-onload-prompt-aioptinmessaging-subtitle\":\"Lucid AI connects intelligence across the Lucid Suite. Use it to generate diagrams, apply conditional formatting rules, summarize documents, and more.\",\"rapid-optimization-onload-prompt-aioptinmessaging-title\":\"Welcome to Lucid AI\",\"rapid-optimization-onload-prompt-brainstorm-use-case-page-1-subtitle\":\"Use the timer to keep your collaboration sessions engaging and focused.\",\"rapid-optimization-onload-prompt-brainstorm-use-case-page-1-title\":\"Get focused\",\"rapid-optimization-onload-prompt-brainstorm-use-case-page-2-subtitle\":\"Brainstorm collaboratively with sticky notes and shapes.\",\"rapid-optimization-onload-prompt-brainstorm-use-case-page-2-title\":\"Spark Innovation\",\"rapid-optimization-onload-prompt-brainstorm-use-case-page-3-subtitle\":\"Customize elements of shapes and give real time reactions with emojis.\",\"rapid-optimization-onload-prompt-brainstorm-use-case-page-3-title\":\"Highlight your best work\",\"rapid-optimization-onload-prompt-brainstorm-use-case-page-4-subtitle\":\"Invite your team to this board to start collaborating.\",\"rapid-optimization-onload-prompt-brainstorm-use-case-page-4-title\":\"Two heads are better than one!\",\"rapid-optimization-onload-prompt-lsonboardingtutorialcontentrefresh-page-0-subtitle\":\"Lucidspark is purpose-built for brainstorming, feedback, and collaboration. Here's how Lucidspark can connect your team and bring your best ideas to life.\",\"rapid-optimization-onload-prompt-lsonboardingtutorialcontentrefresh-page-0-title\":\"Collaborate in Lucidspark\",\"rapid-optimization-onload-prompt-lsonboardingtutorialcontentrefresh-page-1-subtitle\":\"Double-click anywhere on the canvas to quickly add a sticky note. Insert images, text, and links for additional context.\",\"rapid-optimization-onload-prompt-lsonboardingtutorialcontentrefresh-page-1-title\":\"Add your ideas\",\"rapid-optimization-onload-prompt-lsonboardingtutorialcontentrefresh-page-2-subtitle\":\"Select any object on the canvas to bring up the contextual menu. Change the color or format the shape.\",\"rapid-optimization-onload-prompt-lsonboardingtutorialcontentrefresh-page-2-title\":\"Customize your content\",\"rapid-optimization-onload-prompt-lsonboardingtutorialcontentrefresh-page-3-subtitle\":\"Connect ideas by dragging out a line from a purple dot on the edge of an object. For freehand annotation, press <w0></w0> for the pen tool or <w1></w1> for laser pointer. \",\"rapid-optimization-onload-prompt-lsonboardingtutorialcontentrefresh-page-3-title\":\"Draw out connections\",\"rapid-optimization-onload-prompt-lsonboardingtutorialcontentrefresh-page-4-subtitle\":\"Easily add structure to your canvas by wrapping content in Frames. Use the Table of Contents to quickly navigate to different sections of the board. \",\"rapid-optimization-onload-prompt-lsonboardingtutorialcontentrefresh-page-4-title\":\"Organize and navigate your canvas\",\"rapid-optimization-onload-prompt-lsonboardingtutorialcontentrefresh-page-5-subtitle\":\"Invite others to join you on the board by clicking the 'Share' button. Watch the sparks fly as you all add content, make edits, and work together in real time!\",\"rapid-optimization-onload-prompt-lsonboardingtutorialcontentrefresh-page-5-title\":\"Collaborate with others\",\"rapid-optimization-onload-prompt-lucidspark-business-persona-onboarding-page-0-subtitle\":\"Lucidspark is a virtual whiteboard designed for team collaboration. Brainstorm with stakeholders, plan next steps, and incorporate feedback to bring your best ideas forward.\",\"rapid-optimization-onload-prompt-lucidspark-business-persona-onboarding-page-0-title\":\"Better business with Lucidspark\",\"rapid-optimization-onload-prompt-lucidspark-business-persona-onboarding-page-1-subtitle\":\"Double click anywhere to add a sticky note or bring in content using the left toolbar.\",\"rapid-optimization-onload-prompt-lucidspark-business-persona-onboarding-page-1-title\":\"Spark innovation\",\"rapid-optimization-onload-prompt-lucidspark-business-persona-onboarding-page-2-subtitle\":\"Customize your shapes and add real-time emoji reactions using options in the floating contextual menu.\",\"rapid-optimization-onload-prompt-lucidspark-business-persona-onboarding-page-2-title\":\"Highlight your best work\",\"rapid-optimization-onload-prompt-lucidspark-business-persona-onboarding-page-3-subtitle\":\"Need inspiration? Browse more than 250 templates to help you get started faster.\",\"rapid-optimization-onload-prompt-lucidspark-business-persona-onboarding-page-3-title\":\"Templates for all your needs\",\"rapid-optimization-onload-prompt-lucidspark-business-persona-onboarding-page-4-subtitle\":\"Invite your whole team to the board and maximize your creativity.\",\"rapid-optimization-onload-prompt-lucidspark-business-persona-onboarding-page-4-title\":\"More collaborators = more ideas\",\"replication-disabled-by-classification-error-message\":\"Replication is disabled due to this document's classification.\",\"repository-import-blueprint-error\":\"Blueprints aren't able to be moved to a repository.\",\"repository-import-breakout-board-error\":\"This document contains breakout boards which aren't supported in repositories.\",\"repository-import-shared-doc-error\":\"You can only move documents you own.\",\"repository-object-assets\":\"Object assets\",\"restricted-repository-sticker\":\"Restricted\",\"review-progress-trigger-button\":\"Review progress\",\"revision-history-new-from-action-title\":\"New from {title}\",\"right-panel-header-presentations\":\"Presentations\",\"rollover-document-merge-modal-growl-message\":\"A new version of the template has been released. <w0>Update document</w0>\",\"ru--intelligent-feedback-panel-accidental-click\":\"Случайный клик\",\"ru--intelligent-feedback-panel-missing-functionality\":\"Отсутствующая функциональность\",\"ru--intelligent-feedback-panel-preference\":\"Предпочитаю классический вид Lucidchart\",\"ru--intelligent-feedback-panel-something-else\":\"Что-то другое\",\"ru--intelligent-feedback-panel-spark-switch-preference\":\"Предпочитаю Lucidspark\",\"ru--presentation-legacy-label\":\"Презентация\",\"salesforce-template-import-data-title\":\"Import Salesforce Template Data\",\"scenario-modal-generic-integration-name\":\"Integration\",\"scenario-modal-pull-description-checked\":\"<w0>Checked items</w0> will overwrite the current data in your table.\",\"scenario-modal-pull-description-checked-timeline\":\"<w0>Checked items</w0> will overwrite the current data in your timeline.\",\"scenario-modal-pull-description-unchecked\":\"<w0>Unchecked items</w0> will be ignored, and your current data will remain unchanged.\",\"scenario-modal-pull-title\":\"Changes being pulled into your table\",\"scenario-modal-pull-title-timeline\":\"Changes being pulled into your timeline\",\"scenario-modal-push-description-checked\":\"<w0>Checked items</w0> will push changes to overwrite data in {integrationName}.\",\"scenario-modal-push-description-checked-multiple\":\"<w0>Checked items</w0> will push changes to overwrite data in your data sources.\",\"scenario-modal-push-description-unchecked\":\"<w0>Unchecked items</w0> will pull data from {integrationName}, replacing any changes made in Lucid.\",\"scenario-modal-push-description-unchecked-multiple\":\"<w0>Unchecked items</w0> will pull data from your data sources, replacing any changes made in Lucid.\",\"scenario-modal-push-title\":\"Changes being sent to {integrationName}\",\"scena