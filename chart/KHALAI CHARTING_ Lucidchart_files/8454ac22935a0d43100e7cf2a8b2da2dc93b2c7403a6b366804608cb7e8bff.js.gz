UcdMk=UccMk=__decorate([Ucn({method:["method",UcXHk],userId:["userId",Ucbd],documentId:["documentId",Uco],Nm:["invitationId",Ucm(Uco)],yn:["shapeLibraryId",Uco],Wn:["shapeLibraryName",Uco],Jlb:["numShapes",Ucad],Kxm:["sharedWithTeammates",Uc7c],K1l:["numRecipients",Ucad],name:["name",UcPe("sharedCustomShapeLibrary")]})],UcdMk);var UceMk,UcfMk=UceMk=class{constructor(a){this.name="shownCaptcha";this.location=a.location;this.userId=a.userId}toJSON(){return UceMk.Na(this)}};UcfMk.Jc="shownCaptcha";UcfMk=UceMk=__decorate([Ucn({location:["location",UcNvb],userId:["userId",Ucbd],name:["name",UcPe("shownCaptcha")]})],UcfMk);var UcgMk,UchMk=UcgMk=class{constructor(a){this.name="shownEmptyState";this.location=a.location;this.userId=a.userId;this.documentId=a.documentId;this.fal=a.fal}toJSON(){return UcgMk.Na(this)}};UchMk.Jc="shownEmptyState";UchMk=UcgMk=__decorate([Ucn({location:["location",Uc0Hk],userId:["userId",Ucbd],documentId:["documentId",Ucm(Uco)],fal:["emptyStateVariant",Ucm(Uco)],name:["name",UcPe("shownEmptyState")]})],UchMk);var UciMk,UcjMk=UciMk=class{constructor(a){this.name="startedGoogleMeetActivity";this.userId=a.userId;this.wHq=a.wHq;this.documentId=a.documentId;this.Gqp=a.Gqp;this.platform=a.platform}toJSON(){return UciMk.Na(this)}};UcjMk.Jc="startedGoogleMeetActivity";UcjMk=UciMk=__decorate([Ucn({platform:["platform",Ucm(UcLIk)],Gqp:["meetingPlatform",UcOe(UcLIk,()=>"web")],userId:["userId",Ucbd],wHq:["wasOpened",Uc7c],documentId:["documentId",Ucm(Uco)],name:["name",UcPe("startedGoogleMeetActivity")]})],UcjMk);var UckMk,UclMk=UckMk=class{constructor(a){this.name="interactedWithTemplatePicker";this.If=a.If;this.userId=a.userId}toJSON(){return UckMk.Na(this)}};UclMk.Jc="interactedWithTemplatePicker";UclMk=UckMk=__decorate([Ucn({If:["interaction",UcuJk],userId:["userId",Ucbd],name:["name",UcPe("interactedWithTemplatePicker")]})],UclMk);var UcmMk,UcnMk=UcmMk=class{constructor(a){this.name="triggeredInvisibleCaptcha";this.location=a.location;this.userId=a.user