        const vec4 cornersBeforeEdge[4] = vec4[4](vec4(0.0, 0.0, 0.0, 0.0), vec4(0.0, 1.0, 0.0, 0.0), vec4(0.0, 1.0, 1.0, 0.0), vec4(0.0, 1.0, 1.0, 1.0));

