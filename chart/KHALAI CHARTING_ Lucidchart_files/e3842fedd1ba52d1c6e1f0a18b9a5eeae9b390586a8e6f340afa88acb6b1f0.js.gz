h of the minimal stroke, otherwise, it will cause issue like the\n            // line end being thicker than the line body)\n            float totalScale = uZoom * instanceScale;\n            if (baseWidth > 0.05 && baseWidth * totalScale < 1.0) {\n                baseWidth = 1.0 / totalScale;\n                // Use between 100% to 33% of the original color as the scale reduces from 100% to 0%\n                float colorReduction = 3.0 - (smoothstep(0.0, 1.0, totalScale) * 2.0);\n                vColor = vColor / colorReduction;\n            }\n\n            vLineWidth = baseWidth;\n\n            // Add some extra space to the width for aliasing.  We want the aliased area to cover at least\n            // 1.5 pixel to each side of the line, so add 3.0 screen pixels to the width.\n            float aliasWidth = baseWidth + (3.0 / uZoom);\n\n            vFillType = 1.0;\n\n            // We could use 'normalize', but we need the length for later anyways.\n            vec2 segment = end - start;\n            float segmentLength = length(segment);\n\n            // 'normal' tells us which normal to use when we offset the vertex\n            // parallel/perpendicular later on.  For regular segments this is just the\n            // normal of the segment.  For joints, it depends on which side of the\n            // joint we're on.\n            vec2 normal = segment / segmentLength;\n\n            vPatternLengthAndOffset.x = segmentLength;\n\n            // Normals to use\n            // For joints, its the normal on each side of the joint:\n            //   start -> end, end -> next\n            // For regular segment, they're both the segment's normal\n            //   start -> end\n            vNormals = vec2[2](normal, normal);\n\n            // Counter-clockwise perpendicular to the normal\n            //    perp\n            //     ^\n            //     |\n            //     ----\x3e normal\n            vec2 perp = vec2(normal.y, -normal.x);\n\n            // For rectangles and circles:\n            //   prev = width/2, height/2 (radius, radius for circles)\n            //   start = center of shape\n            //   end = corner radii top left, top right\n            //   next = corner radii bottom right, bottom left\n            if (aFlagsShapeZOffset.y == 3.0 || aFlagsShapeZOffset.y == 2.0) {\n                vFillType = 4.0;\n                vCenter = start; // Center of rectangle/circle\n                vEndOrHalfWidthHeight = prev; // width/2, height/2 (both are radius for circles)\n\n                // We can only round at most half the width/height\n                vCornerRadii = min(aCornerRadii, min(prev.x, prev.y));\n                vVertexPosition = start + offset * (prev + aliasWidth);\n            } else {\n                // Assume a radius for rounded linecaps or rounded linejoins\n                vCornerRadii[0] = halfWidth;\n\n                // Everything but simple shapes (circles and rectangles) ends up here.\n                int lineCap = int(aCapJoinStroke.x);\n\n                // A CapOnly quad sits at the end of an arc.\n                if (aFlagsShapeZOffset.y == 4.0) {\n                    vec2 lineCapInfo = capInfo[lineCap];\n                    float capLength = halfWidth * lineCapInfo.x;\n                    vVertexPosition = start;\n                    vCenter = vVertexPosition;\n                    vVertexPosition += (aliasWidth * sideOffset * perp);\n                    vVertexPosition -= (capLength * isStart * normal);\n                    vFillType = lineCapInfo.y;\n                } else {\n                    // Extract the bits for rounding\n                    bool isJoint = ((flags & 32) != 0);\n                    float roundStart = ((flags & 8) != 0) ? 1.0 : 0.0;\n                    float roundEnd = ((flags & 16) != 0) ? 1.0 : 0.0;\n\n                    // Rounding in pixels\n                    float rounding = aWidthRounding.y;\n                    if (roundStart + roundEnd == 0.0) {\n                        rounding = 0.0;\n                    }\n\n                    vFillType = 1.0;\n\n                    // Assume no rounding.  Non-joint vertices use this, too\n                    float roundLength = 0.0;\n\n                    if (isJoint) {\n                        vec2 nextSegment = next - end;\n                        float nextLength = length(nextSegment);\n\n                        roundLength = min(rounding, min(segmentLength, nextLength) / 2.0);\n                        // Set the 2nd normal in 'vNormal' to nextSegment's normal.\n                        vNormals[1] = nextSegment / nextLength;\n\n                        // Calculate the angle between 'segment', and 'nextSegment'.\n                        // dot(a,b) = |a||b|cos(x) or cos(x) = dot(a,b)/|a||b|\n                        float cos2x = dot(-segment, nextSegment) / (segmentLength * nextLength);\n                        float angle = acos(cos2x);\n\n                        // Two dimensional cross product to determine which way the joint bends\n                        // If this is '-1', then we bend to the left as we go from start -> end -> next.\n                        // 1 means we bend to the right.\n                        float direction = sign((segment.x * nextSegment.y) - (segment.y * nextSegment.x));\n\n                        // If the cross product was 0 the segments are parallel.  Pick an arbitrary\n                        // direction in this case so we get non zero edge offsets.\n                        if (direction == 0.0) {\n                            direction = 1.0;\n                        }\n\n                        // Law of cosines:  cos(2x) = 2cos^2(x) - 1 = 1 - 2sin^2(x)\n                        // Use law of cosines to get half the angle of the total joint\n                        // since we measure things like radius from the middle of the\n                        // joint.\n                        float cosSquared = (cos2x + 1.0) / 2.0;\n                        float sinSquared = (cos2x - 1.0) / -2.0;\n\n                        // tan^2 = sin^2/cos^2.  This is the tan() of half the total angle\n                        // at the joint.\n                        float tan = sqrt(abs(sinSquared / cosSquared));\n\n                        vCornerRadii[0] = roundLength * tan;\n\n                        if (aFlagsShapeZOffset.y == 1.0) {\n                            vCornerRadii[0] = prev.x;\n                            roundLength = prev.x / tan;\n                        }\n\n                        vPatternLengthAndOffset.x = vCornerRadii[0] * angle;\n\n                        int lineJoin = int(aCapJoinStroke.y);\n\n                        if (roundLength > 0.0) {\n                            vFillType = 2.0;\n                        } else {\n                            // If we aren't rounding, determine the type of line joint\n                            // we want to use between segments.  (i.e., canvas 'lineJoin')\n                            if (lineJoin == 1) {\n                                // If the lineJoin is 'round', set the fill type to wedge\n                                vFillType = 3.0;\n                            } else if (lineJoin == 0) {\n                                float miterLimit = 10.0;  // Miter limit\n                                // If we exceed the miter limit, switch to 'bevel' line joints\n                                if (sinSquared < 1.0 / (miterLimit * miterLimit)) {\n                                    lineJoin = 2;\n                                }\n                            }\n                        }\n\n                        // The 'quad' we make for a joint looks like the region filled\n                        // with '*' below.  'Inner' and 'Outer' are the common\n                        // points to each triangle.\n                        //\n                        //                     (1)\n                        //   ---------------------------/  Outer (2)\n                        //                      |******/\n                        //            Inner (0) |*****/\n                        //                       ***/\n                        //   -------------/       */\n                        //               /         / (3)\n                        //              /         /\n                        //\n\n                        vec2 joint = joints[cornerIndex];\n                        normal = vNormals[int(joint.x)];\n                        perp = vec2(normal.y, -normal.x);\n\n                        float outer = (aFlagsShapeZOffset.y == 1.0) ? roundLength : aliasWidth / tan;\n\n                        // Offset to get to the edge including space for aliasing\n                        vec2 toEdge = aliasWidth * direction * perp;\n\n                        float isRounded = roundLength > 0.0 ? 1.0 : 0.0;\n\n                        vStart = end - roundLength * vNormals[0];\n                        vCenter = end - isRounded * roundLength * vNormals[0];\n                        vCenter += isRounded * vCornerRadii[0] * -direction * vec2(vNormals[0].y, -vNormals[0].x);\n\n                        if (cornerIndex == 0) { // Inner\n                            // Inner vertex.  Just move this if we're rounded\n                            vVertexPosition = end - isRounded * roundLength * normal;\n                            vVertexPosition += isRounded * vCornerRadii[0] * -direction * perp;\n                        } else if (cornerIndex == 2) { // Outer\n                            // All joint corners are treated the same other than beveled joints.\n                            if (roundLength == 0.0 && lineJoin == 2) {\n                                vec2 perpA = vec2(vNormals[0].y, -vNormals[0].x);\n                                vec2 perpB = vec2(vNormals[1].y, -vNormals[1].x);\n                                vec2 midpoint = direction * perpA + direction * perpB;\n                                vVertexPosition = end + (midpoint * aliasWidth / 2.0);\n                            } else {\n                                // If we're at a very small angle, 'tan' will be very small and\n                                // cause 'outer' to be very large.  Limit outer in that case.\n                                if (tan < 0.001) {\n                                    outer = lineWidth * 10.0;\n                                }\n                                vVertexPosition = end + outer * normal + toEdge;\n                            }\n                        } else {\n                            vVertexPosition = end - roundLength * sideOffset * normal + toEdge;\n                            vUseNext = joint.x;\n                        }\n                    } else {\n                        float capStart = ((flags & 2) != 0) ? 1.0 : 0.0;\n                        float capEnd = ((flags & 4) != 0) ? 1.0 : 0.0;\n\n                        // Regular (non-joint) line segments end up here.\n                        // Select 'start' or 'end' based on flags.\n                        vVertexPosition = isStart * start + isEnd * end;\n                        vVertexPosition += (aliasWidth * perp * sideOffset);\n                        vCenter = vVertexPosition;\n\n                        // Do we need to add any length at the start/end for a linecap?\n                        vec2 lineCapInfo = capInfo[lineCap];\n                        float capDirection = -capStart * isStart + capEnd * isEnd;\n                        float capLength = halfWidth * capDirection * lineCapInfo.x;\n                        vVertexPosition += (capLength * normal);\n\n                        float isRound = (lineCap == 1) ? 1.0 : 0.0;\n                        vFragmentFlags += isRound * capStart * 2.0;\n                        vFragmentFlags += isRound * capEnd * 4.0;\n\n                        // Move the 'start' further along the segment's normal to account\n                        // for any rounding from the previous joint.  Also shorten length\n                        // for dashing/dotting.\n                        vec2 prevSegment = start - prev;\n                        float prevLength = length(prevSegment);\n                        roundLength = roundStart * min(rounding, min(segmentLength, prevLength) / 2.0);\n                        vStart += roundLength * normal;\n                        vPatternLengthAndOffset.x -= roundLength;\n                        vVertexPosition += roundLength * normal * isStart;\n\n                        // Same but with 'end'\n                        vec2 nextSegment = next - end;\n                        float nextLength = length(nextSegment);\n                        roundLength = roundEnd * min(rounding, min(segmentLength, nextLength) / 2.0);\n                        vEndOrHalfWidthHeight -= roundLength * normal;\n                        vPatternLengthAndOffset.x -= roundLength;\n                        vVertexPosition -= roundLength * normal * isEnd;\n                    }\n                }\n            }\n\n            vStrokeStyleAndFlags = aCapJoinStroke.z + aCapJoinStroke.w * 256.0;\n\n            // For dashed/dotted lines/curves, there will be data in this to mark segment length/offsets.\n            if (aPatternLengthAndOffset.x > 0.0) {\n                vPatternLengthAndOffset = aPatternLengthAndOffset;\n            }\n\n            vec2 position = vVertexPosition * instanceScale + aBoundingBox.xy;\n\n            if (uIsShadow > 0.0) {\n                position = vVertexPosition + uShadowOffset;\n                position = position * uShadowZoom * 2.0 / vec2(uShadowCanvasSize.x, -uShadowCanvasSize.y);\n            } else {\n                if (aRotation.z != 0.0) {\n                    // Build rotation matrix\n                    float c = cos(aRotation.z);\n                    float s = sin(aRotation.z);\n                    mat2 rotationMatrix = mat2(c, -s, s, c);\n\n                    // Rotate around center if needed\n                    position = (position - aRotation.xy) * rotationMatrix + aRotation.xy;\n                }\n                position = (position + uPageOrTileOffset) * uZoom * 2.0 / vec2(uCanvasSize.x, -uCanvasSize.y);\n            }\n\n            float zOffset = aFlagsShapeZOffset.z;\n            gl_Position = vec4(position.x - 1.0, position.y + 1.0, (aInstance.x + zOffset) * uDepthFactor - 1.0, 1.0);\n        }"}cTb(){let a,
b,c="";(b=(a=this.options)==null?void 0:a.SBq)!=null&&b&&(c="\n                    if (color.a < 1.0 && alpha < 1.0) {\n                        gl_FragDepth = gl_FragCoord.z - (uDepthFactor / 2.0);\n                    } else {\n                        gl_FragDepth = gl_FragCoord.z;\n                    }");return`#version 300 es
        precision highp float;

        uniform sampler2D uStrokePatternSampler;  // For pattern data (dash/dot) from the pattern texture
        uniform vec2 uStrokePatternTextureSize;

        uniform float uZoom;
        uniform float uShadowZoom;
        uniform float uIsShadow;
        uniform float uDepthFactor;

        // Which edge we're on based on quadrant, and if we're closer to the vertical edge or not.
        // Indexed by quadrant * 2 + isVertical.
        const int edges[8] = int[8](0, 3, 0, 1, 2, 1, 2, 3);

        // Given a edge, which edges/corners come 'before' this one starting at top-left edge.
        const vec4 edgesBeforeEdge[4] = vec4[4](vec4(0.0), vec4(1.0, 0.0, 0.0, 0.0), vec4(1.0, 1.0, 0.0, 0.0), vec4(1.0, 1.0, 1.0, 0.0));
        const vec4 cornersBeforeEdge[4] = vec4[4](vec4(0.0), vec4(0.0, 1.0, 0.0, 0.0), vec4(0.0, 1.0, 1.0, 0.0), vec4(0.0, 1.0, 1.0, 1.0));

        // Given a corner, which edges/corners come 'before' this one starting at top-left edge.
        const vec4 edgesBeforeCorner[4] = vec4[4](vec4(1.0), vec4(1.0, 0.0, 0.0, 0.0), vec4(1.0, 1.0, 0.0, 0.0), vec4(1.0, 1.0, 1.0, 0.0));
        const vec4 cornersBeforeCorner[4] = vec4[4](vec4(0.0, 1.0, 1.0, 1.0), vec4(0.0), vec4(0.0, 1.0, 0.0, 0.0), vec4(0.0, 1.0, 1.0, 0.0));

        // Offsets from center of a shape to the corner
        const vec2 offsets[4] = vec2[4](vec2(-1.0, -1.0), vec2(1.0, -1.0), vec2(1.0, 1.0), vec2(-1.0, 1.0));

        // Normal for each edge of a shape indexed by side
        const vec2 normals[4] = vec2[4](vec2(1.0, 0.0), vec2(0.0, 1.0), vec2(-1.0, 0.0), vec2(0.0, -1.0));

        const vec2 joints[4] = vec2[4](vec2(0.0, 1.0), vec2(0.0, 1.0), vec2(0.0, 1.0), vec2(1.0, 1.0));

        // Stroke style metadata uniform array. Each vec3 contains:
        //     x: Total length of the pattern
        //     y: First entry of the pattern (i.e. 10 for [10, 5])
        //     z: Type of pattern (from StrokeStyleType: 0=Solid, 1=Dash, 2=Dot, 3=Stripe)
        uniform vec3 uStrokeStyleData[64];

        in vec2 vVertexPosition;

        in vec2 vStart;
        in vec2 vEndOrHalfWidthHeight;

        in float vOpacity;

        in vec2 vCenter;

        in float vFillType;
        in vec4 vCornerRadii;
        in float vLineWidth;
        in vec4 vColor;
        in vec2[2] vNormals;
        in float vFragmentFlags;
        in float vUseNext;
        in float vScale;

        // Strokestyle information
        in float vStrokeStyleAndFlags;
        in vec2 vPatternLengthAndOffset;

        // Output color variable
        out vec4 outColor;

        // Declare these here so we can reference them from inside function calls
        vec4 color;
        vec3 strokeStyle;
        float strokeStyleOffset;
        float halfLineWidth;
        float delta;
        float strokeAlpha;
        vec4 sideLengths;
        vec4 cornerLengths;
        float strokeStyleScaledPatternLength;
        float stretchStrokeStyleToFit;
        bool zoomInvariantStrokeStyle;
        float strokeStyleIndex;

        // Measure how many pixels we are along the arcLength by measuring the
        // angle between the arc's start and where we are.
        float pixelsIntoArc(vec2 arcStart, vec2 arcCenter, float radius) {
            // Get a vector from the center of the arc to the current pixel.
            vec2 fromCenter = vVertexPosition - arcCenter;
            vec2 fromStart = arcStart - arcCenter;

            // Measure the angle between the vectors 'fromCenter', and fromStart'.
            float cos2x = dot(fromCenter, fromStart) / (length(fromCenter) * radius);

            float angle = acos(cos2x);
            return angle * radius;
        }

        // When dotting, get the number of pixels that make up a complete pattern:
        // pixels between the centers of two dots.
        float dotPixelsPerPattern(float length, float pixelsIntoPattern) {
            // Find how many patterns fit in 'length' rounded to nearest whole number
            // For very short dotted segments the floor() might be < 1 so make sure we have at least 1 pattern.
            float numPatterns = max(floor((length / strokeStyleScaledPatternLength) + 0.5), 1.0);

            // Now store the pattern / pixel conversion factor.
            float patternPerPixel = strokeStyle.x * numPatterns / length;

            // How many pixels in a single pattern?
            float pixelsPerPattern = strokeStyle.x / patternPerPixel;
            if (length <= strokeStyleScaledPatternLength * 0.67) {
                pixelsPerPattern = length;
            }

            return pixelsPerPattern;
        }

        // Get the 'dash' alpha value (1.0 or 0.0) depending on dash/gap.
        float dashAlpha(float length, float pixelsIntoPattern, float patternOffset) {
            float patternPerPixel = 1.0;

            // When stretched (default) we want to know how far we step along the pattern
            // for each pixel.
            if (stretchStrokeStyleToFit == 1.0) {
                // If we don't have enough space for at least 2/3 of the pattern,
                // leave alpha at 1.  (Always solid)
                if (length <= strokeStyleScaledPatternLength * 0.67) {
                    return 1.0;
                }

                // Find how many patterns fit in this 'length' rounded to nearest whole number
                float numPatterns = floor((length / strokeStyleScaledPatternLength) + 0.5);

                // Pattern / pixel conversion factor.  How many texels in the texture
                // do we step through per pixel.
                patternPerPixel = strokeStyle.x * numPatterns / length;
            }

            // How many texels are we into the pattern?
            float texel = mod(pixelsIntoPattern * patternPerPixel + patternOffset, strokeStyle.x);

            // Sample the pattern texture.  Each row in the texture is a series of
            // 0 or 255.  So a pattern of [2, 4] would be [255, 255, 0, 0, 0, 0].
            // For the 'y', we add 0.5 so we sample from the center of the row's texel.
            vec2 texCoord = vec2(texel, strokeStyleIndex + 0.5) / uStrokePatternTextureSize;
            return texture(uStrokePatternSampler, texCoord).a;
        }

        float arcStrokeStyleAlpha(vec2 arcStart, vec2 arcCenter, float radius, float arcLength, float patternOffset) {
            float pixelsIntoPattern = pixelsIntoArc(arcStart, arcCenter, radius);

            if (strokeStyle.z == 1.0) {
                return dashAlpha(arcLength, pixelsIntoPattern, patternOffset);
            } else {
                float pixelsPerPattern = dotPixelsPerPattern(arcLength, pixelsIntoPattern);

                float closestCenter = floor((pixelsIntoPattern / pixelsPerPattern) + 0.5);
                float rotationInRadians = closestCenter * pixelsPerPattern / radius;

                // Rotate the arc's start around it's center.
                float c = cos(rotationInRadians);
                float s = sin(rotationInRadians);
                mat2 rotationMatrix = mat2(c, -s, s, c);

                vec2 fromStart = arcStart - arcCenter;
                vec2 dotCenter = fromStart * rotationMatrix + arcCenter;

                float dist = distance(vVertexPosition, dotCenter);
                return 1.0 - smoothstep(halfLineWidth - delta, halfLineWidth + delta, dist);
            }
        }

        float lineStrokeStyleAlpha(vec2 start, vec2 normal, float length, float patternStartOffset, float patternOffset) {
            // Get a vector from the start of the line (line's center) to our current pixel
            vec2 fromStart = vVertexPosition - start;

            // How far are we along the segment in the same direction as the segment.
            float pixelsIntoPattern = dot(fromStart, normal);

            // If the stroke style is zoom invariant multiply by zoom so the dashing
            // is in screen pixels instead of document units
            if (zoomInvariantStrokeStyle) {
                pixelsIntoPattern *= uZoom;
            }
            pixelsIntoPattern += patternOffset;

            if (strokeStyle.z == 1.0) {
                return dashAlpha(length, pixelsIntoPattern, patternStartOffset);
            } else {
                float pixelsPerPattern = dotPixelsPerPattern(length, pixelsIntoPattern);
                float closestCenter = floor((pixelsIntoPattern / pixelsPerPattern) + 0.5);

                float centerDistance = closestCenter * pixelsPerPattern - patternOffset;
                vec2 dotCenter = start + normal * centerDistance;
                float dist = distance(vVertexPosition, dotCenter);
                return 1.0 - smoothstep(halfLineWidth - delta, halfLineWidth + delta, dist);
            }
        }

        // Get the distance from the start of the shape (rectangle/circle) to 'edge'
        // and get the pattern alpha at that distance.
        float alphaFromShapeStart(int edge) {
            // Get vectors telling which sides/corners to sum the lengths of.
            // They look something like vec4(1.0, 1.0, 0.0, 0.0) for the 3rd edge so we
            // sum the previous 2 edges.
            vec4 edgesToSum = edgesBeforeEdge[edge];
            vec4 cornersToSum = cornersBeforeEdge[edge];

            // Dot products will sum the sides/corners we're interested in
            float distanceBeforeEdgeStart = dot(sideLengths, edgesToSum) + dot(cornerLengths, cornersToSum);

            // Get the edge's start
            vec2 normal = normals[edge];
            vec2 start = vCenter + (offsets[edge] * vEndOrHalfWidthHeight) + (normal * vCornerRadii[edge]);

            vec2 fromStart = vVertexPosition - start;

            return lineStrokeStyleAlpha(start, normal, sideLengths[edge], distanceBeforeEdgeStart, 0.0);
        }

        void main() {
            float zoom = (uIsShadow > 0.0) ? uShadowZoom : uZoom * vScale;

            strokeAlpha = 1.0;
            halfLineWidth = vLineWidth / 2.0;
            delta = 0.5 / zoom;
            color = vColor;

            // This contains the strokestyle and flags affecting how its used.
            int strokeStyleAndFlags = int(vStrokeStyleAndFlags);

            // The strokestyle index is sent in the lower bytes with flags in the upper byte.
            int intStrokeStyleIndex = strokeStyleAndFlags & 0xff;
            int strokeStyleFlags = strokeStyleAndFlags >> 8;

            // Lookup stroke style information
            //   x = length of pattern
            //   y = first element
            //   z = StrokeStyleType.[Solid | Dash | Dot]
            strokeStyle = uStrokeStyleData[intStrokeStyleIndex];
            strokeStyleIndex = float(intStrokeStyleIndex);

            // And the flags affecting stroke style
            bool scaleStrokeStyleByLineWidth = ((strokeStyleFlags & 1) != 0);
            stretchStrokeStyleToFit = ((strokeStyleFlags & 2) != 0) ? 1.0 : 0.0;
            zoomInvariantStrokeStyle = ((strokeStyleFlags & 8) != 0);

            float patternScale = scaleStrokeStyleByLineWidth ? vLineWidth : 1.0;
            strokeStyleScaledPatternLength = strokeStyle.x * patternScale;

            int fragmentFlags = int(vFragmentFlags);

            if (vFillType == 1.0) {
