i18n.setData(
    JSON.parse(
        "{\"activity-context-menu-add-attribute\":\"Add attribute\",\"activity-context-menu-toggle-axis\":\"Axis\",\"activity-context-menu-toggle-category\":\"Category\",\"activity-context-menu-toggle-option-bank\":\"Option Bank\",\"add-alt-text-button-group-save\":\"Group & save\",\"add-alt-text-group-description\":\"To add a single description to these items, they will be combined into one group.\",\"add-alt-text-heading-group\":\"Group & add alt text\",\"add-alt-text-helper-text\":\"Provide a brief description for screen readers. If the visual is purely decorative, you can leave this blank.\",\"add-alt-text-input-label\":\"Alt text\",\"add-alt-text-input-placeholder-group\":\"e.g., \\\"Company logo,\\\" \\\"Flowchart of the login process,\\\" or \\\"Rough sketch of a house\\\"\",\"agile-capacity-planning-capacity-editing-disabled\":\"This feature is part of the Agility Accelerator. Upgrade to set team capacity.\",\"agile-capacity-planning-onboarding-description\":\"Easily set and track your team's sprint capacity.\",\"agile-capacity-planning-onboarding-primary-button-text\":\"Try it out\",\"agile-capacity-planning-onboarding-title\":\"Plan for capacity\",\"agile-capacity-planning-set-field-apply-to-all\":\"Apply to all\",\"ai-agent-activity-search-action-indicator\":\"Searched documents activity\",\"ai-agent-add-dynamic-table-rows-columns-action-indicator\":\"Added rows and columns\",\"ai-agent-add-items-to-dynamic-table-action-indicator\":\"Added items to dynamic table\",\"ai-agent-add-items-to-timeline-action-indicator\":\"Added items to timeline\",\"ai-agent-add-shape-bank-action-indicator\":\"Added shape bank\",\"ai-agent-change-shape-action-indicator\":\"Changed shape\",\"ai-agent-copy-paste-items-action-indicator\":\"Copying blocks...\",\"ai-agent-create-ai-suggestions-action-indicator.one\":\"Created {count} suggestion\",\"ai-agent-create-ai-suggestions-action-indicator.other\":\"Created {count} suggestions\",\"ai-agent-create-block-action-indicator\":\"Created shape\",\"ai-agent-create-diagram-key-action-indicator\":\"Created diagram key\",\"ai-agent-create-dynamic-table-action-indicator\":\"Created table\",\"ai-agent-create-line-action-indicator\":\"Created line\",\"ai-agent-create-lucid-timeline-action-indicator\":\"Created timeline\",\"ai-agent-create-process-header-action-indicator\":\"Created process header\",\"ai-agent-create-visual-activity-action-indicator\":\"Created visual activity\",\"ai-agent-delete-item-action-indicator-v2.one\":\"Deleted shape\",\"ai-agent-delete-item-action-indicator-v2.other\":\"Deleted shapes\",\"ai-agent-edit-block-card-data-action-indicator\":\"Updated card\",\"ai-agent-edit-block-style-action-indicator\":\"Updated shape style\",\"ai-agent-edit-card-data-confirmation-prompt\":\"Update data fields on {count} card(s)?\",\"ai-agent-edit-card-data-confirmation-single-field\":\"Update \\\"{fieldName}\\\" to \\\"{value}\\\"?\",\"ai-agent-edit-card-data-done-indicator\":\"Updated card data\",\"ai-agent-edit-dynamic-table-metadata-action-indicator\":\"Updated dynamic table data\",\"ai-agent-edit-line-endpoint-action-indicator\":\"Updated line endpoint\",\"ai-agent-edit-line-style-action-indicator\":\"Updated line style\",\"ai-agent-edit-text-area-action-indicator\":\"Updated text\",\"ai-agent-edit-timeline-metadata-action-indicator\":\"Updated timeline settings\",\"ai-agent-export-document-action-indicator\":\"Exported document\",\"ai-agent-find-space-action-indicator\":\"Found available space\",\"ai-agent-generate-process-diagram-action-indicator\":\"Generated process diagram\",\"ai-agent-generate-semantic-diagram-action-indicator-fallback\":\"Generated diagram\",\"ai-agent-generate-semantic-diagram-action-indicator-v2\":\"Generated \\\"{name}\\\"\",\"ai-agent-get-capture-frames-action-indicator\":\"Retrieved capture frames\",\"ai-agent-get-connection-points-action-indicator\":\"Found connection points\",\"ai-agent-get-data-backed-shapes-action-indicator-v2\":\"Read shapes\",\"ai-agent-get-document-history-action-indicator-v2\":\"Read document history\",\"ai-agent-get-resource-schemas-for-dataset-action-indicator-v2\":\"Read schema\",\"ai-agent-get-resource-types-for-dataset-action-indicator-v2\":\"Read resource types\",\"ai-agent-get-screenshot-action-indicator\":\"Captured document screenshot\",\"ai-agent-get-semantic-data-agent-for-query-action-indicator\":\"Routing to the right agent\",\"ai-agent-get-semantic-datasets-for-query-action-indicator\":\"Found relevant data\",\"ai-agent-get-semantic-datasets-ids-for-domain-action-indicator-v2\":\"Collected dataset ids\",\"ai-agent-get-semantic-relation-definitions-action-indicator\":\"Fetching relation definitions\",\"ai-agent-import-jira-to-board-action-indicator\":\"Imported Jira issues to board\",\"ai-agent-import-jira-to-board-confirmation-prompt\":\"Import Jira issues?\",\"ai-agent-import-jira-to-board-confirmation-prompt-with-query\":\"Import Jira issues with query: \\\"{query}\\\"?\",\"ai-agent-jira-search-action-indicator\":\"Searched Jira\",\"ai-agent-jira-search-confirmation-prompt\":\"Search Jira for issues?\",\"ai-agent-jira-search-confirmation-prompt-with-query\":\"Search Jira with query: \\\"{query}\\\"?\",\"ai-agent-move-block-action-indicator\":\"Moved block\",\"ai-agent-move-block-in-assisted-layout-done-indicator\":\"Moved block in assisted layout\",\"ai-agent-move-block-in-assisted-layout-done-indicator-v2\":\"Moved block in grid layout\",\"ai-agent-open-search-action-indicator\":\"Searched documents\",\"ai-agent-query-semantic-resources-action-indicator-v2\":\"Read resources\",\"ai-agent-query-semantic-resources-with-sparql-action-indicator\":\"Querying resources with SPARQL\",\"ai-agent-read-ai-suggestions-action-indicator\":\"Read suggestions\",\"ai-agent-recommend-erd-layout-action-indicator\":\"Computed ERD layout\",\"ai-agent-recommend-grid-layout-action-indicator\":\"Computed grid layout\",\"ai-agent-recommend-sugiyama-layout-action-indicator\":\"Computed flowchart layout\",\"ai-agent-render-action-indicator\":\"Looking at the document\",\"ai-agent-reroute-lines-action-indicator.one\":\"Rerouted line\",\"ai-agent-reroute-lines-action-indicator.other\":\"Rerouted lines\",\"ai-agent-resize-block-action-indicator\":\"Resized block\",\"ai-agent-resolve-ai-suggestions-action-indicator.one\":\"Resolved {count} suggestion\",\"ai-agent-resolve-ai-suggestions-action-indicator.other\":\"Resolved {count} suggestions\",\"ai-agent-run-script-action-indicator\":\"Ran script\",\"ai-agent-set-block-shape-property-action-indicator\":\"Updated shape property\",\"ai-agent-shape-details-action-indicator\":\"Retrieved shape details\",\"ai-agent-shape-library-action-indicator\":\"Browsed shape libraries\",\"ai-agent-switch-agent-action-indicator\":\"Switched agent\",\"ai-agent-sync-jira-to-dynamic-table-action-indicator\":\"Synced Jira issues to dynamic table\",\"ai-agent-sync-jira-to-dynamic-table-confirmation-prompt\":\"Import Jira issues onto the dynamic table?\",\"ai-agent-sync-jira-to-dynamic-table-confirmation-prompt-with-query\":\"Import Jira issues matching \\\"{query}\\\" onto the dynamic table?\",\"ai-agent-sync-jira-to-timeline-action-indicator\":\"Synced Jira issues to timeline\",\"ai-agent-sync-jira-to-timeline-confirmation-prompt\":\"Import Jira issues onto the timeline?\",\"ai-agent-sync-jira-to-timeline-confirmation-prompt-with-query\":\"Import Jira issues matching \\\"{query}\\\" onto the timeline?\",\"ai-agent-text-to-board-action-indicator\":\"Creating board\",\"ai-agent-text-to-board-action-indicator-fallback\":\"Generated board\",\"ai-agent-text-to-board-action-indicator-v2\":\"Generated \\\"{name}\\\"\",\"ai-agent-think-aloud-done-indicator\":\"Thought deeply\",\"ai-agent-update-ai-suggestions-action-indicator.one\":\"Updated {count} suggestion\",\"ai-agent-update-ai-suggestions-action-indicator.other\":\"Updated {count} suggestions\",\"ai-agent-user-lookup-action-indicator\":\"Searched users\",\"ai-agent-validate-canvas-action-indicator\":\"Validated canvas\",\"ai-agent-wrap-in-container-action-indicator\":\"Wrapped items in a container\",\"ai-ask-lucid-ai\":\"Ask Lucid AI\",\"ai-assistant-chunk-summarize-agent-action-indicator\":\"Summarized\",\"ai-assistant-compacted-conversation-history\":\"Compacted conversation history\",\"ai-assistant-conditional-formatting-action-indicator-created-v2\":\"Created rule\",\"ai-assistant-conditional-formatting-action-indicator-updated-v2\":\"Updated rule\",\"ai-assistant-default-permission-question\":\"Allow the AI assistant to use the {toolname} tool?\",\"ai-assistant-describe-what-you-want-or-type-slash\":\"Describe what you want or type /\",\"ai-assistant-diagram-link-text\":\"diagram\",\"ai-assistant-diagram-not-found\":\"Diagram not found. It may have been deleted.\",\"ai-assistant-export-mermaid-action-indicator\":\"Generated Mermaid code\",\"ai-assistant-feature-find-action-indicator\":\"Found features\",\"ai-assistant-filter-canvas-agent-action-indicator-v2\":\"Read canvas\",\"ai-assistant-generate-ideas-action-indicator\":\"Generated ideas\",\"ai-assistant-generate-ideas-want-to-adjust\":\"I've added more ideas. Want to adjust anything?\",\"ai-assistant-help-center-action-indicator-v3\":\"Searched Lucid help desk\",\"ai-assistant-items-sorted-want-to-adjust\":\"Items sorted. Want to adjust anything?\",\"ai-assistant-lucid-ai\":\"Lucid AI\",\"ai-assistant-message-header\":\"Message from AI Assistant\",\"ai-assistant-navigate-to-diagram\":\"Go to diagram\",\"ai-assistant-navigate-to-visual-activity\":\"Go to visual activity\",\"ai-assistant-not-sure-what-to-say\":\"Not sure what to say? Here's one way to start.\",\"ai-assistant-process-agent-display-name\":\"Process Agent\",\"ai-assistant-recreate-diagram\":\"Recreate diagram\",\"ai-assistant-recreate-visual-activity\":\"Recreate visual activity\",\"ai-assistant-shapes-selected.one\":\"{count} shape selected\",\"ai-assistant-shapes-selected.other\":\"{count} shapes selected\",\"ai-assistant-standard-import-action-indicator-v2\":\"Imported diagram data\",\"ai-assistant-suggested-action-bpmn-choreography-diagram-display-text\":\"BPMN choreography diagram\",\"ai-assistant-suggested-action-bpmn-conversation-diagram-display-text\":\"BPMN conversation diagram\",\"ai-assistant-suggested-action-class-diagram-display-text\":\"Class diagram\",\"ai-assistant-suggested-action-erd-display-text\":\"ERD\",\"ai-assistant-suggested-action-flowchart-display-text\":\"Flowchart\",\"ai-assistant-suggested-action-hardcoded-response-aws\":\"Okay! Let's start by describing your AWS architecture.\\n\\nDescribe the AWS system you want to create. Just explain its purpose and how the main services (like EC2, S3, or Lambda) will interact.\",\"ai-assistant-suggested-action-hardcoded-response-azure\":\"Okay! Let's start by describing your Azure architecture.\\n\\nDescribe the Azure system you want to create. Just explain its purpose and how the main services (like App Service, Blob Storage, or Azure SQL) will interact.\",\"ai-assistant-suggested-action-hardcoded-response-bpmn-choreography\":\"Perfect, we'll map out the sequence of interactions with a Choreography Diagram.\\n\\nTo get started, please outline the flow of messages between the different participants. Be sure to include any key decisions or events that change the path of the interaction.\",\"ai-assistant-suggested-action-hardcoded-response-bpmn-conversation\":\"Excellent, let's model the high-level conversations in your business process.\\n\\nTo begin, please identify the main participants involved and then describe the key message exchanges that occur between them.\",\"ai-assistant-suggested-action-hardcoded-response-class-diagram\":\"Great, let's build your Class Diagram!\\n\\nJust tell me the main classes you need, and for each one, briefly describe its properties, the actions it can perform, and how it connects to the others.\",\"ai-assistant-suggested-action-hardcoded-response-erd\":\"Happy to help you create an Entity-Relationship Diagram (ERD)!\\n \\nTo get started, please list the key entities in your system (like 'Customer' or 'Product'). Then, for each entity, tell me its important attributes (like 'name' or 'price'). Finally, describe how these entities relate to one another (for example, \\\"one customer can have many orders\\\").\",\"ai-assistant-suggested-action-hardcoded-response-flowchart\":\"Great, let's create a flowchart! It's a perfect way to visualize any process.\\n\\nJust walk me through the steps from start to finish. Be sure to mention any decision points where the path might split (for example, \\\"if payment is approved, then proceed\\\").\",\"ai-assistant-suggested-action-hardcoded-response-gcp\":\"Got it. Let's map out your Google Cloud Platform (GCP) architecture.\\n\\nTo begin, tell me about the system's goal. Be sure to include the core GCP products you envision using and how they'll fit together.\",\"ai-assistant-suggested-action-hardcoded-response-mind-map\":\"Awesome, a mind map is a great way to explore ideas! \\n\\nTo get started, what is the central concept you want to put in the middle? Then, just list the main themes or categories you'd like to see branch out from there, and I'll map it all out for you.\",\"ai-assistant-suggested-action-hardcoded-response-network-diagram\":\"Okay, a network diagram it is!\\n \\nTo build it out, describe the network's layout. Be sure to mention the key devices like routers and firewalls, and any specific subnets or zones you want to show.\",\"ai-assistant-suggested-action-hardcoded-response-sequence-diagram\":\"I'd love to help you create a Sequence Diagram!\\n\\nTo get started, just tell me who (or what systems) are the main players in this interaction. Once we have the participants, just walk me through the messages they exchange in the order they happen!\",\"ai-assistant-suggested-action-mind-map-display-text\":\"Mind map\",\"ai-assistant-suggested-action-network-diagram-display-text\":\"Network diagram\",\"ai-assistant-suggested-action-sequence-diagram-display-text\":\"Sequence diagram\",\"ai-assistant-summarize-documents-action-indicator\":\"Summarized documents\",\"ai-assistant-try-example-prompt\":\"Try example prompt\",\"ai-assistant-visual-activity-not-found\":\"Visual activity not found. It may have been deleted.\",\"ai-assistant-wave-limit-reached-fallback\":\"Independent work limit reached. Should I keep going?\",\"ai-brainstorm\":\"Brainstorm\",\"ai-brainstorm-board-example-prompt\":\"Set up a brainstorming board for our upcoming summer marketing campaign. Organize the space so we can categorize ideas by 'Social Media,' 'Email,' and 'Events.' Make sure there's plenty of room for the team to drop in sticky notes.\",\"ai-chat-input-menu-cloud-agent-display-name\":\"Cloud Agent\",\"ai-chat-input-menu-leanix-agent-display-name\":\"LeanIX Agent\",\"ai-conditional-formatting\":\"Conditional formatting with AI\",\"ai-contextual-callout-expand-mind-map-with-ideas\":\"Expand with ideas\",\"ai-contextual-callout-expand-mind-map-with-questions\":\"Expand with questions\",\"ai-contextual-callout-generate-mind-map-ideas-disabled-tooltip\":\"Select 1 node at a time to expand\",\"ai-data-access-consent-cancel\":\"Cancel\",\"ai-data-access-consent-continue\":\"Continue\",\"ai-data-access-consent-default-message-v2\":\"To provide accurate results, my next step is referencing the {domain} data associated with this document.\",\"ai-edit-diagram-success-action-prefix\":\"Edited\",\"ai-followup-action-brainstorm-ideas-display-text\":\"Brainstorm ideas\",\"ai-followup-action-brainstorm-ideas-hardcoded-response\":\"Okay, I can help you brainstorm some ideas. Can you give me a topic?\",\"ai-followup-action-sort-shapes-display-text\":\"Sort shapes\",\"ai-followup-action-sort-shapes-hardcoded-response\":\"Awesome. I can help you sort shapes. To get started, I'll need:\\n- Which shapes you want to sort (select them, or reference them e.g., all sticky notes)\\n- How you'd like me to sort them (e.g., by color)\",\"ai-followup-action-summarize-content-display-text\":\"Summarize content\",\"ai-followup-action-summarize-content-hardcoded-response\":\"Great, please tell me what you'd like to summarize. You can select the content on the canvas you'd like summarized or reference it.\",\"ai-generate-diagram\":\"Generate diagram\",\"ai-generate-diagram-example-aws-deployment-process-contents\":\"Create a high-level AWS architecture diagram for a scalable web application. The application should have a front end hosted on Amazon S3 and distributed via Amazon CloudFront. The backend should use an EC2 Auto Scaling group behind an Application Load Balancer to handle incoming traffic. Data should be stored in an Amazon RDS database. Include an Amazon SQS queue to handle asynchronous tasks and an Amazon SNS topic for notifications.\",\"ai-generate-diagram-example-azure-ml-deployment-contents\":\"Create a high-level Azure architecture diagram for a resilient web application. The front end should be hosted in Azure Blob Storage and distributed globally with Azure CDN. The backend should use Azure App Service, configured to autoscale, with an Azure Application Gateway managing traffic. Store primary data in an Azure SQL Database and use Azure Queue Storage for asynchronous background tasks.\",\"ai-generate-diagram-example-bank-loan-application-contents\":\"Create a BPMN choreography diagram with Applicant, Bank, and Credit Agency as participants. Start with a Start Event labeled Loan Application Initiated, followed by Choreography Tasks for Submit Loan Application (Applicant to Bank) and Acknowledge Receipt (Bank to Applicant). Add Request Credit Report (Bank to Credit Agency) with a Timer Intermediate Event for waiting, followed by Provide Credit Report (Credit Agency to Bank). After receiving the credit report, include an Exclusive Gateway with two branches: one for Notify Approval (Bank to Applicant) with an optional Sign Agreement (Applicant to Bank), ending in a Message End Event labeled Loan Approved; and another for Notify Rejection (Bank to Applicant), ending in a Message End Event labeled Loan Rejected. Ensure all Message Flows, Gateways, and Intermediate Events are logically connected and annotated clearly.\",\"ai-generate-diagram-example-erd-event-management-system-contents-v2\":\"Design an ERD for an event management system that includes entities for events, attendees, venues, and sponsors. Highlight relationships like events-to-attendees (many-to-many), events-to-venues (many-to-one), and events-to-sponsors (many-to-many). Include attributes such as event dates, attendee contact information, venue capacity, and sponsorship amounts.\",\"ai-generate-diagram-example-gcp-serverless-event-architecture-contents\":\"Draft a GCP architecture diagram for a containerized, scalable microservices application. User requests should go through a global external HTTPS Load Balancer. The load balancer will route traffic to various backend services running on Google Kubernetes Engine (GKE). Static assets like images and CSS should be stored in a Google Cloud Storage bucket and served through Cloud CDN. Use Cloud SQL for the primary relational database and Pub/Sub to manage asynchronous messaging between services.\",\"ai-generate-diagram-example-mind-map-startup-business-model-contents-v2\":\"Create a mind map that outlines the key components of a startup business model. Map out areas like value proposition, customer segments, revenue streams, cost structure, key partnerships, key activities, key resources, customer relationships, and distribution channels. Show how these elements interconnect to form a viable business strategy.\",\"ai-generate-diagram-example-network-architecture-contents\":\"Create a network diagram for a small office. The diagram should show an internet connection coming into a primary firewall. Behind the firewall, a core switch connects to an internal corporate LAN (192.168.1.0/24) that includes several PCs and a file server. The firewall also provides a connection for a separate, isolated guest Wi-Fi network (10.10.10.0/24) managed by a wireless access point.\",\"ai-generate-diagram-example-online-shopping-site-contents\":\"Draw a sequence diagram for an online shopping site.\",\"ai-generate-diagram-example-order-fulfillment-contents\":\"Draw a BPMN Conversation diagram of a process involving a customer, retailer, and supplier. The customer and retailer exchange order details. The retailer and supplier communicate about stock availability. The retailer and customer discuss shipment updates. Each pair has a single exchange to coordinate order fulfillment.\",\"ai-generate-diagram-example-project-management-process-contents-v3\":\"Draw a flowchart for a project management process, covering activities like project initiation, planning, execution, monitoring, and closure. Include nodes for resource allocation, risk assessment, and stakeholder communication. Add decision nodes for scope changes, budget approvals, and quality gates throughout the project lifecycle.\",\"ai-generate-diagram-example-project-management-system-contents-v2\":\"Draw a class diagram for a project management system. Include classes such as Project, TeamMember, Task, Milestone, and Comment. Show relationships like project-to-tasks (one-to-many), team members-to-tasks (many-to-many), and tasks-to-comments (one-to-many). Include attributes such as project deadlines, task priorities, team member roles, and milestone dates.\",\"ai-generate-diagram-success-action-prefix\":\"Generated\",\"ai-process-agent-read-process-context-frame-done-indicator\":\"Read process context frame\",\"ai-project-kickoff-example-prompt\":\"I'm starting a project kickoff for a website redesign and need a board to align the team. Create sections for our project goals, high-level milestones, and team roles. Use a clear layout that separates the vision from the tactical next steps.\",\"ai-response-note-block-attribution\":\"Generated by {user} on {date}\",\"ai-sort\":\"Sort\",\"ai-sprint-planning-example-prompt\":\"Create a sprint planning board for a one-week sprint. I need a simple flow to track tasks from 'To Do' through 'Done,' with a dedicated spot at the top to highlight our main sprint objective.\",\"ai-sprint-retro-example-prompt\":\"Help me run a sprint retro for our 'Mobile Checkout' project. I need a workspace organized into four categories: what went well, what didn't, ideas for next time, and action items. Please include some starting stickies in each area.\",\"ai-summarize\":\"Summarize\",\"ai-tool-loading-generating-diagram\":\"Generating diagram...\",\"ai-translate-panel-title\":\"AI translate\",\"ai-zero-state-ask-questions-content-conversation-message\":\"Great, I can answer questions you have about this document or scour our help center to help you learn more about Lucid.\",\"ai-zero-state-ask-questions-description\":\"Explore this document or get help.\",\"ai-zero-state-ask-questions-empty-conversation-message\":\"Great, I can scour our help center to help you learn more about Lucid.  Once you add content to the canvas, I can also answer questions about this document.\",\"ai-zero-state-ask-questions-example-prompt\":\"What is the core problem or process this document is trying to solve or illustrate?\",\"ai-zero-state-ask-questions-title\":\"Ask questions\",\"ai-zero-state-brainstorm-board-conversation-message\":\"Great — I'll set up a brainstorming board. A few quick details:\\n1. What is the main topic or problem we're solving?\\n2. How many categories or themes do you want to start with?\\n3. Should I include a 'parking lot' area for unrelated ideas?\\n4. Do you want the board organized by swimlanes or separate frames?\\n\\nAlternatively, you can use the example prompt.\",\"ai-zero-state-brainstorm-board-description\":\"Create a structured brainstorming space for your team to collaborate and organize ideas.\",\"ai-zero-state-brainstorm-board-title\":\"Run a brainstorming session\",\"ai-zero-state-brainstorm-content-conversation-message\":\"Okay, what can I help you with? Here are some examples to get you started.\",\"ai-zero-state-brainstorm-description\":\"Generate ideas and organize them visually.\",\"ai-zero-state-brainstorm-empty-conversation-message\":\"Okay, I can help you brainstorm some ideas. Can you give me a topic?\",\"ai-zero-state-brainstorm-ideas-example-prompt\":\"Generate some ideas for how my team might build AI tooling into their workflows.\",\"ai-zero-state-brainstorm-title-v2\":\"Brainstorm ideas\",\"ai-zero-state-cloud-data-beta-sticker-label\":\"BETA\",\"ai-zero-state-cloud-data-description\":\"Generate a diagram from your imported cloud infrastructure\",\"ai-zero-state-cloud-data-title\":\"Diagram with cloud data\",\"ai-zero-state-design-process-example-prompt\":\"Help me build an onboarding flow designed to minimize time-to-productivity and maximize long-term employee retention.\",\"ai-zero-state-diagram-conversation-message\":\"Okay, describe what kind of diagram you want to create or explore an example with the options below.\",\"ai-zero-state-diagram-description\":\"Create a flowchart, ERD, mind map, and much more.\",\"ai-zero-state-diagram-title-v3\":\"Build a diagram\",\"ai-zero-state-export-mermaid-beta-sticker\":\"Beta\",\"ai-zero-state-export-mermaid-submit-prompt\":\"Export this diagram as Mermaid code\",\"ai-zero-state-export-mermaid-title\":\"Export as Mermaid\",\"ai-zero-state-facilitate-retrospective-title\":\"Facilitate a retrospective\",\"ai-zero-state-get-action-items\":\"Get action items\",\"ai-zero-state-group-create-diagram-title\":\"Create a diagram\",\"ai-zero-state-group-plan-meeting-title\":\"Plan a meeting\",\"ai-zero-state-group-think-with-me-title\":\"Think with me\",\"ai-zero-state-make-flowchart-title\":\"Make a flowchart\",\"ai-zero-state-mcp-server-description\":\"Integrate Lucid with AI tools using the Lucid MCP server.\",\"ai-zero-state-mcp-server-title\":\"Try the MCP server\",\"ai-zero-state-process-agentic-sticker-label-v2\":\"New\",\"ai-zero-state-process-description\":\"Work together to capture and draft processes.\",\"ai-zero-state-process-title-v3\":\"Design a process\",\"ai-zero-state-process-title-v4\":\"Document a process\",\"ai-zero-state-project-kickoff-conversation-message\":\"Great — I'll set up a project kickoff board. A few quick details:\\n1. What is the name of the project?\\n2. What are the 3-4 key sections you need (e.g., Goals, Roles, Timeline)?\\n3. How many team members should I account for in the roles section?\\n4. Do you want a text area for the project's 'North Star' statement at the top?\\n\\nAlternatively, you can use the example prompt.\",\"ai-zero-state-project-kickoff-description\":\"Create a project kickoff board to align your team on goals, roles, and next steps.\",\"ai-zero-state-project-kickoff-title\":\"Kick off a project\",\"ai-zero-state-project-planning-conversation-message\":\"Okay, describe what you want to plan or explore an example with the options below.\",\"ai-zero-state-project-planning-daily-standup-pill\":\"Host a daily standup\",\"ai-zero-state-project-planning-daily-standup-prompt\":\"Create a dynamic table for a daily standup\",\"ai-zero-state-project-planning-description\":\"Create a project timeline or dynamic table from your Jira data.\",\"ai-zero-state-project-planning-plan-sprint-pill\":\"Plan a sprint\",\"ai-zero-state-project-planning-plan-sprint-prompt\":\"Create a dynamic table for sprint planning\",\"ai-zero-state-project-planning-title\":\"Plan and visualize a project\",\"ai-zero-state-project-planning-visualize-timeline-pill\":\"Visualize work on a timeline\",\"ai-zero-state-project-planning-visualize-timeline-prompt\":\"I want to visualize my work on a timeline\",\"ai-zero-state-run-sprint-retro-title\":\"Run a sprint retro\",\"ai-zero-state-sprint-planning-conversation-message\":\"Great — I'll set up a sprint planning board. A few quick details:\\n1. How long is this sprint?\\n2. What's the main goal or theme?\\n3. How many people are on the team?\\n4. Do you want tasks grouped by priority, owner, or status?\\n\\nAlternatively, you can use the example prompt.\",\"ai-zero-state-sprint-planning-description\":\"Create a sprint planning board to organize tasks and align your team for the upcoming sprint.\",\"ai-zero-state-sprint-planning-title\":\"Plan a sprint\",\"ai-zero-state-sprint-retro-conversation-message\":\"Great — I'll set up a sprint retro board. A few quick details:\\n1. What was the name or date of this sprint?\\n2. Which retro format do you prefer (e.g., 'Went Well/To Improve' or 'Start/Stop/Continue')?\\n3. How many participants are joining?\\n4. Do you want a dedicated frame for action items?\\n\\nAlternatively, you can use the example prompt.\",\"ai-zero-state-sprint-retro-description\":\"Create a sprint retrospective to reflect on your team's accomplishments and areas for improvement.\",\"ai-zero-state-sprint-retro-title\":\"Facilitate a sprint retrospective\",\"ai-zero-state-summarize-example-prompt\":\"Turn the contents of this board into a short, executive summary.\",\"at-mention-comment-ui-hint-tooltip\":\"Add an @mention comment\",\"aws-agent-standard-intro-v2\":\"Hi there! I'm Lucid's Cloud Agent — I'm here to help you visualize and communicate your cloud infrastructure. Here is how we will work together:\\n\\n1. <w0>Describe your goal</w0>: Tell me what part of your infrastructure you want to visualize or what kind of diagram you want to create, even if it's just a rough idea.\\n2. <w1>I'll handle the specifics</w1>: I'll ask clarifying questions about the focus of your diagram and what level of detail you'd like to include, then I'll start querying the data attached to this document to get an idea of what should be in scope.\\n3. <w2>We'll build the diagram</w2>: I will generate an architecture diagram that we can refine together to ensure it's ready for your audience.\\n\\nIn the chat below, describe how you want to get started!\",\"aws-name-2025-v3\":\"AWS\",\"azure2024-title\":\"Azure\",\"blueprint-creator-toolkit-toolbar-tool-blueprint-v2\":\"Customize blueprint\",\"blueprint-module-add-insights-callout-title\":\"Share insights\",\"blueprint-module-insights-info-callout-title\":\"Insight shape\",\"button-export-v2\":\"Export\",\"canonical-document-input-parameters-backlog-v2\":\"Backlog refinement\",\"canonical-document-input-parameters-daily-standup\":\"Daily standup\",\"canonical-document-input-parameters-sprint-planning-v2\":\"Team planning\",\"canvas-direct-menu-timeline-keywords\":\"plan\",\"canvas-zero-state-action-tag-add-cloud-frame\":\"Add a cloud frame\",\"canvas-zero-state-action-tag-ai\":\"Diagram with AI\",\"canvas-zero-state-action-tag-browse-shapes\":\"Browse shape libraries\",\"canvas-zero-state-action-tag-diagram-cloud-agent\":\"Diagram with the Cloud Agent\",\"canvas-zero-state-action-tag-freeform-shapes\":\"Use freeform shapes\",\"canvas-zero-state-action-tag-import-data\":\"Import data\",\"canvas-zero-state-action-tag-import-templates\":\"Import templates\",\"canvas-zero-state-action-tag-manage-data\":\"Manage data\",\"canvas-zero-state-dismiss\":\"Dismiss\",\"canvas-zero-state-do-not-show-again\":\"Don't show again\",\"canvas-zero-state-dropdown-menu-trigger\":\"Zero state command dropdown menu trigger\",\"canvas-zero-state-title-get-started-faster\":\"Get started faster\",\"chart-conditional-formatting-v2\":\"Conditional formatting\",\"chart-data\":\"Data\",\"chart-data-linking-v2\":\"Data linking\",\"chart-group-data\":\"Selected Group Data\",\"chart-line-data\":\"Selected Line Data\",\"chart-mode-info-bar-comment-only-v2\":\"Comment only\",\"chart-mode-info-bar-view-only-v2\":\"View only\",\"chart-object-data\":\"Selected Object Data\",\"chart-page-data\":\"Current Page Data\",\"chart-present\":\"Present\",\"chart-shape-data\":\"Selected Shape Data\",\"cloud-insights-generator-after-deprecation-banner-button\":\"Use Lucidscale\",\"cloud-insights-generator-af