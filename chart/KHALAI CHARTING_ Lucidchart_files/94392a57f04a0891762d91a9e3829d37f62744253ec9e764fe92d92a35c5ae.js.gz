[a.toString(),Uc5sc[a]]));var Ucdtc={type:"System",name:UcWa.MQq,Vj:Ucha.wf,isAvailable:()=>!0,description:"Load when adding, moving, or reordering blocks inside any **Assisted Layout** grid (e.g. swimlanes, generated flowcharts) — a container whose children sit in rows/columns instead of x/y",Hr:new Set([UcDd.z7a,UcDd.s5e]),content:'# Assisted Layout Skill\n\nPlace, move, or insert blocks inside **Assisted Layout** containers — grids whose generator, not raw x/y, decides where each child sits (rows and columns, sometimes split into subsections such as swimlane lanes). You cannot position a child with x/y; you must address a grid cell, and only *MoveBlockInAssistedLayout* can do that.\n\n## Detecting It\n\nRead the target area with *CanvasQuery* before placing or moving — prefer `TextPattern` over `SelectionCriteria` so the containing grid comes back in the result. It is an assisted-layout grid if the result shows either:\n\n- a child block with a `row` or `column` field, or\n- a container with `"assistedLayoutEnabled": true`.\n\nIf neither is present, it is a regular container. This skill does not apply. Place its children with x/y.\n\n## Resolving the ContainerId\n\n- **Swimlane** — the node with `BlockClass: AdvancedSwimLaneBlock`; use its un-suffixed `id`, not a wrapping `SparkFrameBlock` or a synthetic lane entry like `<id>-1`. Each **lane is a subsection** — note the `id` of the target lane\'s subsection node in the same *CanvasQuery* result; you address the lane by that id, never by a row/column number.\n- **Flowchart / other grid** — the container with `"assistedLayoutEnabled": true`; use its id directly.\n\n## Moving an Existing Block\n\nCall *MoveBlockInAssistedLayout* with the block\'s `ItemId` and target `Placement`. It works whether the block is already in the grid or coming from elsewhere, preserving its id, connected lines, and comments.\n\n- **Swimlanes — the lane is imperative.** Set `RowSubsectionId` (horizontal lanes) or `ColumnSubsectionId` (vertical lanes) to the target lane\'s subsection id. A bare `Row`/`Column` index does NOT pick a lane and drops the block in the wrong one.\n\n## Inserting a New Block\n\nThere is no atomic create-in-cell tool, so use two waves:\n\n1. **Create** the block however you normally would, at a staging position next to the target cell, sized to a peer (e.g. `x: peer.x + peer.w + 40`, `y: peer.y`). Stage it near the target so a failed move leaves a visible orphan, not a hidden one.\n2. **Place** with *MoveBlockInAssistedLayout* using the returned `ItemId`, pairing the block\'s text/style edits (*EditTextArea* / *EditBlockStyle*) into the same wave. To insert *between* neighbors, target the later neighbor\'s cell with `ToolCollisionHandlingPreference: "createColumn"` (or `"createRow"` for vertical flows) and rewire the affected line with *EditLineEndpoint* in the same wave.\n\nIf *MoveBlockInAssistedLayout* returns `success: false`, an orphan remains at the staging coordinates — delete it (*DeleteItem*) before retrying.'};var Ucetc={type:"System",name:UcWa.EYq,isAvailable:a=>a.Kc.wSa(),Vj:Ucha.EG,description:"Canvas exploration scripting guidance. Use when discovering current blocks, lines, positions, classes, text, shape data, and linked data before deciding what to do.",Hr:new Set([UcDd.FHc]),content:"# Canvas Exploration Skill\n\nLoad CreateAndEditBlocksSkill for block-specific mutation details.\nLoad CreateAndEditLinesSkill for line-specific inspection and mutation details.\nLoad CanvasDataSkill when linked data, reference keys, collections, or formulas need deeper handling.\n\n## Scope\n\nThis skill is for discovery and selection, not mutation. Use it to answer questions like:\n- What is on the current page?\n- Which existing shapes match this label, class, region, color, or data field?\n- Which IDs should a later script edit?\n- Does useful data already exist in text areas, shape data, or linked data?\n\n## Setup\n\nThe run_script sandbox injects only `client`, `console`, and `sdk`. Derive `viewport` and `page` at the top of exploration scripts:\n\n```js\nconst viewport = new sdk.Viewport(client);\nconst page = viewport.getCurrentPage();\nif (!page) {\n  throw new Error('No active page');\n}\n```\n\nReturn JSON-serializable summaries and IDs. Do NOT return proxy objects such as blocks, lines, pages, or reference proxies.\n\n## Exploration Strategy\n\nAlways explore existing content before modifying it. Do not ask the user for information you can discover from the document.\n\nUse two phases:\n\n1. **Surface scan** — count blocks/lines, sample text, class names, bounding boxes, and whether data exists.\n2. **Focused probe** — inspect the relevant matching items and their data fields before choosing how to act.\n\nKeep both phases compact. Avoid dumping every field from every block unless the user explicitly asks for a full audit.\n\n## Surface Scan\n\n```js\nconst blocks = [...page.allBlocks.values()];\nconst lines = [...page.allLines.values()];\nconst selected = viewport.getSelectedItems();\nconst visibleRect = viewport.getVisibleRect();\n\nconst byClass = {};\nlet withReferenceKeys = 0;\nlet withShapeData = 0;\n\nfor (const block of blocks) {\n  const className = block.getClassName();\n  byClass[className] = (byClass[className] || 0) + 1;\n  if ([...block.referenceKeys].length > 0) withReferenceKeys++;\n  if ([...block.allShapeData].length > 0) withShapeData++;\n}\n\nconst samples = blocks.slice(0, 8).map((block) => {\n  const bb = block.getBoundingBox();\n  return {\n    id: block.id,\n    className: block.getClassName(),\n    text: (block.textAreas.get('Text') || block.textAreas.get('FrameTitle') || '').substring(0, 80),\n    boundingBox: { x: Math.round(bb.x), y: Math.round(bb.y), w: Math.round(bb.w), h: Math.round(bb.h) },\n    hasReferenceKeys: [...block.referenceKeys].length > 0,\n    hasShapeData: [...block.allShapeData].length > 0,\n  };\n});\n\nreturn JSON.stringify({\n  blockCount: blocks.length,\n  lineCount: lines.length,\n  selectedCount: selected.length,\n  visibleRect,\n  byClass,\n  withReferenceKeys,\n  withShapeData,\n  samples,\n});\n```\n\n## Search Patterns\n\n### By exact or partial text\n\n```js\nconst needle = 'Flight';\nconst matches = [...page.allBlocks.values()].filter((block) => {\n  const text = block.textAreas.get('Text') || block.textAreas.get('FrameTitle') || '';\n  return text.includes(needle);\n});\n\nreturn JSON.stringify(matches.map((block) => ({\n  id: block.id,\n  className: block.getClassName(),\n  text: block.textAreas.get('Text') || block.textAreas.get('FrameTitle') || '',\n  boundingBox: block.getBoundingBox(),\n})));\n```\n\nMultiline text is stored with `\\n`, so substring searches can match text like `\"Weather\\nOK?\"`.\n\n### By class name\n\n```js\nconst matches = [...page.allBlocks.values()].filter((block) =>\n  block.getClassName() === 'DecisionBlock'\n);\nreturn JSON.stringify(matches.map((block) => ({ id: block.id, text: block.textAreas.get('Text') || '' })));\n```\n\n### By bounding region\n\n```js\nconst region = { x: 0, y: 0, w: 1000, h: 800 };\nconst matches = [...page.allBlocks.values()].filter((block) => {\n  const bb = block.getBoundingBox();\n  return bb.x < region.x + region.w &&\n    bb.x + bb.w > region.x &&\n    bb.y < region.y + region.h &&\n    bb.y + bb.h > region.y;\n});\n\nreturn JSON.stringify(matches.map((block) => ({ id: block.id, boundingBox: block.getBoundingBox() })));\n```\n\n### By fill color\n\n```js\nconst matches = [...page.allBlocks.values()].filter((block) =>\n  (block.properties.get('FillColor') || '').startsWith('#d0021b')\n);\nreturn JSON.stringify(matches.map((block) => ({ id: block.id, fillColor: block.properties.get('FillColor') })));\n```\n\nUse `startsWith` for colors because values often read back with an alpha suffix, such as `#d0021bff`.\n\n## Data Sources To Check\n\nCheck all relevant data sources before deciding how to act:\n\n1. **Text areas** — visible block text, frame titles, and line labels.\n2. **Shape-specific fields** — some shapes render text-like content from named properties, generated fields, or schema-backed values rather than the common `Text` area. If common text areas are empty or do not match what is visible, call `shape_details` for the placed block and inspect `TextAreaDescriptors` plus `ShapeSchemaProperties` / `currentValue`.\n3. **Shape data** — direct and inherited key-value data attached to blocks.\n4. **Reference keys / linked data** — collection-backed fields linked to a block; read values with formulas or by resolving the reference key.\n\n### Focused data probe\n\n```js\nconst block = [...page.allBlocks.values()].find((candidate) =>\n  [...candidate.referenceKeys].length > 0 || [...candidate.allShapeData].length > 0\n);\n\nif (!block) {\n  return JSON.stringify({ found: false });\n}\n\nconst shapeData = {};\nfor (const [key, value] of block.allShapeData) {\n  shapeData[key] = value;\n}\n\nconst references = {};\nfor (const [key, ref] of block.referenceKeys) {\n  try {\n    const item = ref.getItem();\n    const fields = {};\n    for (const fieldName of item.collection.getFields()) {\n      fields[fieldName] = item.fields.get(fieldName);\n    }\n    references[key] = fields;\n  } catch (e) {\n    references[key] = { primaryKey: ref.primaryKey };\n  }\n}\n\nreturn JSON.stringify({\n  id: block.id,\n  className: block.getClassName(),\n  text: block.textAreas.get('Text') || block.textAreas.get('FrameTitle') || '',\n  shapeData,\n  references,\n});\n```\n\n## Compact Snapshot Pattern\n\nUse snapshots to understand or verify a page without returning proxy objects.\n\n```js\nconst snapshot = { blocks: [], lines: [] };\n\nfor (const [id, block] of page.allBlocks) {\n  const bb = block.getBoundingBox();\n  snapshot.blocks.push({\n    id,\n    className: block.getClassName(),\n    text: block.textAreas.get('Text') || block.textAreas.get('FrameTitle') || '',\n    boundingBox: { x: Math.round(bb.x), y: Math.round(bb.y), w: Math.round(bb.w), h: Math.round(bb.h) },\n    hasReferenceKeys: [...block.referenceKeys].length > 0,\n    hasShapeData: [...block.allShapeData].length > 0,\n    connectedLineCount: block.getConnectedLines().length,\n  });\n}\n\nfor (const [id, line] of page.allLines) {\n  const ep1 = line.getEndpoint1();\n  const ep2 = line.getEndpoint2();\n  const textAreas = {};\n  for (const [name, text] of line.textAreas) {\n    textAreas[name] = text;\n  }\n\n  snapshot.lines.push({\n    id,\n    shape: line.getShape(),\n    textAreas,\n    endpoint1: {\n      connectionId: ep1.connection ? ep1.connection.id : null,\n      linkX: ep1.linkX,\n      linkY: ep1.linkY,\n      x: Math.round(ep1.x),\n      y: Math.round(ep1.y),\n    },\n    endpoint2: {\n      connectionId: ep2.connection ? ep2.connection.id : null,\n      linkX: ep2.linkX,\n      linkY: ep2.linkY,\n      x: Math.round(ep2.x),\n      y: Math.round(ep2.y),\n    },\n  });\n}\n\nreturn JSON.stringify(snapshot);\n```\n\n## Exploration Tips\n\n- Check all relevant blocks, not only the ones you expect to modify. Frames, containers, labels, and background blocks may carry context.\n- Use selected items and the visible rect to scope searches when the user refers to \"this\" or \"the selected area.\"\n- Return `item.id` for selected items in summaries so later scripts can retrieve exact items by ID.\n- Sort spatial results yourself when order matters; iteration order is not guaranteed to match canvas position.\n- Return IDs and compact summaries so later scripts can retrieve exact items with `page.allBlocks.get(id)` or `page.allLines.get(id)`.\n- If a search finds no obvious target, broaden the search once before asking the user for clarification."};var Ucftc={type:"System",name:UcWa.CYq,isAvailable:a=>!a.Kc.wSa(),Vj:Ucha.wf,description:"The prerequisite for ANY canvas mutation — direct edits, diagram generation, imports. Grants editing tools and guidance for making canvas edits.",Hr:new Set([UcDd.i5c,UcDd.Tyd,UcDd.j4c,UcDd.zAb,UcDd.O1,UcDd.S$d,UcDd.Uyd,UcDd.yia,UcDd.dIc,UcDd.wwa,UcDd.Lk,UcDd.HS,UcDd.Byd,UcDd.I2c,UcDd.Dyd,UcDd.Eyd,UcDd.K2c,UcDd.B3c,UcDd.k4c,UcDd.Kmc,UcDd.Sbe]),content:'# Canvas Editing Skill\n\nThere are a few VERY IMPORTANT things to keep in mind when working on the canvas in general.  Along with following these instructions below EXTREMELY CAREFULLY AT ALL TIMES, you also ABSOLUTELY MUST include a Full Document Read in your first wave after invoking this skill.  A full document read is using either the CanvasQuery or FilterCanvas tool (whichever you have access to) with the parameters needed to include everything - properties and shapes, and set parseSelectionOnly to false.  For CanvasQuery, this looks like: CanvasQuery(includeAllProperties: true, parseSelectionOnly: false).\n\n## Generating Diagrams\n\n**You are NOT PERIMTTED to create diagrams with this information alone**.  You must find another tool/skill that informs you how to create new diagrams.  THIS IS A HARD RULE - YOU MAY **NEVER** MAKE DIAGRAMS AFTER LOADING ONLY THIS SKILL!\n\n## Think Aloud Often\n\nThe *ThinkAloud* tool is a reasoning aid — a notepad you can use throughout the task to think things through.  You should reach for it often, not just at the start of a task.\n\nGood uses of ThinkAloud include:\n- **Reasoning about task steps** — breaking the user\'s request into concrete tool calls, noting the affected item IDs, and identifying which calls depend on the output of others.  The output of this thinking should be assembled into the Task List.\n- **Surveying available skills and tools** — making observations about which skills or tools might help with the task before committing to an approach.\n- **Noting what information you still need** — writing down what you have versus what you still need to read from the lymtex or discover via ShapeDetails before you can act.\n- **Working through errors or unexpected results** — diagnosing a no-op or failure and adjusting the remaining plan before retrying.\n\nThinkAloud calls can sit alongside edit tools in the same wave, so there is rarely a reason not to use one when you\'d benefit from thinking out loud.  Not every wave needs a ThinkAloud, but they should be a regular part of how you work through canvas edits.\n\n## Read and Understand\n\nThere are many kinds of shapes, and each shape class has its own properties, text area names, and advanced properties. It is ABSOLUTELY CRITICAL that you lean HEAVILY on the canvas read tool and the ShapeDetails tool in order to gain a correct understanding of what the shapes look like and how to work with them.  When you are stuck and think you are not able to complete a given edit operation, READ THOROUGHLY through the ShapeDetails for that shape class before telling the user that you cannot do something.\n\n## Skills and Canvas Editing\n\nWhen editing the document, you may need to invoke a number of skills.  This skill includes all the tools you will need, but there are other skills that you should strongly consider using in different scenarios:\n\n- When the requested change requires any more planning or work than a simple "Make this shape larger"-type change, load the wave-planning skill listed in your Available Skills\n- When working with containers that have **Assisted Layout** enabled — children arranged in a grid of rows/columns (a block\'s lymtex shows a `row`/`column` field, or a container shows `"assistedLayoutEnabled": true`) — load the AssistedLayoutSkill to move, place, or insert blocks within those grids\n- When the requested change involves working with the layout of a diagram (creating, modifying, cleaning up), load any applicable diagram layout skill (e.g. FlowChartDiagramLayoutSkill, ErdDiagramLayoutSkill)\n- When the requested change involves working with dynamic tables, Kanban boards, sprint boards, or any table-like grid layout, use the DynamicTables skill\n- When the requested change involves working with timelines, roadmaps, Gantt charts, or schedules, use the LucidTimelines skill\n\n## Following Existing Patterns\n\nUsers feel strongly about the existing styles, patterns, and conventions already on their documents. The quality of your work on this document is often correlated 1:1 with how much your edits _feel_ like something the user would have done. This means you MUST be very careful to both notice and follow the things the user has already done on the document.\n\nWhen the user has NOT specified exact colors or fonts for new or restyled content, use the *GetDocumentTheme* tool to read the document\'s active theme so your edits match the document\'s established palette and fonts. See the GetDocumentTheme guidance below for details.\n\nFor each of the following classes of patterns and conventions, you MUST begin your task by using the think_aloud tool as a notepad for observing what the current state of the document is. This will help you follow these patterns as you make your edits to the document.\n\n1. Colors and Shape Classes\n\n    The user will often use certain colors or shapes to communicate information on their document. Examples of this include ERD tables color-coded by what database they live in, AWS infrastructure shapes in architecture diagrams to indicate the resource is not home-rolled, or making all steps in a decision flow that relate to money green.\n\n2. Visual Styles\n\n    Not all documents are technical diagrams. Documents may also serve as presentation boards, meeting agendas, etc. In these cases, visual style becomes more of a _branding_ focus rather than an information communication focus. The user will ABSOLUTELY want your edits to mesh with their established style. This includes, but is not limited to:\n    - Colors of frames, sticky notes, text, etc\n    - Border radiuses\n    - Text fonts, sizes, and placements\n\n3. Document Themes\n\n    Some documents have an active theme applied to them. This theme controls the default colors and fonts for the document, and is often carefully chosen by the user to set the mood or tone of the document. You can determine the theme of a document by using the GetDocumentTheme tool.\n    - Use the theme to determine colors that would match the aesthetic of the document when the document is mostly blank and color choices cannot be inferred from existing content.\n\n## Maintaining the Task List\n\nAs you edit diagrams, you MUST use the task list to detail the steps you need to take to accomplish the user\'s request.  You should NOT start your task until the task list is built out with incremental steps, and you are NOT done with your task until the task list is completed and cleared.\n\n## Forward Momentum\n\nThe quality of your work will QUICKLY degrade if your responses (Waves) do not include at least a few tool calls per wave. Waves that only have ThinkAloud, TaskList, or ShapeDetails tool calls sometimes are required, but should be avoided **WHENEVER POSSIBLE**.  You are to follow the guidance in the Wave Planning Skill EXTREMELY CLOSELY when working on the canvas as a matter of necessity!  You are prone to fall into the pattern of many waves, each with one or two tool calls; AVOID THIS AGGRESSIVELY.\n\n## Shape Spacing\n\nFor most diagrams and other document use cases, shapes need space around them to be readable and clean.  As a default, you should **ALWAYS** make sure each shape has at least 100px of space around it.  When adding or moving shapes, you should ALWAYS follow this rule unless there\'s a contextual exception.\n\n# Error Handling and Retry\n\n## When a tool call fails:\n\n1. **Read the error message carefully** — error messages include specific information about what went wrong\n2. **Diagnose the problem** — understand why the operation failed\n3. **Attempt to fix it** — adjust parameters and try again\n4. **Keep trying** — continue until the operation succeeds or you have exhausted reasonable approaches\n5. **Explain failures** — if you cannot complete the operation after reasonable attempts, explain the issue to the user\n\n## Common Errors and Solutions\n\n- **"Item not found"** — double-check the item ID against the Lymtex context\n- **"Items not contiguous"** — the *WrapInContainer* tool requires all items to be connected via lines\n- **EditTextArea returned a no-op or "text area not found"** — the TextAreaName is wrong. For connectors/lines, the canonical label text area is `t0` (the `label` field in the lymtex maps to `t0`). For blocks, do NOT guess — call ShapeDetails with the block\'s class to enumerate its real text area names.\n\n## Shape Contents\n\nWith few exceptions, shapes within diagrams (like Process shapes and other small node shapes) should only have a few words of text max.  Anything more than ~6 words should be rare.\n\n# Tool Usage Guidelines\n\n- **CreateBlock** — geometry only: `blockClass`, `library`, `x`, `y`, `width`, `height`. Do NOT set text or style here; use *EditTextArea* / *EditBlockStyle* in the follow-up. **Critical**: Before adding any shape to the document for the first time in this conversation, you MUST call **ShapeDetails** with that shape\'s `toolboxId` to learn its properties and text areas. Batch all toolboxIds you intend to add into a single ShapeDetails call.\n- **CreateLine** — geometry only: endpoints attached to block IDs. Use *EditLineStyle* / *EditLineEndpoint* for arrows and styling. Use this whether the user says "draw a line", "add a connector", or "connect two shapes".\n- **EditTextArea** — set text on one text area of one block or line. Required for every new block (class-name defaults like "Process" or "Terminator" are NOT labels). For a line/connector label, the text area name is `t0`.\n- **EditBlockStyle** — colors, fill, stroke, font on one block.\n- **EditLineStyle** — colors, stroke, dash on one line.\n- **EditLineEndpoint** — reattach or restyle (Arrow/None) one endpoint of one line.\n  - When the user asks to change endpoint style without specifying which end, **do not ask for clarification** — check the Lymtex to see which endpoints currently have a non-None `Style` and update only those.\n- **MoveBlock** — move one block on the free canvas: absolute X/Y, plus optional rotation and z-order. It has NO placement/row/column parameter and CANNOT put a block into an assisted-layout grid cell — load the AssistedLayoutSkill for grid placement.\n  - When moving items, assume the user wants to rearrange both the layout and the flow of the diagram. Preserve or update connections based on the new position. The diagram should have no new dangling/orphaned nodes or connections after the move — fix up lines with *EditLineEndpoint* in the same wave when needed.\n- **ResizeBlock** — resize one block.\n- **SetBlockShapeProperty** — set one shape-specific property (non-text, non-style) on one block.\n- **EditBlockCardData** — set one card-data field on one block.\n\n## GetDocumentTheme\n- Returns the document\'s currently active theme (palette, font family, other styling). Takes no parameters.\n- Call this **before** creating new shapes, text, or diagrams, or restyling existing content to "match the document", when the user did **not** specify exact colors, fonts, or styling. New content should match the document\'s visual style.\n- The theme exists even on an empty canvas, so an empty document is NOT a reason to skip the call.\n- Call **at most once per turn** — the theme does not change mid-turn.\n- **Skip** the call when the user has given concrete styling instructions ("make these red", "use Comic Sans") — honor the user\'s instruction directly.\n- **Applying the theme**: use the returned palette for fills, borders, and accents (prefer primary/accent colors for emphasis, neutral/background colors for surfaces) and the returned font family for new text. When adding multiple shapes, apply the theme consistently across the batch rather than mixing theme colors with off-theme defaults. If no theme or an unrecognized shape is returned, fall back to canvas defaults rather than blocking on the user.\n\n## Validation\n- Call this **once per turn**, in your **second-to-last wave** (the wave before `message_user`), scoped to the IDs of items you created or modified this turn — not a full canvas scan\n- Do **not** call this in early or mid-task waves — intermediate states are expected to be imperfect\n- Automatically fix any reported issues that are not intentional — do not ask the user\n- If an issue persists after **one fix attempt**, inform the user via `message_user` and proceed — do **not** call `validate_canvas` again\n\n**Fix strategies by issue type:**\n- **Line passes through block**: move the block using `MoveBlock` or change the line endpoint using `EditLineEndpoint` first; if needed, reroute using `RerouteLines` per its rules below\n- **Block overlap**: move one of the blocks using `MoveBlock`\n- **Disconnected endpoint**: reconnect the line using `EditLineEndpoint`\n- **Text overflow**: resize the block using `ResizeBlock`\n- **Low text contrast**: use `EditTextArea` to set a darker/lighter text color, or use `EditBlockStyle` to adjust the fill color\n- **Inefficient routing**: call `RerouteLines` on affected lines per its rules below — if the issue persists after rerouting, inform the user and proceed\n- **Orphaned blocks**: Only treat as an issue in flowchart-style diagrams where every block is expected to be connected (e.g. process flows, org charts, state machines). In all other diagram types, orphaned blocks are intentional — do NOT add lines to blocks solely because they appear orphaned.\n\n## RerouteLines\n- Call when existing lines have inefficient routing — taking unnecessarily long paths, too many direction changes, or entering/exiting blocks from the wrong side\n- **Only adjusts the visual path of existing lines** — does not add new lines and does NOT change which blocks a line connects (sourceId/targetId); use *EditLineEndpoint* to rewire connections\n- Use `RerouteLines` only for lines that are already elbow or intentionally orthogonal\n- If a specific non-elbow line needs orthogonal rerouting, first use `EditLineStyle` to set `LineShape` to elbow for that line, then reroute it\n- Preserve intentionally straight/diagonal lines (for example, fishbone ribs); do not convert those lines to elbow only to reroute\n- Set `LineIds` to only the affected lines rather than rerouting the entire diagram\n- Use `CanvasQuery` first to retrieve all block IDs if not already known\n- If the result includes non-elbow lines skipped, **notify the user** and suggest setting those specific lines to elbow before rerouting when orthogonal routing is intended\n- If the result includes cyclical lines that were skipped, **notify the user** — a cyclical line is a **bidirectional connection**; to replace it: use `EditLineEndpoint` to change the original cyclical line\'s shape to elbow (keeping its A→B direction), then use `CreateLine` to add a new line in the opposite direction (B→A); suggest this especially if the cyclical line visually overlaps other blocks\n\n## ShapeLibrary\n- **Critical**: When the user asks for a specific shape type (e.g., "Amazon Managed Blockchain", "EC2 instance", "Lambda function"), you MUST use ShapeLibrary to find the correct BlockClass — do NOT guess or use generic shapes like ProcessBlock\n- Use the shape\'s `toolboxId` as the `blockClass` in CreateBlock\n\n## ShapeDetails\n- **Critical**: Before adding a shape to the document for the first time, you MUST use ShapeDetails with that shape\'s `toolboxId` to understand what properties and text areas it has.  This is essential for you to be able to use CreateBlock effectively and set the shape\'s text and properties via the sub-tools.\n- Use the shape\'s `toolboxId` as the `blockClass` in CreateBlock\n- Call this tool after finding shapes you want to add with ShapeLibrary\n\n## MessageUser\n- Communicate with the user about **progress or issues**\n- Use after completing edits to **summarize what was done**\n\n## CanvasQuery\n- You are NOT to use this tool in the middle of your execution of a plan unless it is absolutely VITAL.  You should ALMOST NEVER need to use this once you have the information you need up front.\n- `IncludeAllProperties: true` is the most verbose but works well when you cannot find something with filters\n- It is entirely possible that other collaborators/users are changing the document as you work.  If tool calls fail, using this tool to pull small targeted Lymtex outputs is a helpful way to make sure you know what is happening.\n- **Re-query** if the user is not satisfied with your edits and you suspect a tool did not execute as intended\n- Block IDs **cannot change** — you never need to re-query just for that'};var Ucgtc={type:"System",name:UcWa.DYq,isAvailable:a=>a.Kc.wSa(),Vj:Ucha.wf,description:"The prerequisite for ANY canvas mutation — direct edits, diagram generation, imports. Grants editing tools and guidance for making canvas edits.",Hr:new Set([UcDd.i5c,UcDd.Tyd,UcDd.j4c,UcDd.S$d,UcDd.Uyd,UcDd.yia,UcDd.wwa,UcDd.Byd,UcDd.Lk,UcDd.Kmc,UcDd.Sbe,UcDd.FHc]),content:"# Canvas Editing Skill\n\n## Core Requirements\n\n- This skill enables canvas editing, but it does **not** replace specialized scripting skills.\n- In the first wave after loading this skill, perform required discovery unless the current context already contains enough exact IDs, classes, text areas, positions, and properties to safely act.\n- When creating new visual content and the user did not specify styling, call `get_document_theme` once and match the document palette/font.\n- For requests scoped to the selected or current item, use the latest selection context from the user message. Re-query the selection only when that context is missing, ambiguous, or lacks fields needed for the edit.\n\n## Efficient Editing Workflow\n\n- Discover: read canvas context, theme, shape classes, text areas, and relevant IDs.\n- Decide: choose `run_script` for repetitive/scriptable work; choose individual tools for small or tool-specific edits.\n- Load scripting skills before scripting.\n- Execute: batch independent operations where safe.\n- Validate: call `validate_canvas` once near the end, scoped to created or modified items, only after the mutation tool succeeded or returned IDs for items that were actually changed.\n- Repair: fix non-intentional validation issues once when practical.\n- Report: briefly summarize what changed, without exposing internal IDs.\n\n## Shape Details Hard Gate\n\n- Before creating, editing, styling, resizing, or changing text/properties on any block or shape, call `shape_details` for every involved shape class or placed block.\n- This applies to both individual editing tools and `run_script`.\n- A known class name, existing similar shape, visible label, previous canvas summary, or AWS service name is not enough.\n- Do not guess text area names, shape properties, default sizes, default colors, or whether a shape can be created with `run_script`.\n\n## RunScript Hard Gate\n\n- Before calling `run_script`, load every directly relevant scripting skill that the planned script depends on.\n- When you can tell the task will need several scripting skills, load all of them in the same response instead of loading them one at a time.\n- Do **not** call `run_script` for block, text, layout, line, data, or viewport work unless the corresponding scripting skill is already loaded.\n- If the need for scripting becomes clear only after this skill is loaded, pause and load the relevant scripting skills before writing the script.\n\nRelevant scripting skills:\n\n- `create_and_edit_blocks_skill`: creating, finding, resizing, styling, moving, or deleting blocks.\n- `edit_text_areas_skill`: reading, writing, styling, measuring, or positioning block/line text.\n- `create_and_edit_lines_skill`: creating or editing lines, endpoints, routing, arrowheads, labels, style, or deletion.\n- `canvas_exploration_skill`: inspecting current canvas items, IDs, classes, text, positions, linked data, or structure.\n- `canvas_data_skill`: shape data, reference keys, data sources, collections, data items, formulas, or linked data.\n- `canvas_viewport_skill`: viewport, camera, or selection behavior.\n- `validate_canvas_skill`: scripted visual quality checks, including overlap, spacing, dangling lines, line-through-block, and text readability heuristics.\n\nAlso load these supporting skills when applicable:\n\n- When the requested change requires any more planning or work than a simple \"Make this shape larger\"-type change, load the wave-planning skill listed in your Available Skills.\n- When the requested change involves working with the layout of a diagram (creating, modifying, cleaning up), load any applicable diagram layout skill (e.g. FlowChartDiagramLayoutSkill, ErdDiagramLayoutSkill).\n\n## RunScript Preference for Canvas Edits\n\nPrefer 'run_script' when the work you are doing is clearly documented in skills. If working with a complex shape that requires editing properties, use which ever tool is appropriate for the task.\nAlso use 'run_script' when working with the content or style of text areas.  All text on the canvas should be worked with via the 'run_script' tool.\n\n**Exception — assisted layout.** `run_script` can see the blocks in an assisted-layout grid (e.g. swimlane lanes or a generated flowchart), but it cannot read a child's row/column or place a block into a cell: it has no access to that grid coordinate, so `addBlock`/`setBoundingBox` will silently land the block in the wrong cell. For any add, move, or reorder of a block inside such a container, do not use `run_script` — load `assisted_layout_skill`.\n\n### RunScript Best Practices On The Canvas\n\n1. Begin your script by listing out important IDs (lines, shapes, etc), and any high-level information that you are working towards.  A clean setup helps the rest of the script work well.\n2. Load and reference any applicable DiagramLayoutSkill(s) before writing your scripts.\n3. Lean on the strengths of code (e.g. using a loop to align blocks relative to eachother by using live block bounding box data rather than trying to manually define all X and Y positions).\n    - However, unless the diagram is very large, you should not walk through it with code to identify primary structures.  You should analyze this yourself by reading the document.\n4. Return as much diagnostic data as you could possibly use if the script fails.  Data returned from the script is extremely valuable for your ability to understand what happened.\n5. Utilize helper functions to make your job easier.\n6. Keep shape sizes in mind when working on your tasks.  Your scripts should regularly pull and utilize shape bounding box info to inform your actions.\n7. In most cases, your script should have TWO parts; the first part is where you define all the relevant IDs and then define the goal of your action as code (e.g. defining what nodes belong to certain branches in a map at the start of a script to fix the layout of a flowchart) - this includes the decision making at a high level.  The second section is written with a focus on the logistical steps to make that goal happen.\n8. Dynamic grids work better than static ones in most cases.  Static grids place blocks via 'x = colIndex * colWidth' calculations, while dynamic grids ensure gaps between shapes remain constant with calculations like 'x = prevBlock.x + prevBlock.width + gapBetweenBlocks'.\n\n## Script Failure Recovery\n\nA script can fail even with the right skills loaded. When `run_script` fails:\n\n- Read the error carefully before choosing a fallback.\n- Do not mark dependent tasks complete, run final validation as if the edit succeeded, or report completion until the mutation script returns success.\n- If the error mentions class loading, block creation, SDK object methods, text handling, layout helpers, or missing canvas APIs, load the relevant scripting skill and retry when the fix is clear.\n- For SDK parameter errors, check whether the script passed a proxy object where a string ID was expected, or an ID where the SDK expects a proxy.\n- Do not immediately fall back to many individual tool calls unless scripting is unsafe, unavailable, or still uncertain after loading the relevant skill.\n- If a script partially mutated the canvas, repair or clean up before reporting completion.\n\nCommon recovery examples:\n\n- Error about shape class loading or block creation → load `create_and_edit_blocks_skill`.\n- Error about labels, text areas, or text not appearing → load `edit_text_areas_skill`.\n- Error about line endpoints, arrowheads, routing, or labels → load `create_and_edit_lines_skill`.\n\n## Ambiguous Selection and Item Type\n\nWhen the user says \"this\", \"make this purple\", \"selected item\", or otherwise refers to the current selection, do not infer the item type from `getClassName()` alone. Selected items can be blocks, lines, groups, or container/generator items, and some selected lines do not expose `getClassName()`.\n\nClassify selected items by looking them up in the page collections with their string ID:\n\n```js\nconst selected = viewport.getSelectedItems();\nfor (const item of selected) {\n  const block = page.allBlocks.get(item.id);\n  const line = page.allLines.get(item.id);\n\n  if (block) {\n    block.properties.set('FillColor', '#c4b5fd');\n  } else if (line) {\n    line.properties.set('LineColor', '#7c3aed');\n  }\n}\n```\n\nIf the selected item is not found in `page.allBlocks` or `page.allLines`, inspect it before claiming the edit succeeded.\n\n## Shape Creation Rules\n\n- Use `shape_library` when the user requests a specific shape type or visual element and a shape that directly addresses that need.\n- DO NOT recreate a shape's visual or functional purpose with generic shapes unless shape_library does not return a suitable candidate, the shape cannot be created or edited with available tools, the requested customization is not supported by the real shape, or the user explicitly asks for a custom/manual approximation.\n- Use `shape_details` before creating a shape class for the first time in the conversation.\n- `create_block` is geometry-only: class, library, position, and size. Use text/style tools or scripting for labels and visual formatting.\n- With `run_script`, still respect discovered class names, valid text areas, default sizes, and theme styling.\n- Keep node labels short. For small diagram shapes, prefer a few words; avoid long paragraphs.\n\n## Text Editing Rules\n\n- Never guess block text area names.\n- For line labels, the canonical text area is usually `t0` when supported by the line.\n- If text edits no-op or fail, fetch shape details or inspect a similar existing item before retrying.\n\n## Layout and Spacing\n\n- Maintain at least 100px of readable spacing around new or moved shapes unless the diagram type or existing pattern clearly calls for tighter spacing.\n- When writing scripts for layout it is EXTREMELY IMPORTANT to calculate gaps between blocks based on the bounding boxes of the shapes themselves.\n- Follow existing document conventions for colors, shape classes, sizes, alignment, spacing, and labeling.\n- Assisted layout containers control child placement (a grid generator, not raw x/y, decides where each child sits — swimlanes and generated flowcharts are the common cases). Before moving or placing any of their children, load `assisted_layout_skill`.\n- When moving diagram nodes, preserve or update connections so the result does not create unintended dangling lines or orphaned nodes.\n- **Decision blocks are taller than process blocks** — use different height constants.\n\n## Validation\n\n- Load `validate_canvas_skill` and run a validation script near the end of the turn, scoped to created or modified items.\n- Include scripted checks relevant to the edit.\n- Fix unintentional validation issues when practical and re-run the same focused validation after a fix attempt.\n- Only report success for a validation check when the latest validation result is clean for the checked issue types.\n- If an issue persists after one reasonable fix attempt, tell the user what remains and what was completed.\n\n## Examples\n\n### Example: Repeated Shape Creation\n\nUser: “Add 8 circles labeled A through H.”\n\nPreferred workflow:\n\n- Load `canvas_editing_v2_skill`.\n- Also load `create_and_edit_blocks_skill` and `edit_text_areas_skill` before scripting.\n- Read the document and theme.\n- Use `shape_library` and `shape_details` if the circle class or text areas are unknown.\n- Use one `run_script` call to create the 8 circles in a loop, set labels, apply theme styling, and return created IDs.\n- Validate the created items once.\n\nAvoid creating 8 blocks and then issuing 8 separate text-edit calls unless scripting is unavailable, unsafe, or explicitly not desired.\nThere will be instances where you are required to create a single shape then call SetBlockShapeProperty to set a property on that shape. This is REQUIRED. Do not try to set properties other ways in an attempt to avoid a non-RunScript tool.\n\n### Example: Small One-Off Edit\n\nUser: “Make this one circle larger.”\n\nPreferred workflow:\n\n- Use the selected/current item if the reference is clear.\n- Use `run_script` with `create_and_edit_blocks_skill` loaded.\n- Validate if the resize could cause overlap or text overflow.\n\nDo not write a script for a single simple resize unless the user explicitly asks for scripting.\n\n## How to use the runscript tool with frames (containers) and groups to organize blocks on the canvas.\n\n### Finding Space\n\n#### `viewport.findAvailableSpace(width, height)`\n\nReturns `{ page, x, y }` — a position on the current page where content of the given size won't overlap existing blocks.\n\n```js\nconst space = viewport.findAvailableSpace(800, 600);\nconst baseX = Math.round(space.x);\nconst baseY = Math.round(space.y);\n```\n\n**Behavior:**\n- Returns fractional coordinates — always round to integers\n- Idempotent: repeated calls return the same position (doesn't \"consume\" space)\n- For large requests (e.g. 5000x3000), returns coordinates far from existing content\n\n#### `page.findAvailableSpace(searchX, searchY, width, height)`\n\nSame but searches near a specific starting point. Useful for placing multiple items near a region.\n\n#### Container Membership\n\nBlocks spatially inside a frame are automatically contained by it. There is no explicit `addToContainer()` API — containment is determined by position.\n\n```js\nconst containers = block.getContainers();\n// Returns BlockProxy[] of all frames containing this block\n```\n\n**Key behaviors:**\n- Moving a block INTO a frame's bounds automatically makes it a member\n- Moving a block OUT of a frame removes it from that container\n- Containment is checked from the child side only — frames have no `getContainedItems()` method\n\n**To find all blocks in a frame:**\n\n```js\nconst containedBlocks = allBlocks.filter(b => {\n  if (b.id === frame.id) return false;\n  return b.getContainers().some(c => c.id === frame.id);\n});\n```\n\n#### Moving Frames\n\nMoving a frame moves all contained children with it:\n\n```js\nconst bb = frame.getBoundingBox();\nframe.setBoundingBox({ x: bb.x + 200, y: bb.y + 100, w: bb.w, h: bb.h });\n// All contained blocks shift by +200, +100\n```\n\n**Partial containment caveat:** If a block's bounding box extends outside the frame, it may NOT move with the frame. Ensure blocks are fully within the frame bounds.\n\n#### Nested Frames\n\nFrames can be nested. A block inside an inner frame reports BOTH the inner and outer frames as containers:\n\n```js\nblock.getContainers(); // [innerFrame, outerFrame] — both returned\ninnerFrame.getContainers(); // [outerFrame] — frames can also have containers\n```\n\n#### Position Parents Before Children\n\nMoving or resizing a frame shifts all contained blocks by the same delta. This means:\n\n- If you position blocks inside a frame, then resize/move the frame, the blocks move again and end up in the wrong place.\n- **Always finalize the frame's position and size FIRST, then position the blocks inside it.**\n- If you need to resize a parent frame to fit its children, compute the needed size, set the frame's bounding box, then position the children relative to the frame's final position.\n\nFor nested frames (theme frames inside a parent frame): set the parent frame first, then the child frames, then the blocks inside them — outermost to innermost.\n\nBe careful to think through the sequence of moves. For example, if you move Frame A to where Frame B currently is, then move some shapes into Frame A, then move Frame B to some empty space, the shapes you moved into Frame A may end up moving with Frame B. Move all frames first, then move the blocks. The moves can be done in a single script run, but the order within the script matters.\n\n#### Nested Frames Pattern\n\n```js\nconst mainFrame = page.addBlock({\n  className: 'DefaultFrameBlock',\n  boundingBox: { x: baseX, y: baseY, w: 1100, h: 700 },\n});\nmainFrame.textAreas.set('FrameTitle', 'System Dashboard');\n\nconst subsFrame = page.addBlock({\n  className: 'DefaultFrameBlock',\n  boundingBox: { x: baseX + 20, y: baseY + 50, w: 520, h: 280 },\n});\nsubsFrame.textAreas.set('FrameTitle', 'Flight Operations');\n```\n\n**Frame title takes ~40-45 units ABOVE the bounding box at the default size.** Place the frame accordingly.\n\n**Compute frame size from contents:** `frameW = cols * blockW + (cols-1) * gap + 2 * padding`\n\nLoad CanvasViewportSkill for camera focus, visible area, and selection state.\n\n### Groups\n\nGroups bundle blocks together for collective operations.\n\n```js\nconst group = page.groupBlocks([block1, block2]);\n```\n\n#### Reading Group Members\n\n```js\n// Direct members\nconst blocks = [...group.blocks.values()];\nconst lines = [...group.lines.values()];\nconst subgroups = [...group.groups.values()];\n\n// All members (including nested)\nconst allBlocks = [...group.allBlocks.values()];\nconst allLines = [...group.allLines.values()];\nconst allGroups = [...group.allGroups.values()];\n```\n\n#### Group Properties\n\n```js\ngroup.getBoundingBox(); // Bounding box of all members\ngroup.setBoundingBox({ ... }); // Move/resize the group\ngroup.getContainers(); // Containers the group is in\ngroup.id; // Unique ID\ngroup.delete(); // ⚠️ DELETES ALL member blocks, lines, and nested groups\n```\n\n#### Moving Groups\n\nMoving a group (via `setBoundingBox`) moves all member blocks:\n\n```js\nconst bb = group.getBoundingBox();\ngroup.setBoundingBox({ x: bb.x + 100, y: bb.y, w: bb.w, h: bb.h });\n```\n\n#### Iterating Page Groups\n\n```js\nfor (const [id, group] of page.allGroups) { ... }\nconst groups = [...page.allGroups.values()];\n```\n\n#### Group Deletion Is Destructive\n\n**`group.delete()` deletes ALL member blocks, lines, and nested groups.** There is no `ungroup()` API. If you need to dissolve a group without destroying its members, you cannot do so through the current SDK.\n\n#### Groups vs Frames\n\n| Feature | Frame | Group |\n|---|---|---|\n| Created with | `page.addBlock({ className: 'DefaultFrameBlock' })` | `page.groupBlocks([...])` |\n| Membership | Automatic by position | Explicit at creation |\n| Title/label | `FrameTitle` text area | None |\n| Visible on canvas | Yes (border + title) | No visible boundary |\n| Moving | Moves contained children | Moves member blocks |\n| Deletion | Deletes the frame only (children survive) | **Deletes all members** |\n| Nesting | Frames can nest; `getContainers()` returns all ancestors | Has `groups` for sub-groups |\n| Can add members later | Yes — move blocks into bounds | No known API |\n| Iterable from page | Via `page.allBlocks` (it's a block) | Via `page.allGroups` |\n\n### Text Sizing and Overflow\n\n**Critical gotcha:** `ProcessBlock` (and most standard blocks) will **never auto-resize** to fit text. Text that doesn't fit simply renders outside the block's bounds, overlapping other content. You must size blocks to fit their text.\n\n#### `measureText()`\n\nThe SDK provides `block.measureText(textAreaName, maxWidth)` which returns `{ w, h }` — the exact pixel dimensions needed to render the text at the current style settings.\n\n```js\nblock.textAreas.set('Text', 'Emergency Beacon');\nblock.textStyles.set('Text', { size: 12, bold: true });\n\nconst size = block.measureText('Text', 300);\n// { w: 251.46, h: 25.83 } — needs ~252px wide for a single line\n\nconst wrapped = block.measureText('Text', 150);\n// { w: 147.23, h: 64.55 } — wraps to 2 lines at 150px max width\n```\n\n**How it works:**\n- Pass a `maxWidth` to constrain the text. If the text fits in one line within that width, you get a single-line measurement. If not, it wraps and returns the multi-line dimensions.\n- If a single word is wider than `maxWidth`, the returned width will exceed `maxWidth` (it won't break mid-word).\n- Returns the **text dimensions only** — you need to add padding for the block border/margin.\n\n#### Recommended Sizing Pattern\n\n```js\n// 1. Create the block at a temporary size\nconst block = page.addBlock({\n  className: 'ProcessBlock',\n  boundingBox: { x, y, w: 200, h: 50 },  // temporary\n});\nblock.textAreas.set('Text', label);\nblock.textStyles.set('Text', { size: 12, bold: true });\n\n// 2. Measure the text\nconst textSize = block.measureText('Text', 300);  // generous maxWidth for single-line\n\n// 3. Resize to fit (add padding)\nconst padX = 24;  // horizontal padding (12 each side)\nconst padY = 16;  // vertical padding (8 top + 8 bottom)\nblock.setBoundingBox({\n  x, y,\n  w: Math.ceil(textSize.w) + padX,\n  h: Math.ceil(textSize.h) + padY,\n});\n```\n\n#### Uniform Sizing for a Group of Blocks\n\nWhen building a grid or flowchart, measure all labels first, then size every block to the largest:\n\n```js\nlet maxW = 0;\nlet maxH = 0;\nfor (const block of blocks) {\n  const size = block.measureText('Text', 300);\n  maxW = Math.max(maxW, size.w);\n  maxH = Math.max(maxH, size.h);\n}\n\nconst blockW = Math.ceil(maxW) + 24;\nconst blockH = Math.ceil(maxH) + 16;\nfor (const block of blocks) {\n  const bb = block.getBoundingBox();\n  block.setBoundingBox({ x: bb.x, y: bb.y, w: blockW, h: blockH });\n}\n```\n\n#### Practical Advice\n\n- **Always use `measureText()`** rather than guessing dimensions. Text overflow looks broken; a slightly oversized block looks fine.\n- **Prefer single-line text.** Two-line text doubles the height and creates wrapping ambiguity.\n- **Bold text is ~3-5% wider** than regular at the same size.\n- **When combining name + status**, put status in the fill color (heatmap) rather than in the text.\n- **Add at least 24px horizontal and 16px vertical padding** to `measureText` results.\n"};var Uchtc={type:"System",name:UcWa.OJ,Vj:Ucha.wf,description:"Create and edit conditional formatting rules. Load this skill when the user wants to change shape colors, borders, or text based on conditions. Eagerly load when the user wants to change shapes of a certain type, shapes that say specific things, etc.",Hr:new Set([UcDd.ayd,UcDd.Cyd]),content:'## Skill: Conditional Formatting\n\nYou have two tools for conditional formatting:\n- **CreateConditionalFormatting** — add a brand-new rule to the canvas.\n- **EditConditionalFormatting** — modify an existing rule by ID.\n\n### Choosing which tool to call\n- If the user is referring to a rule that was already created earlier in this conversation (e.g. "make that rule blue instead", "rename the priority rule"), call **EditConditionalFormatting** and pull the rule\'s ID from conversation history. Never ask the user for a rule ID — they aren\'t aware that rules have IDs.\n- In all other cases — any request that introduces a new condition/effect pair — call **CreateConditionalFormatting**.\n- If the user wants several independent rules in one message, issue multiple **CreateConditionalFormatting** calls in parallel (one rule per call).\n- If the user asks you to **delete** a rule, tell them you can\'t — neither tool supports deletion.\n\n### IsComplex\nBoth tools take an IsComplex flag — getting it right on the first call avoids a wasted retry. See each tool\'s parameter docs for specifics.\n\n### Best practices for good rules\n- Prefer conditions grounded in canvas state the system can actually observe: shape text, shape data fields, shape type, connection counts, and container/frame membership. Steer the user away from conditions that require semantic understanding (e.g. "shapes that look important").\n- Encourage exact, unambiguous condition language. "Contains the text \'Priority\'" is a better command than "is a priority shape".\n- When the user asks for a styling change that doesn\'t depend on a condition (just "make these red"), confirm whether they actually want a rule. A direct style edit is usually the better fit and avoids cluttering the rule list.\n- For multi-effect requests with different conditions ("High → red, Low → green"), split into separate Create calls so each rule can be edited or removed independently later.\n- Give each rule a short, descriptive title (2-5 words) that names the *condition*, not the effect — titles outlive color choices.'};var Ucitc={type:"System",name:UcWa.Fir,Vj:Ucha.wf,description:"Load when working with ANY dynamic table — a plain table, a Kanban, sprint, status, task tracker, or a capacity view. Grants tools for creating and working with dynamic tables.",Hr:new Set([UcDd.r1e,UcDd.J_e,UcDd.H_e,UcDd.A2e]),content:"## Working with Lucid Dynamic Tables\n\nA Lucid dynamic table arranges blocks into a grid whose rows and columns are driven by a shared attribute of those blocks — a data field they carry or a visual property like color or tags. Any Lucid blocks can sit on one, but **Lucid cards** are the richest fit because they carry the fields (status, priority, sprint, estimate, assignee) that the most useful pivots read from, so prefer cards for scrum, agile, Kanban, and sprint work. Tables are useful for Kanban boards, sprint boards, status and task trackers, capacity views, or any time you want a body of blocks grouped by something they share. This skill grants the four dynamic-table tools below. The blocks a table holds, and the frame around it, are created with the **canvas_editing** tools, so that skill needs to be loaded too.\n\n### The dynamic table tools\n\n* **CreateDynamicTable** — creates a table on the current page and returns a `generatorId` you'll reference in the other tools. Create it *without* row/column labels when you intend to pivot on card data; pass labels directly only for a plain, non-pivoted table.\n* **AddItemsToDynamicTable** — places blocks already on the canvas onto a table (by `generatorId`). This also seeds the table's schema: a block's data fields (status, priority, sprint…) only become available as pivots once at least one block carrying them is on the table. Visual pivots don't depend on this.\n* **AddDynamicTableRowsColumns** — adds entries to a pivoted axis (the Status values, the sprints, etc.) so the axis renders as a real grid rather than a single row or column.\n* **EditDynamicTableMetadata** — sets or changes how the table pivots: `rowGroupByField` / `columnGroupByField`, capacity planning, and visual pivots. For any change to a table that already exists — re-pivoting, rescaling, turning on capacity planning — this is the tool; you don't recreate the table.\n\n### Building a grouped table\n\nFor a table grouped by data fields (\"grouped by status and priority\"), the order of work follows from one hard dependency: a data-field pivot has nothing to group on until cards carrying that field are on the table. So seed the table before you pivot — create it with `CreateDynamicTable` (no row/column labels, since you're pivoting on data, not fixed ones), make a starter set of cards and *vary* their field values so they spread across cells, place them on the table, and only then pivot and flesh out each axis. Fix the axis order if it reads wrong, then frame the result.\n\nDo this eagerly and end to end — a populated, pivoted grid is the goal, only deviate when the user explicitly asks for an empty table or names plain row/column labels, in which case `CreateDynamicTable` with those labels is the whole job.\n\n### Putting rows and columns in the right order\n\nA data-field pivot often comes back out of order (e.g. \"Done\" on the far left). Put each axis in its natural order — Status: To Do, In Progress, Done; Priority: Low, Medium, High; Sprint: 1, 2, 3 — with **SetBlockShapeProperty**: get each row/column `containerId` from **canvas_query**, then set `rowOrder` (top-to-bottom) or `columnOrder` (left-to-right) to those ids comma-separated, listing every entry on the axis exactly once.\n\n### Dynamic-table gotchas\n\n* **Why cards must be added before the pivot:** data-field pivots (assignee/user, status, priority, sprint, estimate, parent, reporter, team, project, issuetype) read off fields the blocks carry, and those fields only exist once a block carrying them is on the table — they can't be typed in by hand, and Lucid cards are what carry them. Pivoting before any card is placed has nothing to group on. Creating a card makes only the shell, so set the fields and vary the values across cards. (Visual pivots have no such requirement — see below.)\n* **A table pivots on at most two fields — one X-axis and one Y-axis.** There is no third dimension; drive the pivot through the two axes rather than inserting extra fields as plain rows or columns. When you need to ask which fields to pivot by, constrain the question to two named choices (\"rows by Status and columns by Priority, or swap one for Sprint?\") rather than an open list that invites more than the table can hold. If the user has already named more than two, pick the two strongest.\n* **Set both pivots in ONE `EditDynamicTableMetadata` call — one `rowGroupByField`, one `columnGroupByField`.** Never put the second field on the same axis as the first; assigning an axis again silently replaces what was there, so e.g. setting `rowGroupByField` twice ends up grouped by only the last one. The tool reports the actual resulting pivot on both axes — trust that read-back over your memory of what you sent, and don't tell the user it's grouped by a field the read-back doesn't confirm.\n* **Capacity planning and load tracking are the dynamic table's most distinctive affordance** — much like capacity planning is for a timeline. They show work loaded against a per-period capacity and are a core reason to choose a dynamic table over a static one. They're most meaningful when cards carry estimates and an axis is something like Sprint, and a poor fit for a pure categorization table with no workload field.\n* **Visual pivots (Fill Color, Line Color, Emojis, Tags) are always available, on any block, regardless of whether it carries card data.** This is what lets a table of plain blocks still pivot into a real grid. Reach for them when the blocks lack data fields like Status, or when the user wants to organize by something visual — the blocks re-sort automatically as you recolor or retag them.\n* **Assignee/User pivots use real people only.** Leave the assignee field unset rather than inventing names, and ask the user for real assignees instead of guessing.\n\n### Preferences\n\n* **A populated, pivoted table beats an empty grid.** When the user wants a table for some body of work, seeding it with blocks spread across the pivot shows what the structure is for; an empty 2×2 grid teaches nothing about why they'd use a dynamic table. For scrum, agile, Kanban, and sprint work, use Lucid cards and give them more than a bare title (a short description, a status, an estimate); for other groupings, plain blocks pivoted on a visual property work fine. Default each pivoted axis to a sensible starter set of values (Status → To Do / In Progress / Done; Priority → Low / Medium / High; Sprint → Sprint 1 / 2 / 3)\n* **We generally like a frame around a finished table.** Wrap it (pass the table's `generatorId` alone so it's framed as one unit) and give the frame a short, human-readable title. A table that already exists on the canvas may already be framed — don't double-frame it, and don't reframe when you're only re-pivoting or adding cards to an existing table."};var Ucjtc={type:"System",name:UcWa.wmr,description:"Information on how to add, resolve, and update on-canvas suggestions attached to specific shapes. Load when the user explicitly asks for your evaluation, feedback, suggestion, review, critique, or improvement ideas on canvas content, rather than making a change directly.",Hr:new Set([UcDd.E6e,UcDd.p1e,UcDd.V8e,UcDd.R6e]),isAvailable:a=>a.Kc.qmt(),Vj:Ucha.wf,content:"# Evaluation\n\nSurface feedback on canvas content as suggestions the user can act on, discuss, or ignore. **The only way to create, change, or resolve a suggestion is the dedicated suggestion tools.** When you call `CreateAiSuggestions`, the system renders the suggestion for you as an entry in the chat panel's suggestion list and as a callout anchored to the item on the canvas.\n\nThe capability **tracks feedback only**; it does not edit the canvas. Applying an accepted change is left to whatever editing tools are loaded (e.g. the canvas editing skill).\n\n## Working with feedback\n\n- **Each suggestion anchors to one real item.** There is no board-level suggestion — whole-board or whole-section feedback must be decomposed into individual per-item suggestions, each anchored to a real item on canvas. An item can only have one active suggestion at a time.\n- **Only raise feedback you could actually act on.** Every suggestion must resolve into a change achievable with your loaded editing tools; skip feedback that needs tools you don't have or that the canvas can't express. This applies to **contextNeeded** too — only ask when the answer could plausibly become such a change.\n- **A user answering a contextNeeded question is giving you context, not accepting a change** (an explicit accept is the user clearly agreeing — e.g. \"yes\", \"apply that\", \"do it\"). Morph it into a recommendation and wait — never resolve it as accepted or apply an edit off the back of clarification alone, and don't update and resolve the same suggestion in one turn. After morphing, tell the user the concrete change you'd make and ask them to confirm before it's applied.\n- **Resolve as accepted only once the change has actually been applied.** If no editing tools are loaded, leave the suggestion open and tell the user what edit is needed (or that an editing skill must be loaded to apply it for them). Resolve as ignored when the user dismisses it.\n- **Address each suggestion by its `itemId` from `ReadAiSuggestions` results.** When updating or resolving, use the existing id; never invent one.\n- **Bundle into single calls.** Raise several suggestions in one `CreateAiSuggestions` call (one entry per item), and resolve several in one `ResolveAiSuggestions` call, rather than a separate tool call for each.\n- **Don't restate the suggestions in chat.** Each suggestion is already surfaced to the user on the canvas, so repeating its content in a chat message is redundant. After creating suggestions, a brief pointer is all that's needed (e.g. \"I've added a few suggestions to the canvas — click any to see the details.\")."};var Ucktc={type:"System",name:UcWa.Pzr,Vj:Ucha.wf,description:"REQUIRED before creating new diagrams (NO MATTER HOW SIMPLE). Optimal workflow for generating new diagrams.",Hr:new Set([UcDd.Spb]),isAvailable:a=>a.Kc.BNo(),content:'# Generating New Diagrams\n\nROLE: Deterministic Layout Compiler.\nGOAL: Generate mathematically precise, structurally flawless diagrams.\n\n## GENERATE DIAGRAM SHORTCUT\n\nThis skill provides the GenerateDiagram tool.  You are to use the GenerateDiagram tool ONLY when you are generating one of the following diagram types.  In all other cases, follow the instructions in the rest of this skill.  This tool ONLY covers:\n- Swimlane diagrams (when the per-actor lanes are needed or specifically requested)\n- Mindmap diagrams\n- Sequence diagrams (UML)\n- Choreography diagrams\n\nALL other diagrams (flowcharts, ERDs, etc) should be handled by following these skill steps.  For the above diagram types, ignore the rest of this skill and use the GenerateDiagram tool.\nThis rule applies to new diagrams as well as editing existing ones; choose the diagram type thoughtfully and consider whether the Generate Diagram tool is appropriate.  Unless the diagram should be one of the above listed types, then using the generate diagram tool is NOT allowed.\n\n## GLOBAL CONSTRAINTS\n\n1. NO SPATIAL GUESSING: You MUST calculate exact coordinates (X, Y, W, H) before placing ANY shape.\n2. WAVE DENSITY: MANDATORY adherence to WavePlanning skill. Pack maximum tool calls per wave. NEVER spend a wave solely on ThinkAloud/TaskList. Combine thoughts with corresponding actions.\n3. FORBIDDEN TOOLS: HelpCenterFallbackTool is BANNED.\n4. AGENT LOCK: DO NOT switch to Process Agent for a quick diagram, edit, or fix — including of the user\'s own or internal process. Switch when EITHER (a) the user explicitly asks for polished/formal output — formality/polish cues or an SOP / formal process documentation (a bare "document this" is NOT enough), even for general public knowledge — OR (b) the process is specific to the user, their organization, or their situation AND the request carries documentation intent (they want it captured, written up, or formalized — signaled by documentation/SOP language, an audience who will follow it, or walking through their own steps to record them). Org-specificity is a STRONG supporting signal, but NOT a trigger on its own. Otherwise draw the diagram directly (see the Final Output step for when to offer expanding it into polished documentation).\n5. SUPPORTING DIAGRAM SKILLS: You MUST look for and ADHERE TO any relevant diagram-specific skills during your generation process (e.g. the flowchart skill for flowchart diagrams).\n6. GENERATE DIAGRAM SPECIFICITY: You may NOT use Generate Diagram tool for ANY diagram types other than those specified above.\n\n## CLARIFYING QUESTIONS WINDOW\n\n- Permitted ONLY in Step 0.\n- ONCE THE FIRST CANVAS TOOL IS CALLED: ZERO QUESTIONS ALLOWED.\n- If you hit a fork mid-build: Pick the standard interpretation, document the assumption, and KEEP BUILDING.\n\n## MANDATORY TASK LIST\n\nIn your FIRST wave, call TaskListAdd with EXACTLY these steps. Mark done (TaskListMarkDone) in the SAME WAVE as the actions completing them.\n1. Parse Topology (Semantic graph).\n2. Resolve Shape Classes & Read Sizes.\n3. Calculate Master Coordinate Sheet.\n4. Render Containers & Nodes.\n5. Route Lines.\n6. Inject Aesthetic Tokens (Colors/Styles).\n7. Canvas Audit & Polish.\n8. Canvas Audit & Polish Again (INCREDIBLY IMPORTANT).\n\n---\n\n## EXECUTION PROTOCOL (IN STRICT ORDER)\n\n### STEP 1: Parse Topology\n- Call `ThinkAloud`.\n- Extract and map nodes (ID, label, type) and edges (Source, Target, relation).\n- DO NOT discuss coordinates yet.\n- Resolve all content ambiguities NOW. Pick a diagram archetype.\n- Determine the flow of the diagram (Default to left-to-right).\n\n### STEP 2: Shape Classes & Sizes\n- Call `ShapeLibrary` using the domain term.\n- Identify the exact `blockClass` for every node.\n- Read default shape sizes. You need these to calculate math.\n\n### STEP 3: Master Coordinate Sheet (CRITICAL)\n- Use `ThinkAloud` as a math scratchpad. Calculate absolute (X, Y) centers or top-left corners for EVERY node.\n- CONSTRAINT 1 (Vertical Gap): >= 100px between adjacent block edges.\n- CONSTRAINT 2 (Horizontal Gap): >= 120px between adjacent block edges.\n- CONSTRAINT 3 (Orthogonal Alignment): Nodes in the same row MUST have identical Y values. Nodes in the same column MUST have identical X values.\n- OUTPUT: A literal text-based table mapping Node IDs to (X, Y, W, H) coordinates.\n\n### STEP 4: Render Nodes\n- Execute `CreateBlock` serially using the EXACT coordinates from Step 3.\n- Order: 1. Containers/Swimlanes -> 2. Nodes.\n- Call `EditTextArea` for labels.\n- DO NOT apply color yet.\n- THIS step is the only wave that you do NOT have to follow the maximum tool calls per wave directive.  ALL create commands can and MUST BE packed into the same wave.\n\n### STEP 5: Route Lines\n- Call `ThinkAloud` to define exact routing paths (Source -> Target, specific edge connections).\n- Emit `CreateLine`. Because Step 2 enforced orthogonal alignment, all lines MUST form clean 90-degree paths with NO diagonal clipping.\n- `validate_canvas_` to find line crossings or line-through-block issues. Fix crossings by first adjusting layout (move shapes closer to their line destinations), then use `RerouteLines` following its eligibility rules.\n- OUTPUT: A clean validation-script result that shows no line crossings, if possible.\n\n### STEP 6: Inject Aesthetics\n- Call `ThinkAloud` to define a ~3-color semantic palette. Color is REQUIRED.\n- Colors should be pastel, light, and friendly.  Light blues, greens, and purples are good for blocks, while yellow is good for decision blocks.\n- Emit `EditBlockStyle` and `EditLineStyle`.\n- Group shapes by semantic type using high-contrast fills. Use 10% opacity for container backgrounds.\n\n### STEP 7: Canvas Audit & Polish\n- Take EXACTLY ONE screenshot.\n- Call `ThinkAloud` to verify math vs reality: Did text expansion break the 100px/120px gap constraints? Are lines bent?\n- If geometry is broken: Call `MoveBlock` and reroute eligible lines in the SAME WAVE to repair offsets.\n- If lines are crossing after a reroute, IT IS A SHAPE LAYOUT ISSUE, not a line routing issue. Adjust block positions closer to their line destinations to avoid crossings.\n- **SPACING AUDIT**: Make sure no two shapes are within 100px of each other (cramped diagrams are the root cause of clutter)\n- Do not call `MessageUser` yet if STEP 8 still needs to run.\n\n### STEP 8: Canvas Audit & Polish Again\n- Read the document, `validate_canvas_` on all the shapes you\'ve worked with.\n- Fix line collisions by moving lines and shapes around to better locations.\n- Audit line connection points (THIS IS VITAL TO DO FOR EVERY SINGLE LINE).\n- Final Output: Call `MessageUser` as the sole final action, summarize your assumptions, and present the finalized diagram. If the request was genuinely *ambiguous* about whether the user wanted a quick diagram or polished process documentation — they named a specific process, mentioned an audience ("for my team"), or used soft formal language but did NOT explicitly ask for polished/formal output — close by briefly offering to expand it into polished process documentation. Do NOT make this offer for plainly casual or quick one-off diagrams ("draw a flowchart of X", "how photosynthesis works") — offering there is unnecessary nagging.\n'};var Ucltc={type:"System",name:UcWa.hNr,Vj:Ucha.wf,description:"Load whenever the user's request includes mentions of Jira cards or integrations. Load it proactively the moment you suspect Jira is needed. Do NOT ask the user to confirm.",Hr:new Set([UcDd.t4e,UcDd.T3e,UcDd.t8e,UcDd.u8e,UcDd.B2e]),isAvailable:a=>a.Kc.y7i(),content:"# Skill: Jira Card Integrations\n\nA Jira integration brings Jira issues onto the Lucid canvas as cards. Once imported or synced, those issues become ordinary Lucid cards — their fields (status, assignee, priority, sprint, dates) are readable and editable through the normal canvas tools, with no live connection required. Jira issues can have custom fields such as Story Points, Sprint, Team, etc. Reach for the tools below when a request involves pulling Jira data in, keeping cards in sync with a JQL query, or editing the data on cards that came from Jira.\n\n### When the request isn't actually about Jira\nThis skill loads eagerly on loose signals (cards, tasks, sprints, boards), so the request may not actually involve Jira. If it becomes clear the user wants something else, do NOT push the Jira tools or import/sync from Jira — step back to the right approach instead:\n- **Plain Lucid cards or general canvas edits** (creating, moving, restyling cards that aren't tied to an issue tracker) → load `canvas_editing_skill` and use the normal canvas-editing tools.\n- **A table, kanban, or tracker that isn't Jira-backed** → load `dynamic_tables`.\n- **A timeline, roadmap, or schedule that isn't Jira-backed** → load `lucid_timelines`.\n- **Sprint, PI, roadmap, or project planning not sourced from Jira** → load `project_planning`.\n- **A different integration or extension** (e.g. another issue tracker such as Azure DevOps, GitHub, Asana, or Trello) → the Jira tools here do NOT apply; don't use them as a stand-in. If no available skill covers that integration, tell the user it isn't supported rather than importing from Jira instead.\n\nOnly keep using the Jira tools when the work genuinely involves Jira-tracked issues. If the user explicitly says they don't want Jira, immediately drop the Jira approach. If the intended source is genuinely ambiguous between Jira and a distinct alternative (a different tracker, or plain cards), ask the user which they mean rather than defaulting to Jira — but don't re-ask once they've made it clear.\n\n### Tool ordering\n- `JiraSearch` must be called before `SyncJiraToTimeline`, `SyncJiraToDynamicTable`, and `ImportJiraToBoard`\n- `CanvasQuery` is how you find a card's id on the board; call it before `ReadCardData` or `EditIntegrationCardData` whenever you don't already have the card id\n- `ReadCardData` must be called before `EditIntegrationCardData`\n\n### Example requests\n- **Import Jira issues to the board.** Use `JiraSearch` to build and validate the JQL corresponding to the user's requests, then use `ImportJiraToBoard` with the JQL found earlier.\n- **Import Jira issues to a dynamic table.** If there is not an existing dynamic table, load the `dynamic_tables` skill and create one. Then use `JiraSearch` to build and validate the JQL corresponding to the user's requests, then use `SyncJiraToDynamicTable` with the JQL found earlier.\n- **Import Jira issues to a timeline.** If there is not an existing Lucid timeline, load the `lucid_timelines` skill and create one. Then use `JiraSearch` to build and validate the JQL corresponding to the user's requests, then use `SyncJiraToTimeline` with the JQL found earlier.\n- **Edit fields on an existing Jira card.** Use `CanvasQuery` to find the card matching the user's descriptions, then use `ReadCardData` to fetch the card's information, then use `EditIntegrationCardData` to edit the card's fields.\n\n### Gotchas\n- **Every import and sync tool needs a valid JQL query.** Build and validate it with `JiraSearch` first rather than guessing; if a query returns an error or no issues, fix the JQL (check the project key, field names, and status values) before retrying — don't pass an unverified query straight to an import or sync tool.\n- **Project, board, sprint, and similar names can be anything, including multiple words, and may be ambiguous.** When a user refers to one of these, treat their whole phrase as a single literal name — it may span several words and may even contain words like \"sprint\", \"board\", or \"project\" themselves (e.g. \"PS Sprint 1\", \"SCRUM Sprint 2\", \"Project Phoenix\", \"Q3 Planning\"). Don't split the phrase into separate clauses, drop words, or assume any naming pattern (such as a project key plus a number). Logically determine the most likely category each name falls into using the user's request and surrounding context (which field they're describing, which entities you've already seen, what they asked for), then build the JQL against that field and confirm it with `JiraSearch`. If the name is plausibly more than one type, try the most likely interpretation first.\n- **When you can't resolve a project, board, sprint, or other named entity, ask the user rather than guessing.** If `JiraSearch` returns an error or no matches for a name and a reasonable retry (a different field type, a corrected spelling) still doesn't find it, stop and return to the user for more exact details (the precise name, project key, or which kind of entity they mean) instead of importing or syncing against an unverified or invented value.\n- **Sync tools target a generator that already exists.** `SyncJiraToTimeline` and `SyncJiraToDynamicTable` require the `generatorId` of an existing timeline or dynamic table; they do not create one. If there is no generator yet, load `lucid_timelines` or `dynamic_tables` to create it first, then sync.\n- **`EditIntegrationCardData` is for data fields only.** Use it to change a card's structured fields (status, assignee, priority, etc.), never its visual properties (color, size, position) — those belong to the canvas-editing tools. Always `ReadCardData` first so you edit against the card's current fields rather than overwriting them blindly.\n- **Don't re-import what is already on the canvas.** Cards from a previous import or sync are ordinary Lucid cards; read, move, and edit those in place instead of importing the same issues again, which creates duplicates.\n- **Assignees and other people fields are real Jira users.** Don't invent names — leave a field unset or ask the user when the real value isn't available.\n- **Custom fields should not be guessed.** For custom fields in a Jira card, use `ReadCardData` to discover a card's real values before editing instead of guessing."};var Ucmtc={type:"System",name:UcWa.kUr,Vj:Ucha.wf,description:"Load when working with ANY timelines, roadmaps, Gantt charts, or schedules. Grants timeline-specific tools.",Hr:new Set([UcDd.u1e,UcDd.K_e,UcDd.D2e]),content:"## Working with Lucid Timelines\n\nA Lucid timeline lays Lucid cards out along a time axis — useful for project plans, sprints, roadmaps, launches, Gantt charts, and schedules. This skill grants the three timeline-specific tools below. The cards a timeline holds, and the frame around it, are created with the **canvas_editing_skill** tools, so that skill needs to be loaded too.\n\n### Match the time unit to the span\n\nThe time unit should match how long the work actually runs — a timeline whose cards span a single day should not pivot on quarters, and one spanning two years should not pivot on days. Look at the earliest `startTime` and latest `endTime` across the cards (or the date range the user gave) and pick the unit so the axis shows roughly a handful to a few dozen columns, not one fat column or hundreds of slivers. As a rule of thumb:\n\n* up to ~2 weeks → **days**\n* a few weeks to ~3 months → **weeks** (or **sprints** for agile work)\n* ~3 months to ~2 years → **months**\n* beyond ~2 years → **quarter**\n\n(`days, weeks, sprints, months, quarter` are the only valid units.)\n\n* **When setting up a timeline, fix this automatically.** Derive the unit from the span of the dates you're about to plot before calling `CreateLucidTimeline` — don't ask the user, and don't fall back to quarters by default.\n* **When editing an existing timeline, suggest a reframe rather than silently rescaling.** If the user adds or changes cards so the dates now span much less (or much more) than the current unit suits — e.g. a quarter-pivoted timeline that now only covers a single day — point out that the time frame no longer fits and offer to rescale it (and the date range) with `EditTimelineMetadata`. Only rescale outright if the user already asked you to fit the timeline to the work, or confirms the suggestion.\n\n### Timeline-specific gotchas\n\n* **A card's position and width come entirely from its `startTime` and `endTime`.** Set both (ISO `YYYY-MM-DD`) *before* adding a card to the timeline. A card with no dates collapses to the timeline's start date at a default width, so undated cards all stack on top of each other at the left edge instead of spreading across the axis.\n* **Row grouping and other pivots read off card-backed fields,** much like dynamic table pivots. Grouping by Status, Assignee, etc. only works once the cards are actually on the timeline, so apply grouping *after* placing cards, not before.\n* **Capacity planning is the timeline's most distinctive affordance for agile work.** It shows load against a per-period capacity (e.g. story points per sprint) and is what makes a timeline more than a Gantt chart. It's most meaningful when cards carry estimates and the unit is sprints.\n* **The today marker and weekend shading** are cheap context cues. The today marker only helps when the date range actually includes today; weekend shading reads well on day/week units but gets noisy on months or quarters.\n\n### Preferences\n\n* **A populated timeline beats an empty one.** When the user wants a timeline for some body of work, seeding it with dated cards shows what the tool is for; an empty axis leaves them to start over. Vary card durations and stagger start dates so tasks cascade across the range instead of lining up flat, and give cards more than a bare title (a short description, a status, an estimate when the context is agile). Only leave a timeline empty when the user explicitly asks for just an empty axis.\n* **We generally like a frame around a finished timeline.** Wrap it (pass the timeline's `generatorId` alone so it's framed as one unit) and give the frame a short, human-readable title. A timeline that already exists on the canvas may already be framed — don't double-frame it."};var Ucntc={type:"System",name:UcWa.v6r,Vj:Ucha.wf,description:"Create and edit Mermaid diagram-as-code blocks from Mermaid code. Use when the user pastes Mermaid syntax or asks to represent Mermaid on the canvas.",Hr:new Set([UcDd.yia,UcDd.wwa,UcDd.Lk,UcDd.Kmc]),content:'# Mermaid Diagram Skill\n\nMermaid diagram-as-code blocks are the Lucid canvas representation for Mermaid code. When the user pastes Mermaid syntax or asks to represent Mermaid on the canvas, use this skill.\n\n## Workflow for new diagrams\n1. Use ShapeLibrary with the search term "Mermaid" to locate the Mermaid diagram shape. The expected shape is "Mermaid diagram" with blockClass "MermaidDiagramGenerator" from library "mermaiddiagramviz.js".\n2. Create one block using blockClass "MermaidDiagramGenerator" via CreateBlock. CreateBlock reports the created generator\'s id.\n3. Set MermaidMarkup on that returned generator id using SetBlockShapeProperty. MermaidMarkup is the canonical Mermaid source for the diagram (discoverable via ShapeDetails on "MermaidDiagramGenerator"); setting it renders the diagram.\n\n## Workflow for edits\n- Inspect the existing Mermaid item with ShapeDetails on the generator id.\n- Update only MermaidMarkup unless the user explicitly asks for another canvas change.\n\n## Rules\n- Preserve the user-provided Mermaid code exactly, except for the minimal formatting needed to make it valid Mermaid.\n- Do NOT route pasted Mermaid through text-to-diagram or GenerateDiagram.'};var Ucotc={type:"System",name:UcWa.QPs,Vj:Ucha.wf,description:"Generate or edit a structured board for planning, colaborating, or any frame/section that needs a structured layout Use cases may include (but are not limited to): - retrospectives, planning boards, workshops, and agendas - SWOT analyses, comparison matrices, roadmaps, schedules, and trackers - template-like boards the user or team will later fill in - structured brainstorming with labeled sections Not for connected diagrams or unstructured brainstorming.",
Hr:new Set([UcDd.a9a,UcDd.z2e]),isAvailable:a=>!a.Kc.s0p(),content:"# Text-to-Board Skill\n\n\n## Tools\n\n- **TextToBoard** creates a new T2B-generated board from a natural-language prompt.\n- **EditBoard** revises the board generated by TextToBoard in the current conversation. It relies on the saved T2B layout\n  and rendered block IDs, so use normal canvas-editing tools for unrelated existing boards.\n\n## Prompting TextToBoard\nPass through the user's actual goal, topic, audience, constraints, and requested sections. Do not over-specify layout\ndetails unless the user gave them.\n\nWhen the user gives partial information, prefer reasonable defaults over blocking. Ask a clarifying question only when\nthe request lacks enough signal to identify the board type or topic.\n\n## Editing T2B-Generated Boards\n\nUse EditBoard when the user asks to modify the board just created from the TextToBoard tool. Use it for things such as adding sections, changing content, renaming\nframes, adjusting tables, or tailoring the board for a new audience.\n\n## Choosing TextToBoard vs. Other Tools\n- Use **TextToBoard** for structured visual workspaces: frames or sections containing sticky notes, cards, tables,\nswimlanes, timelines, or similar grouped content.\n- Use the **EditBoard** tool when the user requests changes to the board that TextToBoard just generated in this\nconversation. Do not use EditBoard for unrelated edits to an existing board or document.\n\n## Good TextToBoard fits:\n- retrospectives, planning boards, workshops, and agendas\n- SWOT analyses, comparison matrices, roadmaps, schedules, and trackers\n- template-like boards the user or team will later fill in\n- structured brainstorming with labeled sections\n\nWhen a board includes planning, tracking, or scheduling content, consider loading additional skills to enhance it:\n- For roadmaps, schedules, or Gantt charts, use the LucidTimelines skill\n\n## Use another tool or capability instead when the request is for:\n- connected diagrams such as flowcharts or ERDs\n- a single sticky note or shape\n- flat idea generation with no board structure\n\n## Response Style\n\nAfter creating or editing a board, briefly summarize what changed. Mention the board title and major sections when\nuseful."},
Ucptc={type:"System",name:UcWa.Uzs,Vj:Ucha.wf,description:"Generate or edit a structured board for planning, colaborating, or any frame/section that needs a structured layout Use cases may include (but are not limited to): - retrospectives, planning boards, workshops, and agendas - SWOT analyses, comparison matrices, roadmaps, schedules, and trackers - template-like boards the user or team will later fill in - structured brainstorming with labeled sections Not for connected diagrams or unstructured brainstorming.",
isAvailable:a=>a.Kc.s0p(),content:"# Board-Building Utility Functions\n\nThese high-level helpers handle block class loading, positioning, and layout for common board-building tasks. They are **not** pre-defined in the sandbox — if one fits your task, paste its implementation into your script. They assume `viewport` is in scope.\n\n### textToBoard(frames)\nCreates frames with optional sticky notes inside them. Frames are placed to the right of existing content. Returns `Array<{ title: string, id: string, type: \"frame\" | \"sticky\" }>`.\n\n```js\nasync function textToBoard(frames) {\n    const page = viewport.getCurrentPage();\n    if (!page) {\n        throw new Error('No active page');\n    }\n\n    await client.loadBlockClasses(['DefaultFrameBlock', 'DefaultStickyNoteBlock']);\n\n    const results = [];\n    const defaultColors = ['#6366f1', '#3b82f6', '#ec4899', '#14b8a6', '#f97316', '#8b5cf6'];\n\n    let startX = 100;\n    const blocks = [...page.allBlocks.values()];\n    if (blocks.length > 0) {\n        let rightmost = 0;\n        for (const b of blocks) {\n            const bb = b.getBoundingBox();\n            rightmost = Math.max(rightmost, bb.x + bb.w);\n        }\n        startX = rightmost + 200;\n    }\n\n    let currentX = startX;\n    const startY = 100;\n    const stickySize = 160;\n    const padding = 80;\n    const gap = 20;\n    const frameGap = 60;\n\n    for (let fi = 0; fi < frames.length; fi++) {\n        const def = frames[fi];\n        if (!def) {\n            continue;\n        }\n        const stickies = def.stickies || [];\n        const color = def.color || defaultColors[fi % defaultColors.length] || '#6366f1';\n\n        const cols = Math.max(Math.min(stickies.length || 3, 4), 2);\n        const rows = Math.max(Math.ceil((stickies.length || 3) / cols), 1);\n        const frameW = cols * (stickySize + gap) - gap + 2 * padding;\n        const frameH = rows * (stickySize + gap) - gap + 2 * padding + 80;\n\n        const frame = page.addBlock({\n            className: 'DefaultFrameBlock',\n            boundingBox: {x: currentX, y: startY, w: frameW, h: frameH},\n            properties: {\n                'LineColor': color,\n                'Rounding': 24,\n                'LineWidth': 4,\n            },\n        });\n        frame.textAreas.set('FrameTitle', def.frameTitle);\n        results.push({title: def.frameTitle, id: frame.id, type: 'frame'});\n\n        for (let si = 0; si < stickies.length; si++) {\n            const col = si % cols;\n            const row = Math.floor(si / cols);\n            const sticky = page.addBlock({\n                className: 'DefaultStickyNoteBlock',\n                boundingBox: {\n                    x: currentX + padding + col * (stickySize + gap),\n                    y: startY + padding + 80 + row * (stickySize + gap),\n                    w: stickySize,\n                    h: stickySize,\n                },\n                properties: {\n                    'FillColor': color,\n                    'LineWidth': 0,\n                },\n            });\n            const text = stickies[si] || '';\n            if (text) {\n                sticky.textAreas.set('Text', text);\n            }\n            results.push({title: text, id: sticky.id, type: 'sticky'});\n        }\n\n        currentX += frameW + frameGap;\n    }\n\n    return results;\n}\n```\n\n### putInFrameWithNudging(items, frame)\nPlaces items inside a frame, nudging existing children down to make room and expanding the frame. `items` and `frame` are entries returned by the helpers above (objects with an `id`).\n\n```js\nasync function putInFrameWithNudging(items, frame) {\n    const page = viewport.getCurrentPage();\n    if (!page) {\n        throw new Error('No active page');\n    }\n\n    const frameBlock = page.allBlocks.get(frame.id);\n    if (!frameBlock) {\n        throw new Error('Frame ' + frame.id + ' not found');\n    }\n\n    const frameBB = frameBlock.getBoundingBox();\n    const padding = 80;\n    const spacing = 20;\n\n    const itemBlocks = [];\n    let itemsTotalH = 0;\n    let itemsMaxW = 0;\n    for (const item of items) {\n        const block = page.allBlocks.get(item.id);\n        if (!block) {\n            continue;\n        }\n        const bb = block.getBoundingBox();\n        itemsTotalH += bb.h;\n        itemsMaxW = Math.max(itemsMaxW, bb.w);\n        itemBlocks.push(block);\n    }\n    if (itemBlocks.length === 0) {\n        return;\n    }\n    itemsTotalH += (itemBlocks.length - 1) * spacing;\n\n    const existingChildren = [];\n    for (const [, block] of page.allBlocks) {\n        if (block.id === frameBlock.id) {\n            continue;\n        }\n        const containers = block.getContainers();\n        for (const c of containers) {\n            if (c.id === frameBlock.id) {\n                existingChildren.push(block);\n                break;\n            }\n        }\n    }\n\n    const nudgeAmount = itemsTotalH + spacing;\n    for (const child of existingChildren) {\n        const bb = child.getBoundingBox();\n        child.setBoundingBox({x: bb.x, y: bb.y + nudgeAmount, w: bb.w, h: bb.h});\n    }\n\n    let placeY = frameBB.y + padding + 80;\n    const placeX = frameBB.x + padding;\n    for (const block of itemBlocks) {\n        const bb = block.getBoundingBox();\n        block.setBoundingBox({x: placeX, y: placeY, w: bb.w, h: bb.h});\n        placeY += bb.h + spacing;\n    }\n\n    const neededH = frameBB.h + nudgeAmount;\n    const neededW = Math.max(frameBB.w, itemsMaxW + 2 * padding);\n    frameBlock.setBoundingBox({\n        x: frameBB.x,\n        y: frameBB.y,\n        w: neededW,\n        h: neededH,\n    });\n}\n```\n\n## Tips\n\n- Always load block classes BEFORE creating blocks\n- Return IDs (not proxy objects) when you need them in a later call — there is no persistent state\n- Use console.log() to debug — output is returned to you\n- Always use `measureText()` to size blocks — never guess text dimensions\n- Build complex diagrams step by step across multiple run_script calls\n"};var Ucqtc={type:"System",name:UcWa.SPs,Vj:Ucha.wf,description:"REQUIRED for ANY new diagram generation based on a natural language description for the following diagram types: flowcharts, sequence diagrams, class diagrams, ERDs, mind maps, conversation diagrams, choreography diagrams, swimlanes, and cloud architecture diagrams.",Hr:new Set([UcDd.Spb]),isAvailable:a=>!a.Kc.BNo(),content:'# Text to Diagram Skill\n\nUse this skill when the user describes a diagram they want created from text.\n\n## Workflow\n\n- Use **generate_diagram** tool for new diagrams requested in natural language.\n- Preserve the user\'s requested diagram type, domain details, relationships, labels, style preferences, and layout constraints in the prompt.\n- Make the prompt self-contained. Include the important context the user provided instead of relying on vague references like "the above."\n- Ask a clarifying question only when the request is too ambiguous to produce a useful first draft.\n\n## Related diagram paths\n\n- If the user wants a diagram based on existing linked data or data-backed shapes, load the semantic-data skill and use its data-backed diagram guidance.\n- If the user wants to edit an existing diagram rather than create a new one, load the canvas editing skill. Only pass an existing diagram ID to **generate_diagram** tool when the user just created that diagram with **generate_diagram** tool in this conversation and asks to regenerate it.\n- If the user is asking for you to recreate a diagram in a provided image, load and utilize the DiagramsFromImagesSkill and CanvasEditingSkill; do NOT use the GenerateDiagram tool.\n- If the user is asking specifically for a "Fishbone" diagram, load and utilize the FishboneDiagramLayoutSkill and CanvasEditingSkill; do NOT use the GenerateDiagram tool.'};var Ucrtc={type:"System",name:UcWa.$Ws,isAvailable:a=>a.Kc.wSa(),Vj:Ucha.wf,description:"Canvas validation scripting guidance. Use when checking a canvas for visual quality issues, including but not limited to overlaps, spacing, dangling lines, and unreadable text.",Hr:new Set([UcDd.FHc,UcDd.dIc]),content:"# Validate Canvas Skill\n\nThe document can be huge and complex.  Loading the entire document may completely fill your context.  You can read everything yourself and look for problems, or you can run a script to check for problems on the canvas for you.\n\nWhen this skill is loaded after a canvas edit, validation is a completion gate.  Do not send the final completion message until you have run a focused validation script for the issue types implied by the edit, or until you can clearly explain why validation is not possible.\n\nPrefer validation scripts instead of screenshots.  Screenshots take a long time to process and aren't guaranteed to show the issues.\n\n## Recommended workflow\n\n1. Build and run a focused validation script.\n- Start by asking what changed on the canvas and what visual or structural issues those changes could have introduced.\n- Load the current page in the script, then gather the blocks, lines, generators, or other canvas items needed for the checks.\n- Check for relevant issues such as block overlaps, tight spacing, dangling lines, unreadable text, poor text contrast, or any other quality problems implied by the edit.\n- Return a compact JSON result.  For each issue, include the issue type, severity when useful, a short description, and the relevant item labels or IDs needed for your next action.\n- Combine related checks in one script when practical, so the result gives you one clear list of issues to reason from.\n\n2. Interpret the validation result before acting.\n- Treat the returned issues as inputs to a repair plan, not as a final answer to the user.\n- Decide which issues are real problems, which are intentional, and which can be safely ignored.\n- When planning a fix, consider the whole nearby layout so a repair does not introduce new overlaps, spacing problems, dangling lines, or unreadable text.\n- Make the repair and update other affected items in the same script to avoid creating new problems (e.g., if you move a block, also move blocks it would cover or move parts of the diagram out of the way)\n\n3. Fix practical issues and verify your fixes.\n- If an issue should be fixed, use a targeted script to repair it.\n- Fix all issues at once.  Don't fix one thing, then move to the next.\n- Fix and validate a fix in a single script (fix and validate fix).  No need to do two separate scripts (fix then validate fix).\n- If an issue cannot be fixed reliably, report it to the user with a concise manual-fix suggestion.\n- Do not mention ignored or intentionally acceptable issues unless they affect the user's requested outcome.\n\n## Pre-created scripts\n\nYou have access to a set of pre-created validation scripts through the Validate Canvas tool.  Use this tool only for validation which can't be accomplished through scripting.\n\nExamples of validators included here that are hard to script are:\n- Text overflow (text that is cut off or hidden) If you encounter any text issues, make sure you load the shape's details so you can understand how to fix the issue.  Some blocks with multiple text areas may have issues with one text area but not another.\n- Text color contrast (text that is hard to read due to low contrast with the shape's background color)\n\n## Example validation scripts\n\nUse these as patterns, not as the only validators you can write.  Return compact JSON with enough detail to decide what to fix next.  Prefer readable labels in the result, and avoid returning raw SDK objects.\n\n### Example 1: block overlap and spacing\n\n~~~javascript\nconst viewport = new sdk.Viewport(client);\nconst page = viewport.getCurrentPage();\nif (!page) throw new Error('No active page');\n\nfunction label(block) {\n    return ((block.textAreas.get('Text') || block.textAreas.get('FrameTitle') || '') + '').trim() || block.getClassName();\n}\n\nfunction rect(block) {\n    const b = block.getBoundingBox();\n    return {x: b.x, y: b.y, w: b.w, h: b.h};\n}\n\nconst minimumGap = 120;\n\nfunction blockDirectionAndDistance(a, b) {\n    const gapX = Math.max(a.x - (b.x + b.w), b.x - (a.x + a.w));\n    const gapY = Math.max(a.y - (b.y + b.h), b.y - (a.y + a.h));\n    const centerA = {x: a.x + a.w / 2, y: a.y + a.h / 2};\n    const centerB = {x: b.x + b.w / 2, y: b.y + b.h / 2};\n\n    const currentGap = Math.round(Math.max(gapX, gapY));\n\n    return {\n        currentGap,\n        overlapWidth: Math.round(Math.max(0, -gapX)),\n        overlapHeight: Math.round(Math.max(0, -gapY)),\n    };\n}\n\nconst blocks = [...page.allBlocks.values()].map((block) => ({block, label: label(block), rect: rect(block)}));\nconst issues = [];\n\nfor (let i = 0; i < blocks.length; i++) {\n    for (let j = i + 1; j < blocks.length; j++) {\n        const a = blocks[i];\n        const b = blocks[j];\n        const separation = blockDirectionAndDistance(a.rect, b.rect);\n        if (separation.currentGap < 0) {\n            issues.push({\n                type: 'block-overlap',\n                items: [a.label, b.label],\n                separation,\n            });\n        } else {\n            if (separation.currentGap < minimumGap) {\n                issues.push({type: 'tight-spacing', items: [a.label, b.label], separation});\n            }\n        }\n    }\n}\n\nreturn {checkedBlocks: blocks.length, issues: issues.slice(0, 50)};\n~~~\n\n### Example 2: dangling connector endpoints\n\n~~~javascript\nconst viewport = new sdk.Viewport(client);\nconst page = viewport.getCurrentPage();\nif (!page) throw new Error('No active page');\n\nconst issues = [];\nfor (const line of page.allLines.values()) {\n    const endpoint1 = line.getEndpoint1();\n    const endpoint2 = line.getEndpoint2();\n    if (!endpoint1.connection || !endpoint2.connection) {\n        issues.push({\n            severity: 'high',\n            type: 'dangling-line',\n            lineId: line.id,\n            endpoint1Connected: !!endpoint1.connection,\n            endpoint2Connected: !!endpoint2.connection,\n        });\n    }\n}\n\nreturn {checkedLines: page.allLines.size, issues};\n~~~\n\n### Example 3: orphan blocks, disconnected graph components, and flow direction\n\n~~~javascript\nconst viewport = new sdk.Viewport(client);\nconst page = viewport.getCurrentPage();\nif (!page) throw new Error('No active page');\n\n// Change this to 'left-to-right' when validating a horizontal flow.\nconst expectedDirection = 'top-to-bottom';\nconst allBlocks = [...page.allBlocks.values()];\nconst labels = new Map();\nconst centers = new Map();\nconst adjacency = new Map();\nconst issues = [];\n\nfunction label(block) {\n    return ((block.textAreas.get('Text') || block.textAreas.get('FrameTitle') || '') + '').trim() || block.getClassName();\n}\n\nfunction center(block) {\n    const b = block.getBoundingBox();\n    return {x: b.x + b.w / 2, y: b.y + b.h / 2};\n}\n\nfor (const block of allBlocks) {\n    labels.set(block.id, label(block));\n    centers.set(block.id, center(block));\n    adjacency.set(block.id, new Set());\n}\n\nconst backwardEdges = [];\nfor (const line of page.allLines.values()) {\n    const endpoint1 = line.getEndpoint1();\n    const endpoint2 = line.getEndpoint2();\n    if (!endpoint1.connection || !endpoint2.connection) continue;\n    const a = endpoint1.connection.id;\n    const b = endpoint2.connection.id;\n    if (!adjacency.has(a) || !adjacency.has(b)) continue;\n    adjacency.get(a).add(b);\n    adjacency.get(b).add(a);\n\n    const source = centers.get(a);\n    const target = centers.get(b);\n    const goesBackward =\n        expectedDirection === 'top-to-bottom' ? target.y < source.y - 10 : target.x < source.x - 10;\n    if (goesBackward) {\n        backwardEdges.push({from: labels.get(a), to: labels.get(b), lineId: line.id});\n    }\n}\n\nconst orphanLabels = allBlocks.filter((block) => adjacency.get(block.id).size === 0).map(label);\nfor (const orphanLabel of orphanLabels) {\n    issues.push({severity: 'high', type: 'orphan-block', items: [orphanLabel]});\n}\n\nconst visited = new Set();\nconst components = [];\nfor (const block of allBlocks) {\n    if (visited.has(block.id) || adjacency.get(block.id).size === 0) continue;\n    const stack = [block.id];\n    const component = [];\n    visited.add(block.id);\n    while (stack.length > 0) {\n        const id = stack.pop();\n        component.push(labels.get(id));\n        for (const next of adjacency.get(id)) {\n            if (visited.has(next)) continue;\n            visited.add(next);\n            stack.push(next);\n        }\n    }\n    components.push(component);\n}\n\nif (components.length > 1) {\n    issues.push({\n        severity: 'medium',\n        type: 'disconnected-components',\n        componentCount: components.length,\n        sampleComponents: components.slice(0, 4).map((component) => component.slice(0, 6)),\n    });\n}\n\nif (backwardEdges.length > 0) {\n    issues.push({\n        severity: 'medium',\n        type: 'backward-flow-edges',\n        expectedDirection,\n        sampleEdges: backwardEdges.slice(0, 10),\n    });\n}\n\nreturn {checkedBlocks: allBlocks.length, connectedComponentCount: components.length, issues};\n~~~\n"};var Ucstc={type:"System",name:UcWa.FYs,Vj:Ucha.wf,description:"Create, inspect, delete, and replace visual activities. REQUIRED for working with visual activities.",Hr:new Set([UcDd.z7a,UcDd.qZ,UcDd.wwa,UcDd.Kmc,UcDd.zAb]),content:"# Visual Activity Skill\n\n## Creating and Editing Visual Activities\n\n- Create new visual activities with **CreateVisualActivity**.\n- Use **CanvasQuery** or **ShapeDetails** to inspect existing visual activities before changing them.\n- Most new visual activities are one-axis, two-axis, or multi-category activities with one to many draggable blocks.\n- For structural edits or changes to the activity type, prefer deleting the existing activity with **DeleteItem** and creating a replacement with **CreateVisualActivity**.\n- Use **SetBlockShapeProperty** only for small property updates that the visual activity schema explicitly supports."};var Ucttc=Ucfb({name:Uch,oauthProviderName:Uch,callbackBaseUrl:Uch,dataActions:Uchb(Uch),spreadsheet:Uckb(Ucfb({allowEmptyPrimaryKey:Uc1a}))});function UcFg(){this.Eem="";this.eAs=UcFg.Z8a;this.gto=null}UcFg.yyd=!1;UcFg.JBs=!0;UcFg.prototype.QBl=!0;UcFg.prototype.puc=function(){return this.gto};UcFg.prototype.uRc=!0;UcFg.prototype.ZTb=function(){return this.Eem.toString()};UcFg.unwrap=function(a){return Ucutc(a).toString()};function Ucutc(a){if(a instanceof UcFg&&a.constructor===UcFg&&a.eAs===UcFg.Z8a)return a.Eem;UcC5a(a);return"type_error:SafeHtml"}
