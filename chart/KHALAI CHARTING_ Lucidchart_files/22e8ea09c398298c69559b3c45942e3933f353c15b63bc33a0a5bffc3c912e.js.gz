Claim license\",\"on-request-cta-claim-license-tooltip\":\"Claim a license to unlock the Lucid Suite.\",\"onboarding-tip-content-close-aria-label\":\"Close\",\"page-switcher-back-aria-label\":\"Back\",\"page-switcher-back-month-aria-label\":\"Navigate back one month\",\"page-switcher-back-ten-years-aria-label\":\"Navigate back ten years\",\"page-switcher-back-year-aria-label\":\"Navigate back one year\",\"page-switcher-forward-aria-label\":\"Forward\",\"page-switcher-forward-month-aria-label\":\"Navigate forward one month\",\"page-switcher-forward-ten-years-aria-label\":\"Navigate forward ten years\",\"page-switcher-forward-year-aria-label\":\"Navigate forward one year\",\"page-switcher-select-month-aria-label\":\"Select month\",\"page-switcher-select-year-aria-label\":\"Select year\",\"pagination-footer-summary\":\"{start}-{end} of {total}\",\"pagination-footer-summary-short.one\":\"{count} result\",\"pagination-footer-summary-short.other\":\"{count} results\",\"person-tag-upload\":\"Upload\",\"pl-PL--blank-document-default-title-chart\":\"Pusty diagram\",\"pl-PL--blank-document-default-title-scale\":\"Model bez tytułu\",\"pl-PL--blank-document-default-title-spark\":\"Pusta tablica\",\"pl-PL--quick-action-switch-to-diagramming-title\":\"Przełącz na tworzenie diagramów\",\"pl-PL--quick-action-switch-to-whiteboarding-title\":\"Przejdź na tablicę\",\"pl-PL--user-attribution-guest-label\":\"Gość: {name}\",\"platform-share-header-unlock-full-access\":\"Unlock full access\",\"product-activation-dialog-bullet-one-chart\":\"Find the right shapes for any diagram—flowcharts, ERDs, and more.\",\"product-activation-dialog-bullet-one-spark\":\"Capture ideas quickly with sticky notes and freehand drawing.\",\"product-activation-dialog-bullet-three-chart\":\"Share your work and collaborate with your team in real time.\",\"product-activation-dialog-bullet-three-spark\":\"Take action by grouping your ideas and exporting them to Lucidchart.\",\"product-activation-dialog-bullet-two-c