# Discord OAuth Application
DISCORD_CLIENT_ID=
DISCORD_CLIENT_SECRET=

# Discord Bot (for guild membership verification)
DISCORD_BOT_TOKEN=
DISCORD_GUILD_ID=

# Comma-separated Discord User IDs with super-admin access
ADMIN_DISCORD_IDS=

# Supabase
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=

# Postgres connection string (get from Supabase → Settings → Database → URI tab)
# Special chars in password MUST be percent-encoded: ! → %21, ) → %29, @ → %40
DATABASE_URL=postgresql://postgres.your-project:password@aws-0-region.pooler.supabase.com:5432/postgres

# Public site URL (used for OAuth redirect URIs and absolute URLs)
NEXT_PUBLIC_SITE_URL=https://kmhq.org

# Session secret for admin cookies (optional — falls back to DISCORD_CLIENT_SECRET)
ADMIN_SESSION_SECRET=

# Payload CMS JWT secret (optional — has built-in fallback)
PAYLOAD_SECRET=
